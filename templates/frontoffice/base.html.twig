<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>{% block title %}Mon Application{% endblock %}</title>
    <link href="{{ asset('simpleUsr/css/styles.css') }}" rel="stylesheet" />
    <style>
        /* =========================================
           SIDEBAR STYLES
        ========================================= */
        #sidebar-wrapper {
            background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
            min-height: 100vh;
        }

        .sidebar-inner {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Brand */
        .sidebar-heading {
            background: transparent !important;
            border-bottom: 1px solid rgba(255,255,255,0.1) !important;
            padding: 1.2rem 1.25rem !important;
        }

        .brand-logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .brand-icon {
            font-size: 1.4rem;
        }

        .brand-text {
            color: #ffffff;
            font-size: 1.1rem;
            font-weight: 700;
            letter-spacing: 0.05em;
        }

        /* Profile */
        .sidebar-profile {
            padding: 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            text-align: center;
        }

        .avatar {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 0.6rem;
            font-size: 1.4rem;
            color: white;
            font-weight: bold;
            border: 2px solid rgba(255,255,255,0.2);
        }

        .user-name {
            color: #ffffff;
            font-weight: 600;
            font-size: 0.88rem;
            margin-bottom: 0.25rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            max-width: 160px;
            margin: 0 auto 0.25rem;
        }

        .user-role {
            display: inline-block;
            background: rgba(102,126,234,0.3);
            color: #a5b4fc;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            margin-top: 0.25rem;
        }

        /* Nav */
        .sidebar-section-label {
            padding: 1rem 1.25rem 0.4rem;
            color: rgba(255,255,255,0.3);
            font-size: 0.68rem;
            text-transform: uppercase;
            letter-spacing: 0.12em;
            font-weight: 600;
        }

        .sidebar-nav .list-group-item {
            background: transparent !important;
            border: none !important;
            border-left: 3px solid transparent !important;
            color: rgba(255,255,255,0.6) !important;
            padding: 0.8rem 1.25rem !important;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            font-size: 0.88rem;
            font-weight: 500;
            transition: all 0.2s ease;
            text-decoration: none;
        }

        .sidebar-nav .list-group-item:hover {
            color: #ffffff !important;
            background: rgba(255,255,255,0.07) !important;
            border-left-color: rgba(102,126,234,0.6) !important;
        }

        .sidebar-nav .list-group-item.active {
            color: #ffffff !important;
            background: rgba(102,126,234,0.2) !important;
            border-left-color: #667eea !important;
        }

        .nav-icon {
            width: 18px;
            text-align: center;
            flex-shrink: 0;
            opacity: 0.85;
        }

        /* Logout */
        .sidebar-logout {
            padding: 1rem 1.25rem 1.5rem;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .btn-logout {
            width: 100%;
            background: rgba(220,53,69,0.12);
            color: #fc8181 !important;
            border: 1px solid rgba(220,53,69,0.25);
            padding: 0.6rem 1rem;
            border-radius: 8px;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            text-decoration: none !important;
            transition: all 0.2s ease;
            font-weight: 500;
        }

        .btn-logout:hover {
            background: rgba(220,53,69,0.25) !important;
            color: #ffffff !important;
            border-color: rgba(220,53,69,0.5) !important;
        }

        /* =========================================
           NAVBAR STYLES
        ========================================= */
        .top-navbar {
            background: #ffffff !important;
            border-bottom: 1px solid #e9ecef !important;
            padding: 0.5rem 1.5rem !important;
            box-shadow: 0 1px 8px rgba(0,0,0,0.06);
        }

        .btn-toggle {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            color: #6c757d;
            padding: 0.45rem 0.7rem;
            border-radius: 8px;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }

        .btn-toggle:hover {
            background: #e9ecef;
            color: #343a40;
        }

        .page-title-text {
            font-size: 0.95rem;
            font-weight: 600;
            color: #343a40;
        }

        /* Search */
        .search-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .search-icon {
            position: absolute;
            left: 10px;
            color: #adb5bd;
        }

        .search-input {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 20px;
            padding: 0.4rem 1rem 0.4rem 2rem;
            font-size: 0.85rem;
            color: #495057;
            width: 220px;
            outline: none;
            transition: all 0.2s ease;
        }

        .search-input:focus {
            border-color: #667eea;
            background: #ffffff;
            box-shadow: 0 0 0 3px rgba(102,126,234,0.1);
            width: 260px;
        }

        /* Icon buttons */
        .icon-btn {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 8px;
            padding: 0.45rem 0.6rem;
            color: #6c757d;
            cursor: pointer;
            transition: all 0.2s ease;
            display: flex;
            align-items: center;
        }

        .icon-btn:hover {
            background: #e9ecef;
            color: #343a40;
        }

        .notif-badge {
            position: absolute;
            top: -4px;
            right: -4px;
            background: #dc3545;
            color: white;
            font-size: 0.6rem;
            width: 16px;
            height: 16px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            border: 2px solid white;
        }

        /* User dropdown button */
        .user-dropdown-btn {
            background: #f8f9fa;
            border: 1px solid #e9ecef;
            border-radius: 10px;
            padding: 0.35rem 0.75rem 0.35rem 0.45rem;
            display: flex;
            align-items: center;
            gap: 0.6rem;
            cursor: pointer;
            transition: all 0.2s ease;
        }

        .user-dropdown-btn:hover {
            background: #e9ecef;
        }

        .user-dropdown-btn::after {
            display: none;
        }

        .user-avatar-sm {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            font-weight: 700;
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .user-name-sm {
            font-size: 0.82rem;
            font-weight: 600;
            color: #343a40;
            max-width: 120px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .user-role-sm {
            font-size: 0.7rem;
            color: #6c757d;
        }

        .dropdown-caret {
            color: #adb5bd;
            margin-left: 2px;
        }

        /* Dropdown menu */
        .dropdown-header-info {
            padding: 0.5rem 1rem;
        }

        .dh-name {
            font-size: 0.85rem;
            font-weight: 600;
            color: #343a40;
        }

        .dh-role {
            font-size: 0.75rem;
            color: #6c757d;
        }

        .dropdown-item {
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            padding: 0.5rem 1rem;
        }

        .dropdown-item:hover {
            background: #f8f9fa;
        }

        /* =========================================
           LAYOUT
        ========================================= */
        body, html {
            height: 100%;
        }

        #wrapper {
            min-height: 100vh;
        }

        #page-content-wrapper {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            flex: 1;
        }

        .page-content {
            flex: 1;
            padding: 1.5rem;
            background: #f8f9fa;
        }

        /* Flash messages */
        .flash-container {
            padding: 0 1.5rem;
            margin-top: 0.75rem;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<div class="d-flex" id="wrapper">

    {# ===== SIDEBAR ===== #}
    {% include 'frontoffice/partials/_sidebar.html.twig' %}

    {# ===== CONTENU PRINCIPAL ===== #}
    <div id="page-content-wrapper">

        {# NAVBAR #}
        {% include 'frontoffice/partials/_navbar.html.twig' %}

        {# FLASH MESSAGES #}
        <div class="flash-container">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}
        </div>

        {# CONTENU PAGE #}
        <div class="page-content">
            {% block body %}{% endblock %}
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('simpleUsr/js/scripts.js') }}"></script>
{% block javascripts %}{% endblock %}

</body>
</html>