{# templates/frontoffice/partials/_sidebar.html.twig #}



<div class="border-end" id="sidebar-wrapper">
    <div class="sidebar-inner">

        {# ===== LOGO / BRAND ===== #}
        <div class="sidebar-heading">
            <div class="brand-logo">
                <span class="brand-text">ESPRI TECH</span>
            </div>
        </div>

       {# ===== PROFILE SECTION — utilisateur réel ===== #}
<div class="sidebar-profile">
    <div class="avatar">
        {{ app.user.username|first|upper }}
    </div>
    <div class="user-name">
        {{ app.user.username }}
    </div>
    <div class="user-role">
        {% if app.user.role == 'ADMINISTRATEUR' %}Administrateur
        {% elseif app.user.role == 'MANAGER' %}Manager
        {% elseif app.user.role == 'EMPLOYE' %}Employé
        {% else %}Utilisateur{% endif %}
    </div>
</div>

        {# ===== NAVIGATION ===== #}
        <div class="sidebar-nav">

            <div class="sidebar-section-label">NAVIGATION</div>

            <div class="list-group list-group-flush">

                {# Dashboard #}
                <a href="{{ path('app_frontoffice_index') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') == 'app_frontoffice_index' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 3.293 1 9.5V15h5v-4h4v4h5V9.5L8 3.293zM8 1.707l7 6.563V16H9v-4H7v4H1V8.27L8 1.707z"/>
                        </svg>
                    </span>
                    Dashboard
                </a>

                {# Formations #}
                <a href="{{ path('app_frontoffice_trainings') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') == 'app_frontoffice_trainings' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828z"/>
                        </svg>
                    </span>
                    Formations
                </a>

                {# Recrutements #}
                <a href="#" class="list-group-item list-group-item-action" onclick="alert('Page Recrutement en construction'); return false;">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                            <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                            <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                        </svg>
                    </span>
                    Recrutements
                </a>

                {# Salaires #}
                <a href="#" class="list-group-item list-group-item-action" onclick="alert('Page Salaires en construction'); return false;">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718H4z"/>
                        </svg>
                    </span>
                    Salaires
                </a>

                {# Projets #}
                <a href="#" class="list-group-item list-group-item-action" onclick="alert('Page Projets en construction'); return false;">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1h-7zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6v7z"/>
                        </svg>
                    </span>
                    Projets
                </a>

            </div>

            {# ===== SECTION MON COMPTE ===== #}
            <div class="sidebar-section-label" style="margin-top: 0.5rem;">MON COMPTE</div>

            <div class="list-group list-group-flush">
                <a href="#" class="list-group-item list-group-item-action" onclick="alert('Page Profil en construction'); return false;">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </span>
                    Mon Profil
                </a>
            </div>

        </div>

        {# ===== SEPARATEUR ===== #}
        <div style="flex: 1;"></div>

        {# ===== LOGOUT ===== #}
<div class="sidebar-logout">
    <a href="{{ path('app_logout') }}" class="btn-logout" onclick="return confirm('Voulez-vous vraiment vous déconnecter ?');">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
            <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
            <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
        </svg>
        Déconnexion
    </a>
</div>

    </div>
</div>