{# templates/frontoffice/partials/_sidebar.html.twig #}

{# ── Lecture des données utilisateur depuis la session fake ── #}
{% set fake_name  = app.session.get('fake_user_name')  ?? 'Utilisateur' %}
{% set fake_email = app.session.get('fake_user_email') ?? '' %}
{% set fake_role  = app.session.get('fake_user_role')  ?? '' %}

<div class="border-end" id="sidebar-wrapper">
    <div class="sidebar-inner">

        {# ===== LOGO / BRAND ===== #}
        <div class="sidebar-heading">
            <div class="brand-logo">
                <img src="{{ asset('images/logo.png') }}"
                    alt="Logo"
                    class="brand-icon"
                    style="width: 30px; height: 30px; object-fit: contain;">
                
                <span class="brand-text">MyApp</span>
            </div>
        </div>

        {# ===== PROFILE SECTION — session fake ===== #}
        <div class="sidebar-profile">
            <div class="avatar">
                {{ fake_name|first|upper }}
            </div>
            <div class="user-name">
                {{ fake_name }}
            </div>
            <div class="user-role">
                {% if fake_role == 'ADMINISTRATEUR' %}Administrateur
                {% elseif fake_role == 'MANAGER' %}Manager
                {% elseif fake_role == 'EMPLOYE' %}Employé
                {% else %}Invité{% endif %}
            </div>
        </div>

        {# ===== NAVIGATION ===== #}
        <div class="sidebar-nav">

            <div class="sidebar-section-label">Navigation</div>

            <div class="list-group list-group-flush">

                {# Dashboard #}
                <a href="{{ path('app_dashboard') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') == 'app_dashboard' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 3.293 1 9.5V15h5v-4h4v4h5V9.5L8 3.293zM8 1.707l7 6.563V16H9v-4H7v4H1V8.27L8 1.707z"/>
                        </svg>
                    </span>
                    Dashboard
                </a>

                {# Formations #}
                <a href="{{ path('app_formations') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') starts with 'app_formations' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
                        </svg>
                    </span>
                    Formations
                </a>

                {# Recrutements #}
                <a href="{{ path('app_recrutements') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') starts with 'app_recrutements' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"/>
                            <path fill-rule="evenodd" d="M5.216 14A2.238 2.238 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.325 6.325 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1h4.216z"/>
                            <path d="M4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5z"/>
                        </svg>
                    </span>
                    Recrutements
                </a>

                {# Salaires #}
                <a href="{{ path('app_salaires') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') starts with 'app_salaires' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718H4zm3.391-3.836c-1.043-.263-1.6-.825-1.6-1.616 0-.944.704-1.641 1.8-1.828v3.495l-.2-.05zm1.591 1.872c1.287.323 1.852.859 1.852 1.769 0 1.097-.826 1.828-2.2 1.939V8.73l.348.086z"/>
                        </svg>
                    </span>
                    Salaires
                </a>

                {# Projets #}
                <a href="{{ path('app_projets') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') starts with 'app_projets' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M2.5 3.5a.5.5 0 0 1 0-1h11a.5.5 0 0 1 0 1h-11zm2-2a.5.5 0 0 1 0-1h7a.5.5 0 0 1 0 1h-7zM0 13a1.5 1.5 0 0 0 1.5 1.5h13A1.5 1.5 0 0 0 16 13V6a1.5 1.5 0 0 0-1.5-1.5h-13A1.5 1.5 0 0 0 0 6v7zm1.5.5A.5.5 0 0 1 1 13V6a.5.5 0 0 1 .5-.5h13a.5.5 0 0 1 .5.5v7a.5.5 0 0 1-.5.5h-13z"/>
                        </svg>
                    </span>
                    Projets
                </a>

            </div>

            {# ===== SECTION COMPTE ===== #}
            <div class="sidebar-section-label" style="margin-top: 0.5rem;">Mon Compte</div>

            <div class="list-group list-group-flush">
                <a href="{{ path('app_profile') }}"
                   class="list-group-item list-group-item-action {{ app.request.get('_route') == 'app_profile' ? 'active' : '' }}">
                    <span class="nav-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                            <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10z"/>
                        </svg>
                    </span>
                    Mon Profil
                </a>
            </div>
        </div>

        {# ===== SPACER ===== #}
        <div style="flex: 1;"></div>

        {# ===== LOGOUT — pointe vers fake_logout ===== #}
        <div class="sidebar-logout">
            <a href="{{ path('fake_logout') }}" class="btn-logout">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0v2z"/>
                    <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708l3-3z"/>
                </svg>
                Déconnexion
            </a>
        </div>

    </div>
</div>
