{# templates/frontoffice/dashboard.html.twig #}
{% extends 'frontoffice/base.html.twig' %}

{% block title %}Dashboard - Mon Espace{% endblock %}

{% set fake_name = app.session.get('fake_user_name') ?? 'Utilisateur' %}
{% set fake_role = app.session.get('fake_user_role') ?? '' %}

{% block body %}
    <h1 class="mt-4">
        <i class="bi bi-speedometer2 me-2"></i>Dashboard
    </h1>
    <p class="text-muted">
        Bienvenue <strong>{{ fake_name }}</strong>
        <span class="badge bg-{{
            fake_role == 'ADMINISTRATEUR' ? 'danger' :
            fake_role == 'MANAGER' ? 'warning' : 'success'
        }}">{{ fake_role }}</span>
    </p>

    <div class="row mt-4">

        {# Carte Formations #}
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-4 border-primary shadow h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted text-uppercase small mb-1">Formations</div>
                            <div class="h4 mb-0 fw-bold">—</div>
                        </div>
                        <div class="text-primary fs-2"><i class="bi bi-mortarboard"></i></div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="{{ path('app_formations') }}" class="text-primary text-decoration-none small">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte Salaires #}
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-4 border-success shadow h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted text-uppercase small mb-1">Bulletins</div>
                            <div class="h4 mb-0 fw-bold">—</div>
                        </div>
                        <div class="text-success fs-2"><i class="bi bi-cash-stack"></i></div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="{{ path('app_salaires') }}" class="text-success text-decoration-none small">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte Projets #}
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-4 border-warning shadow h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted text-uppercase small mb-1">Projets</div>
                            <div class="h4 mb-0 fw-bold">—</div>
                        </div>
                        <div class="text-warning fs-2"><i class="bi bi-kanban"></i></div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="{{ path('app_projets') }}" class="text-warning text-decoration-none small">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte Recrutement #}
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-start border-4 border-info shadow h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="text-muted text-uppercase small mb-1">Candidatures</div>
                            <div class="h4 mb-0 fw-bold">—</div>
                        </div>
                        <div class="text-info fs-2"><i class="bi bi-people"></i></div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <a href="{{ path('app_recrutements') }}" class="text-info text-decoration-none small">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
{% endblock %}
