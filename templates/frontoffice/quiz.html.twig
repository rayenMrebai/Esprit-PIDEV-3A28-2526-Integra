{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Mes quiz – ESPRI TECH{% endblock %}

{% block page_heading %}Mes Quiz{% endblock %}
{% block page_subheading %}Consultez vos résultats et tentatives de quiz{% endblock %}

{% block content %}

    <div class="post-preview">
        <h2 class="post-title" style="color: #0B63CE;">
            <i class="fas fa-question-circle me-2"></i>Résultats des quiz
        </h2>
        <p class="post-subtitle">Retrouvez ici l'historique de tous vos quiz effectués.</p>
    </div>
    <hr class="my-4" />

    {% for quiz in quizResults %}
        <div class="post-preview">
            <!-- Titre : formation liée -->
            <h3 class="post-title" style="color: #0B63CE;">
                {{ quiz.training is defined and quiz.training ? quiz.training.title : 'Formation inconnue' }}
            </h3>

            <!-- Score affiché en sous-titre -->
            <p class="post-subtitle">
                Score obtenu : <strong>{{ quiz.score }} / {{ quiz.totalQuestions }}</strong>
            </p>

            <!-- Barre de progression -->
            <div class="skill-progress-wrap mb-2">
                <div class="progress" style="height: 8px; border-radius: 10px; background: #e9ecef;">
                    <div class="progress-bar"
                        style="width: {{ quiz.percentage }}%; border-radius: 10px;
                        background: {{ quiz.percentage >= 60 ? '#0FA36B' : '#dc3545' }};">
                    </div>
                </div>
                <small class="text-muted">{{ quiz.percentage }}%</small>
            </div>

            <p class="post-meta">
                <!-- Réussi / Échoué -->
                <span class="badge-status"
                    style="background: {{ quiz.passed ? '#0FA36B' : '#dc3545' }}; color: white;">
                    {{ quiz.passed ? '✅ Réussi' : '❌ Échoué' }}
                </span>

                <!-- Date -->
                <span class="ms-3">
                    <i class="far fa-calendar-alt"></i>
                    {{ quiz.completedAt is defined and quiz.completedAt ? quiz.completedAt|date('d/m/Y H:i') : '—' }}
                </span>
            </p>
        </div>
        {% if not loop.last %}<hr class="my-4" />{% endif %}
    {% else %}
        <p class="text-muted fst-italic">Aucun résultat de quiz disponible pour le moment.</p>
    {% endfor %}

{% endblock %}
