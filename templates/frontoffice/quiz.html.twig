{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Résultats des quiz - ESPRI TECH{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <div class="page-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H7z"/>
            </svg>
            Résultats des quiz
        </div>
        <div class="page-subtitle">
            Historique de vos évaluations
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h6>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2z"/>
            </svg>
            Liste des quiz
            <span class="count-pill">{{ quizResults|length }}</span>
        </h6>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Utilisateur</th>
                    <th>Formation</th>
                    <th>Score</th>
                    <th>Pourcentage</th>
                    <th>Réussi</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                {% for quiz in quizResults %}
                <tr>
                    <td>{{ quiz.id }}</td>
                    <td>{{ quiz.userId }}</td>
                    <td>{{ quiz.training ? quiz.training.title : 'N/A' }}</td>
                    <td>{{ quiz.score }} / {{ quiz.totalQuestions }}</td>
                    <td>
                        <div class="progress" style="height: 6px; width: 100px;">
                            <div class="progress-bar {{ quiz.percentage >= 60 ? 'bg-success' : 'bg-danger' }}" 
                                 style="width: {{ quiz.percentage }}%"></div>
                        </div>
                        <small>{{ quiz.percentage }}%</small>
                    </td>
                    <td>
                        <span class="badge {{ quiz.passed ? 'badge-soft' : 'badge-tech' }}">
                            {{ quiz.passed ? '✅ Réussi' : '❌ Échoué' }}
                        </span>
                    </td>
                    <td>{{ quiz.completedAt ? quiz.completedAt|date('d/m/Y H:i') : 'N/A' }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="7" class="text-center">Aucun résultat de quiz trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}