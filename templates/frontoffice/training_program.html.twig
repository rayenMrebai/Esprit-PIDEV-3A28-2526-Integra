{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Formations - ESPRI TECH{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <div class="page-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M1 2.828c.885-.37 2.154-.769 3.388-.893 1.33-.134 2.458.063 3.112.752v9.746c-.935-.53-2.12-.603-3.213-.493-1.18.12-2.37.461-3.287.811V2.828zm7.5-.141c.654-.689 1.782-.886 3.112-.752 1.234.124 2.503.523 3.388.893v9.923c-.918-.35-2.107-.692-3.287-.81-1.094-.111-2.278-.039-3.213.492V2.687zM8 1.783C7.015.936 5.587.81 4.287.94c-1.514.153-3.042.672-3.994 1.105A.5.5 0 0 0 0 2.5v11a.5.5 0 0 0 .707.455c.882-.4 2.303-.881 3.68-1.02 1.409-.142 2.59.087 3.223.877a.5.5 0 0 0 .78 0c.633-.79 1.814-1.019 3.222-.877 1.378.139 2.8.62 3.681 1.02A.5.5 0 0 0 16 13.5v-11a.5.5 0 0 0-.293-.455c-.952-.433-2.48-.952-3.994-1.105C10.413.809 8.985.936 8 1.783z"/>
            </svg>
            Formations
        </div>
        <div class="page-subtitle">
            Gérez vos formations, compétences et quiz
        </div>
    </div>
</div>

{# ===== 3 BOUTONS ===== #}
<div class="mb-4">
    <ul class="nav nav-pills">
        <li class="nav-item me-2">
            <a class="nav-link active" id="tab-programmes" data-bs-toggle="pill" href="#programmes">
                <i class="bi bi-mortarboard me-1"></i> Programmes de formation
            </a>
        </li>
        <li class="nav-item me-2">
            <a class="nav-link" id="tab-competences" data-bs-toggle="pill" href="#competences">
                <i class="bi bi-code-slash me-1"></i> Compétences
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link" id="tab-quiz" data-bs-toggle="pill" href="#quiz">
                <i class="bi bi-question-circle me-1"></i> Quiz
            </a>
        </li>
    </ul>
</div>

{# ===== CONTENU DES ONGLETS ===== #}
<div class="tab-content">

    {# ===== ONGLET PROGRAMMES ===== #}
    <div class="tab-pane fade show active" id="programmes">
        <div class="table-card">
            <div class="table-card-header">
                <h6>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2z"/>
                    </svg>
                    Liste des programmes
                    <span class="count-pill">{{ trainings|length }}</span>
                </h6>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titre</th>
                            <th>Description</th>
                            <th>Durée</th>
                            <th>Type</th>
                            <th>Date début</th>
                            <th>Date fin</th>
                            <th>Statut</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for training in trainings %}
                        <tr>
                            <td>{{ training.id }}</td>
                            <td><strong>{{ training.title }}</strong></td>
                            <td>{{ training.description|length > 100 ? training.description|slice(0, 100) ~ '...' : training.description }}</td>
                            <td>{{ training.duration }} h</td>
                            <td>
                                <span class="badge 
                                    {% if training.type == 'présentiel' %}badge-tech
                                    {% elseif training.type == 'en ligne' %}badge-soft
                                    {% else %}badge-management{% endif %}">
                                    {{ training.type }}
                                </span>
                            </td>
                            <td>{{ training.startDate ? training.startDate|date('d/m/Y') : 'N/A' }}</td>
                            <td>{{ training.endDate ? training.endDate|date('d/m/Y') : 'N/A' }}</td>
                            <td>
                                <span class="badge 
                                    {% if training.status == 'PROGRAMMÉ' %}badge-soft
                                    {% elseif training.status == 'EN COURS' %}badge-tech
                                    {% else %}badge-management{% endif %}">
                                    {{ training.status }}
                                </span>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="8" class="text-center">Aucun programme trouvé.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ===== ONGLET COMPÉTENCES ===== #}
    <div class="tab-pane fade" id="competences">
        <div class="table-card">
            <div class="table-card-header">
                <h6>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2z"/>
                    </svg>
                    Liste des compétences
                    <span class="count-pill">{{ skills|length }}</span>
                </h6>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Nom</th>
                            <th>Description</th>
                            <th>Niveau requis</th>
                            <th>Catégorie</th>
                            <th>Formation liée</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for skill in skills %}
                        <tr>
                            <td>{{ skill.id }}</td>
                            <td><strong>{{ skill.nom }}</strong></td>
                            <td>{{ skill.description|length > 100 ? skill.description|slice(0, 100) ~ '...' : skill.description }}</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 80px;">
                                    <div class="progress-bar bg-primary" style="width: {{ skill.levelRequired * 20 }}%"></div>
                                </div>
                                <small>Niveau {{ skill.levelRequired }}/5</small>
                            </td>
                            <td>
                                <span class="badge 
                                    {% if skill.categorie == 'technique' %}badge-tech
                                    {% elseif skill.categorie == 'soft' %}badge-soft
                                    {% else %}badge-management{% endif %}">
                                    {{ skill.categorie }}
                                </span>
                            </td>
                            <td>{{ skill.trainingProgram ? skill.trainingProgram.title : 'N/A' }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="6" class="text-center">Aucune compétence trouvée.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {# ===== ONGLET QUIZ ===== #}
    <div class="tab-pane fade" id="quiz">
        <div class="table-card">
            <div class="table-card-header">
                <h6>
                    <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2z"/>
                    </svg>
                    Résultats des quiz
                    <span class="count-pill">{{ quizResults|length }}</span>
                </h6>
            </div>
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Utilisateur</th>
                            <th>Formation</th>
                            <th>Score</th>
                            <th>Pourcentage</th>
                            <th>Réussi</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for quiz in quizResults %}
                        <tr>
                            <td>{{ quiz.id }}</td>
                            <td>{{ quiz.userId }}</td>
                            <td>{{ quiz.training ? quiz.training.title : 'N/A' }}</td>
                            <td>{{ quiz.score }} / {{ quiz.totalQuestions }}</td>
                            <td>
                                <div class="progress" style="height: 6px; width: 100px;">
                                    <div class="progress-bar {{ quiz.percentage >= 60 ? 'bg-success' : 'bg-danger' }}" 
                                         style="width: {{ quiz.percentage }}%"></div>
                                </div>
                                <small>{{ quiz.percentage }}%</small>
                            </td>
                            <td>
                                <span class="badge {{ quiz.passed ? 'badge-soft' : 'badge-tech' }}">
                                    {{ quiz.passed ? '✅ Réussi' : '❌ Échoué' }}
                                </span>
                            </td>
                            <td>{{ quiz.completedAt ? quiz.completedAt|date('d/m/Y H:i') : 'N/A' }}</td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="text-center">Aucun résultat de quiz trouvé.</td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

{# Ajout des icônes Bootstrap Icons #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
{% endblock %}