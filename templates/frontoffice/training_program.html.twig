{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Programmes de formation{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
    <h1>Programmes de formation</h1>
    <p>Découvrez tous nos programmes de formation.</p>
    
    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Titre</th>
                    <th>Description</th>
                    <th>Durée</th>
                    <th>Type</th>
                    <th>Date début</th>
                    <th>Date fin</th>
                    <th>Statut</th>
                </tr>
            </thead>
            <tbody>
                {% for training in trainings %}
                <tr>
                    <td>{{ training.id }}</td>
                    <td>{{ training.title }}</td>
                    <td>{{ training.description|length > 100 ? training.description|slice(0, 100) ~ '...' : training.description }}</td>
                    <td>{{ training.duration }} h</td>
                    <td>{{ training.type }}</td>
                    <td>{{ training.startDate ? training.startDate|date('d/m/Y') : 'N/A' }}</td>
                    <td>{{ training.endDate ? training.endDate|date('d/m/Y') : 'N/A' }}</td>
                    <td>{{ training.status }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="8" class="text-center">Aucun programme trouvé.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}