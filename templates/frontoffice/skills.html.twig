{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Mes compétences{% endblock %}

{% block content %}
<div class="container mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Mes compétences</h4>
        </div>
        <div class="card-body">
            {% if userSkills is defined and userSkills|length > 0 %}
                <div class="row">
                    {% for skill in userSkills %}
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h5 class="card-title">{{ skill.nom }}</h5>
                                    <p class="card-text text-muted small">{{ skill.description|slice(0, 100) }}...</p>
                                    <div class="mb-2">
                                        <span class="badge 
                                            {% if skill.categorie == 'technique' %}bg-primary
                                            {% elseif skill.categorie == 'soft' %}bg-success
                                            {% elseif skill.categorie == 'management' %}bg-warning
                                            {% else %}bg-secondary{% endif %}">
                                            {{ skill.categorie }}
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-info" style="width: {{ skill.levelRequired * 20 }}%;"></div>
                                    </div>
                                    <small class="text-muted">Niveau requis: {{ skill.levelRequired }}/5</small>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% else %}
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> Vous n'avez aucune compétence associée pour le moment.
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}