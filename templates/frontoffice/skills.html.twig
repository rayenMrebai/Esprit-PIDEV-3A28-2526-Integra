{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Compétences - ESPRI TECH{% endblock %}

{% block content %}
<div class="page-header">
    <div>
        <div class="page-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16">
                <path d="M4 10.781c.148 1.667 1.513 2.85 3.591 3.003V15h1.043v-1.216c2.27-.179 3.678-1.438 3.678-3.3 0-1.59-.947-2.51-2.956-3.028l-.722-.187V3.467c1.122.11 1.879.714 2.07 1.616h1.47c-.166-1.6-1.54-2.748-3.54-2.875V1H7.591v1.233c-1.939.23-3.27 1.472-3.27 3.156 0 1.454.966 2.483 2.661 2.917l.61.162v4.031c-1.149-.17-1.94-.8-2.131-1.718H4z"/>
            </svg>
            Compétences
        </div>
        <div class="page-subtitle">
            Les compétences développées dans nos formations
        </div>
    </div>
</div>

<div class="table-card">
    <div class="table-card-header">
        <h6>
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V2z"/>
            </svg>
            Liste des compétences
            <span class="count-pill">{{ skills|length }}</span>
        </h6>
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Description</th>
                    <th>Niveau requis</th>
                    <th>Catégorie</th>
                    <th>Formation liée</th>
                </tr>
            </thead>
            <tbody>
                {% for skill in skills %}
                <tr>
                    <td>{{ skill.id }}</td>
                    <td><strong>{{ skill.nom }}</strong></td>
                    <td>{{ skill.description|length > 100 ? skill.description|slice(0, 100) ~ '...' : skill.description }}</td>
                    <td>
                        <div class="progress" style="height: 6px; width: 80px;">
                            <div class="progress-bar bg-primary" style="width: {{ skill.levelRequired * 20 }}%"></div>
                        </div>
                        <small>Niveau {{ skill.levelRequired }}/5</small>
                    </td>
                    <td>
                        <span class="badge 
                            {% if skill.categorie == 'technique' %}badge-tech
                            {% elseif skill.categorie == 'soft' %}badge-soft
                            {% else %}badge-management{% endif %}">
                            {{ skill.categorie }}
                        </span>
                    </td>
                    <td>{{ skill.trainingProgram ? skill.trainingProgram.title : 'N/A' }}</td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="6" class="text-center">Aucune compétence trouvée.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}