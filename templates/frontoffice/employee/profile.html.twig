{% extends 'frontoffice/base_employee.html.twig' %}

{% block title %}Mon Profil{% endblock %}
{% block page_heading %}Mon Profil{% endblock %}
{% block page_subheading %}Mes informations personnelles{% endblock %}

{% block body %}

<div class="post-preview mb-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <div class="text-center mb-4">
                <i class="fas fa-user-circle fa-5x text-primary mb-3"></i>
                <h3>{{ user.username }}</h3>
                <span class="badge bg-primary">{{ user.role }}</span>
            </div>
            
            <hr class="my-4">
            
            <div class="row text-start">
                <div class="col-md-6 mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Nom d'utilisateur</label>
                    <p class="mb-0 fs-5">{{ user.username }}</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Email</label>
                    <p class="mb-0 fs-5">{{ user.email }}</p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Statut</label>
                    <p class="mb-0">
                        {% if user.isActive %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-danger">Inactif</span>
                        {% endif %}
                    </p>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="text-muted small text-uppercase fw-bold">Membre depuis</label>
                    <p class="mb-0">{{ user.accountCreatedDate|date('d/m/Y') }}</p>
                </div>
            </div>
            
            <div class="text-center mt-4 pt-3 border-top">
                <a href="{{ path('app_employee_profile_edit') }}" class="btn btn-primary rounded-pill px-4">
                    <i class="fas fa-edit me-2"></i>Modifier
                </a>
                
                {# BOUTON RETOUR VERS DASHBOARD EMPLOYÉ #}
                <a href="{{ path('app_employee_dashboard') }}" class="btn btn-outline-secondary rounded-pill px-4 ms-2">
                    <i class="fas fa-arrow-left me-2"></i>Retour au Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

{% endblock %}