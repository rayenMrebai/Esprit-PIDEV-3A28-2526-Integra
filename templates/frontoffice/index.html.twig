{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Dashboard - ESPRI TECH{% endblock %}

{% block content %}
{# Récupération des données utilisateur depuis la session #}
{% set fake_name = app.session.get('fake_user_name') ?? 'Utilisateur' %}
{% set fake_role = app.session.get('fake_user_role') ?? 'EMPLOYE' %}

<div class="dashboard-header">
    <h1 class="dashboard-title">Dashboard</h1>
    <p class="dashboard-welcome">
        Bienvenue <strong>{{ fake_name }}</strong>
        <span class="badge 
            {% if fake_role == 'ADMINISTRATEUR' %}bg-danger
            {% elseif fake_role == 'MANAGER' %}bg-warning
            {% else %}bg-success{% endif %} ms-2">
            {{ fake_role }}
        </span>
    </p>
</div>

<div class="dashboard-cards">
    <div class="row g-4">
        
        {# Carte 1: Formations #}
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-card">
                <div class="card-icon bg-primary">
                    <i class="bi bi-mortarboard-fill"></i>
                </div>
                <div class="card-content">
                    <h3 class="card-count">{{ trainings_count|default(0) }}</h3>
                    <p class="card-label">FORMATIONS</p>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_frontoffice_trainings') }}" class="btn-link">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte 2: Compétences #}
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-card">
                <div class="card-icon bg-success">
                    <i class="bi bi-code-slash"></i>
                </div>
                <div class="card-content">
                    <h3 class="card-count">{{ skills_count|default(0) }}</h3>
                    <p class="card-label">COMPÉTENCES</p>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_frontoffice_skills') }}" class="btn-link">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte 3: Quiz #}
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-card">
                <div class="card-icon bg-info">
                    <i class="bi bi-question-circle-fill"></i>
                </div>
                <div class="card-content">
                    <h3 class="card-count">{{ quiz_count|default(0) }}</h3>
                    <p class="card-label">QUIZ</p>
                </div>
                <div class="card-footer">
                    <a href="{{ path('app_frontoffice_quiz') }}" class="btn-link">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        {# Carte 4: Projets #}
        <div class="col-md-3 col-sm-6">
            <div class="dashboard-card">
                <div class="card-icon bg-warning">
                    <i class="bi bi-kanban-fill"></i>
                </div>
                <div class="card-content">
                    <h3 class="card-count">{{ projets_count|default(0) }}</h3>
                    <p class="card-label">PROJETS</p>
                </div>
                <div class="card-footer">
                    <a href="#" class="btn-link" onclick="alert('Page Projets en construction'); return false;">
                        Voir <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .dashboard-header {
        margin-bottom: 2rem;
    }

    .dashboard-title {
        font-size: 1.75rem;
        font-weight: 700;
        color: #1e2533;
        margin-bottom: 0.5rem;
    }

    .dashboard-welcome {
        font-size: 0.9rem;
        color: #6c757d;
        margin-bottom: 0;
    }

    .dashboard-welcome .badge {
        font-size: 0.7rem;
        padding: 0.25rem 0.6rem;
    }

    .dashboard-cards {
        margin-top: 1rem;
    }

    .dashboard-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.07);
        overflow: hidden;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .dashboard-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    }

    .dashboard-card .card-icon {
        width: 100%;
        padding: 1.2rem;
        text-align: center;
    }

    .dashboard-card .card-icon i {
        font-size: 2rem;
        color: white;
    }

    .bg-primary { background: linear-gradient(135deg, #667eea, #764ba2); }
    .bg-success { background: linear-gradient(135deg, #11998e, #38ef7d); }
    .bg-info { background: linear-gradient(135deg, #4facfe, #00f2fe); }
    .bg-warning { background: linear-gradient(135deg, #f093fb, #f5576c); }

    .dashboard-card .card-content {
        padding: 1.2rem;
        text-align: center;
    }

    .card-count {
        font-size: 2rem;
        font-weight: 700;
        color: #1e2533;
        margin-bottom: 0.25rem;
    }

    .card-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: #adb5bd;
        font-weight: 600;
        margin-bottom: 0;
    }

    .dashboard-card .card-footer {
        padding: 0.8rem 1.2rem;
        background: #f8f9fa;
        border-top: 1px solid #f0f2f5;
        text-align: center;
    }

    .btn-link {
        color: #667eea;
        text-decoration: none;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
    }

    .btn-link:hover {
        color: #5a67d8;
    }
</style>

{# Ajout des icônes Bootstrap Icons #}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
{% endblock %}