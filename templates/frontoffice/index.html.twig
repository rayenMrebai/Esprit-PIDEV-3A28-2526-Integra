{% extends 'frontoffice/base_frontoffice.html.twig' %}

{% block title %}Accueil - ESPRI TECH{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <i class="fas fa-user-circle fa-5x text-primary mb-3"></i>
                    <h4>{{ app.user ? app.user.email : 'Invité' }}</h4>
                    <p class="text-muted">Utilisateur</p>
                    <hr>
                    <p><strong>Rôle :</strong> {{ app.user ? 'Utilisateur' : 'Non connecté' }}</p>
                </div>
            </div>
        </div>
        
        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5>Bienvenue sur ESPRI TECH</h5>
                </div>
                <div class="card-body">
                    <p>Centre de formation de référence en Tunisie.</p>
                    <p>Consultez nos formations, compétences et résultats de quiz.</p>
                    <div class="row mt-3">
                        <div class="col-md-4">
                            <a href="{{ path('app_frontoffice_trainings') }}" class="btn btn-primary w-100">
                                <i class="fas fa-graduation-cap me-2"></i> Formations
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a href="{{ path('app_frontoffice_skills') }}" class="btn btn-success w-100">
                                <i class="fas fa-code me-2"></i> Compétences
                            </a>
                        </div>
                        <div class="col-md-4">
                            <a href="{{ path('app_frontoffice_quiz') }}" class="btn btn-info w-100">
                                <i class="fas fa-question-circle me-2"></i> Quiz
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}