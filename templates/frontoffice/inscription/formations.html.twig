{% extends 'base_front.html.twig' %}


{% block title %}Formations disponibles à l'inscription{% endblock %}
{% block page_heading %}Formations disponibles{% endblock %}
{% block page_subheading %}Consultez et inscrivez-vous aux formations disponibles{% endblock %}

{% block content %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <a href="{{ path('app_frontoffice_mes_inscriptions') }}" class="btn btn-info">
        <i class="bi bi-list-check"></i> Mes demandes
    </a>
</div>

<div class="row">
    {% for formation in formations %}
        <div class="col-md-6 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">{{ formation.title }}</h5>
                    <p class="card-text text-muted">{{ formation.description|slice(0, 150) }}...</p>
                    
                    <ul class="list-unstyled">
                        <li><strong>📅 Dates :</strong> {{ formation.startDate|date('d/m/Y') }} - {{ formation.endDate|date('d/m/Y') }}</li>
                        <li><strong>⏱️ Durée :</strong> {{ formation.duration }} heures</li>
                        <li><strong>📚 Type :</strong> {{ formation.type }}</li>
                        <li><strong>📊 Statut :</strong>
                            <span class="badge bg-{{ formation.status == 'PROGRAMMÉ' ? 'info' : 'success' }}">
                                {{ formation.status }}
                            </span>
                        </li>
                    </ul>

                    {% set inscriptionStatus = inscriptions[formation.id] ?? null %}

                    {% if inscriptionStatus == 'EN_ATTENTE' %}
                        <div class="alert alert-warning mb-0">
                            <i class="bi bi-hourglass-split"></i> Demande en attente de validation
                        </div>
                    {% elseif inscriptionStatus == 'ACCEPTEE' %}
                        <div class="alert alert-success mb-0">
                            <i class="bi bi-check-circle"></i> Inscription acceptée ✓
                        </div>
                    {% elseif inscriptionStatus == 'REFUSEE' %}
                        <div class="alert alert-danger mb-0">
                            <i class="bi bi-x-circle"></i> Demande refusée
                        </div>
                    {% else %}
                        <a href="{{ path('app_frontoffice_inscription_new', {id: formation.id}) }}"
                           class="btn btn-primary w-100">
                            <i class="bi bi-send"></i> S'inscrire
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="alert alert-info text-center">
                <i class="bi bi-info-circle"></i> Aucune formation disponible pour le moment.
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}