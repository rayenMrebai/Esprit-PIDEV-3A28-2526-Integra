<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>{% block title %}ESPRI TECH{% endblock %}</title>
    <link rel="icon" type="image/x-icon" href="{{ asset('assets/images/favicon.ico') }}" />
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
    
    {% block stylesheets %}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
        <link href="{{ asset('assets/css/styles.css') }}" rel="stylesheet" />
        <style>
            /* Supprimer le titre ESPRI TECH dans la sidebar */
            #sidebar-wrapper .sidebar-heading {
                display: none !important;
            }
            
            /* Agrandir la sidebar */
            #sidebar-wrapper {
                width: 280px !important;
            }
            
            #sidebar-wrapper .list-group {
                width: 280px !important;
            }
            
            /* Contenu pleine largeur */
            #page-content-wrapper {
                width: calc(100% - 280px) !important;
                min-width: 0 !important;
            }
            
            /* Supprimer les marges du conteneur */
            .container-fluid {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            
            /* Ajuster les cards et rangées */
            .card {
                margin-left: 0;
                margin-right: 0;
                width: 100%;
            }
            
            .row {
                margin-left: 0 !important;
                margin-right: 0 !important;
                width: 100%;
            }
            
            /* Ajuster les colonnes */
            .col-md-4, .col-md-8, [class*="col-"] {
                padding-left: 0.75rem;
                padding-right: 0.75rem;
            }
            
            /* Responsive mobile */
            @media (max-width: 768px) {
                #page-content-wrapper {
                    width: 100% !important;
                }
                #sidebar-wrapper {
                    width: 260px !important;
                }
            }
        </style>
    {% endblock %}
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="border-end bg-white" id="sidebar-wrapper">
            <div class="sidebar-heading border-bottom bg-light">
                <i class="fas fa-graduation-cap me-2"></i> ESPRI TECH
            </div>
            <div class="list-group list-group-flush">
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="{{ path('app_frontoffice_index') }}">
                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                </a>
                
                <!-- Formation avec sous-menu -->
                <div class="list-group-item list-group-item-light p-0">
                    <a class="list-group-item list-group-item-action list-group-item-light p-3" data-bs-toggle="collapse" href="#submenuFormation" role="button" aria-expanded="false">
                        <i class="fas fa-graduation-cap me-2"></i> Formation <i class="fas fa-chevron-down float-end"></i>
                    </a>
                    <div class="collapse" id="submenuFormation">
                        <a class="list-group-item list-group-item-action list-group-item-light ps-5" href="{{ path('app_frontoffice_skills') }}">
                            <i class="far fa-circle me-2"></i> Compétences
                        </a>
                        <a class="list-group-item list-group-item-action list-group-item-light ps-5" href="{{ path('app_frontoffice_trainings') }}">
                            <i class="far fa-circle me-2"></i> Programmes
                        </a>
                        <a class="list-group-item list-group-item-action list-group-item-light ps-5" href="{{ path('app_frontoffice_quiz') }}">
                            <i class="far fa-circle me-2"></i> Quiz
                        </a>
                    </div>
                </div>
                
                <!-- Salaire -->
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#">
                    <i class="fas fa-euro-sign me-2"></i> Salaire
                </a>
                
                <!-- Projet -->
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#">
                    <i class="fas fa-project-diagram me-2"></i> Projet
                </a>
                
                <!-- Recrutement -->
                <a class="list-group-item list-group-item-action list-group-item-light p-3" href="#">
                    <i class="fas fa-users me-2"></i> Recrutement
                </a>
            </div>
        </div>
        
        <!-- Page content wrapper -->
        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-light bg-light border-bottom">
                <div class="container-fluid">
                    <button class="btn btn-primary" id="sidebarToggle">
                        <i class="fas fa-bars"></i> Menu
                    </button>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarSupportedContent">
                        <ul class="navbar-nav ms-auto mt-2 mt-lg-0">
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_frontoffice_index') }}">
                                    <i class="fas fa-home me-1"></i> Accueil
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="fas fa-user me-1"></i> Mon compte
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </nav>
            
            <div class="container-fluid">
                {% block content %}{% endblock %}
            </div>
        </div>
    </div>
    
    {% block javascripts %}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="{{ asset('assets/js/scripts.js') }}"></script>
        <script>
            const sidebarToggle = document.getElementById('sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', function(e) {
                    e.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                });
            }
        </script>
    {% endblock %}
</body>
</html>