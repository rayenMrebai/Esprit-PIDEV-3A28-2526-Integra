{% extends 'base.html.twig' %}

{% block body %}
    <div class="container mt-5">
        <div class="card">
            <div class="card-header">
                <h3>Edit Profile</h3>
            </div>
            <div class="card-body">
                {{ form_start(form) }}
                {{ form_row(form.email) }}
                {{ form_row(form.username) }}
                <button type="submit" class="btn btn-primary">Save</button>
                <a href="{{ path('app_profile') }}" class="btn btn-secondary">Cancel</a>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %}