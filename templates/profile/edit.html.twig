{% extends 'layout/authenticated.html.twig' %}

{% block authenticated_content %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-white">
                    <h4 class="mb-0">Edit Profile</h4>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                    {{ form_row(form.email) }}
                    {{ form_row(form.username) }}
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                    <a href="{{ path('app_profile') }}" class="btn btn-secondary">Cancel</a>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}