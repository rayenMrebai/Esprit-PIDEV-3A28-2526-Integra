{% extends 'base.html.twig' %}

{% block title %}Statistiques RH - INTEGRA{% endblock %}

{% block body %}
    <div class="stats-page" style="background: #f0f4f8; min-height: 100vh;">
        <!-- Header avec gradient -->
        <div class="main-header" style="background: linear-gradient(90deg, #0B63CE 0%, #0FA36B 100%); padding: 16px 28px; display: flex; justify-content: space-between; align-items: center;">
            <div class="logo-area" style="display: flex; align-items: center; gap: 14px;">
                <div class="logo-icon" style="width: 44px; height: 44px; background: rgba(255,255,255,0.2); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 22px; color: white;">IN</div>
                <div>
                    <h1 style="font-size: 20px; color: white; margin: 0;">STATISTIQUES RH</h1>
                    <p style="font-size: 12px; color: rgba(255,255,255,0.85); margin: 0;">Tableau de bord analytique</p>
                </div>
            </div>
            <a href="{{ path('app_recruitment_dashboard') }}" class="btn-back" style="background: rgba(255,255,255,0.2); color: white; padding: 8px 18px; border-radius: 30px; text-decoration: none; font-weight: 600;">
                <i class="fas fa-arrow-left"></i> Retour au recrutement
            </a>
        </div>

        <div style="max-width: 1400px; margin: 30px auto; padding: 0 24px;">
            <!-- KPI CARDS en grille -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 24px; margin-bottom: 40px;">
                <div class="kpi-card" style="background: white; border-radius: 24px; padding: 22px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05); transition: transform 0.2s;">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="background: #EFF6FF; width: 56px; height: 56px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px;">💼</div>
                        <div><div style="color: #64748B; font-size: 13px; font-weight: 600;">TOTAL JOBS</div><div style="font-size: 36px; font-weight: 800; color: #0B63CE;">{{ totalJobs }}</div></div>
                    </div>
                </div>
                <div class="kpi-card" style="background: white; border-radius: 24px; padding: 22px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="background: #F0FDF4; width: 56px; height: 56px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px;">✅</div>
                        <div><div style="color: #64748B; font-size: 13px; font-weight: 600;">OFFRES OUVERTES</div><div style="font-size: 36px; font-weight: 800; color: #0FA36B;">{{ jobsOpen }}</div></div>
                    </div>
                </div>
                <div class="kpi-card" style="background: white; border-radius: 24px; padding: 22px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="background: #F1F5F9; width: 56px; height: 56px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px;">🔒</div>
                        <div><div style="color: #64748B; font-size: 13px; font-weight: 600;">OFFRES FERMÉES</div><div style="font-size: 36px; font-weight: 800; color: #475569;">{{ jobsClosed }}</div></div>
                    </div>
                </div>
                <div class="kpi-card" style="background: white; border-radius: 24px; padding: 22px; box-shadow: 0 10px 25px -5px rgba(0,0,0,0.05);">
                    <div style="display: flex; align-items: center; gap: 16px;">
                        <div style="background: #FEF3C7; width: 56px; height: 56px; border-radius: 18px; display: flex; align-items: center; justify-content: center; font-size: 28px;">👥</div>
                        <div><div style="color: #64748B; font-size: 13px; font-weight: 600;">CANDIDATS TOTAL</div><div style="font-size: 36px; font-weight: 800; color: #F59E0B;">{{ totalCandidats }}</div></div>
                    </div>
                </div>
            </div>

            <!-- Graphiques double -->
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); gap: 30px; margin-bottom: 40px;">
                <!-- Pie chart statut candidats -->
                <div class="chart-card" style="background: white; border-radius: 28px; padding: 24px; box-shadow: 0 20px 30px -12px rgba(0,0,0,0.08);">
                    <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 8px;"><i class="fas fa-users" style="color: #0B63CE;"></i> Répartition des candidats</h3>
                    <canvas id="candidatStatusChart" width="400" height="300" style="max-height: 300px; width: 100%;"></canvas>
                    {% if statusLabels is empty %}
                        <p class="text-center" style="color: #94A3B8; margin-top: 20px;">Aucune donnée de candidat disponible.</p>
                    {% endif %}
                </div>
                <!-- Pie chart statut offres -->
                <div class="chart-card" style="background: white; border-radius: 28px; padding: 24px; box-shadow: 0 20px 30px -12px rgba(0,0,0,0.08);">
                    <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 8px;"><i class="fas fa-briefcase" style="color: #0FA36B;"></i> État des offres</h3>
                    <canvas id="jobStatusChart" width="400" height="300" style="max-height: 300px; width: 100%;"></canvas>
                </div>
            </div>

            <!-- Bar chart candidats par offre -->
            <div class="chart-card" style="background: white; border-radius: 28px; padding: 24px; box-shadow: 0 20px 30px -12px rgba(0,0,0,0.08);">
                <h3 style="margin: 0 0 20px 0; font-size: 18px; font-weight: 700; display: flex; align-items: center; gap: 8px;"><i class="fas fa-chart-bar" style="color: #F59E0B;"></i> Candidatures par offre</h3>
                <canvas id="candidatsPerJobChart" width="800" height="400" style="max-height: 400px; width: 100%;"></canvas>
                {% if jobTitles is empty %}
                    <p class="text-center" style="color: #94A3B8; margin-top: 20px;">Aucune offre créée pour le moment.</p>
                {% endif %}
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Graphique statut candidats
            const ctxCand = document.getElementById('candidatStatusChart')?.getContext('2d');
            if (ctxCand && {{ statusLabels|length }} > 0) {
                new Chart(ctxCand, {
                    type: 'doughnut',
                    data: {
                        labels: {{ statusLabels|json_encode|raw }},
                        datasets: [{
                            data: {{ statusCounts|json_encode|raw }},
                            backgroundColor: ['#0B63CE', '#0FA36B', '#F59E0B', '#EF4444', '#8B5CF6', '#EC4899'],
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: {
                            legend: { position: 'bottom', labels: { font: { size: 12 } } },
                            tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw} candidat(s)` } }
                        }
                    }
                });
            }

            // Graphique statut offres
            const ctxJob = document.getElementById('jobStatusChart')?.getContext('2d');
            if (ctxJob) {
                new Chart(ctxJob, {
                    type: 'doughnut',
                    data: {
                        labels: {{ jobStatusLabels|json_encode|raw }},
                        datasets: [{
                            data: {{ jobStatusCounts|json_encode|raw }},
                            backgroundColor: ['#0FA36B', '#94A3B8'],
                            borderWidth: 0,
                            hoverOffset: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom' }, tooltip: { callbacks: { label: (ctx) => `${ctx.label}: ${ctx.raw} offre(s)` } } }
                    }
                });
            }

            // Histogramme candidats par offre
            const ctxBar = document.getElementById('candidatsPerJobChart')?.getContext('2d');
            if (ctxBar && {{ jobTitles|length }} > 0) {
                new Chart(ctxBar, {
                    type: 'bar',
                    data: {
                        labels: {{ jobTitles|json_encode|raw }},
                        datasets: [{
                            label: 'Nombre de candidats',
                            data: {{ candidatsPerJob|json_encode|raw }},
                            backgroundColor: 'rgba(11, 99, 206, 0.7)',
                            borderRadius: 12,
                            barPercentage: 0.65,
                            categoryPercentage: 0.8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: true,
                        plugins: { tooltip: { callbacks: { label: (ctx) => `${ctx.raw} candidat(s)` } } },
                        scales: {
                            y: { beginAtZero: true, title: { display: true, text: 'Candidats', font: { weight: 'bold' } }, grid: { color: '#E2E8F0' } },
                            x: { ticks: { autoSkip: false, maxRotation: 35, minRotation: 35, font: { size: 11 } }, title: { display: true, text: 'Offres', font: { weight: 'bold' } } }
                        }
                    }
                });
            }
        });
    </script>

    <style>
        .kpi-card:hover { transform: translateY(-4px); transition: all 0.2s; }
        .chart-card { transition: transform 0.2s; }
        .chart-card:hover { transform: translateY(-2px); }
        .btn-back:hover { background: rgba(255,255,255,0.35); transition: 0.2s; }
    </style>
{% endblock %}