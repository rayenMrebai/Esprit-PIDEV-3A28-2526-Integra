{% extends 'base.html.twig' %}

{% block title %}Quiz result{% endblock %}

{% block body %}
    <h1>Quiz result</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ quiz_result.id }}</td>
            </tr>
            <tr>
                <th>User_id</th>
                <td>{{ quiz_result.user_id }}</td>
            </tr>
            <tr>
                <th>Training_id</th>
                <td>{{ quiz_result.training_id.title }}</td>
            </tr>
            <tr>
                <th>Score</th>
                <td>{{ quiz_result.score }}</td>
            </tr>
            <tr>
                <th>Total_questions</th>
                <td>{{ quiz_result.total_questions }}</td>
            </tr>
            <tr>
                <th>Percentage</th>
                <td>{{ quiz_result.percentage }}</td>
            </tr>
            <tr>
                <th>Passed</th>
                <td>{{ quiz_result.passed ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Completed_at</th>
                <td>{{ quiz_result.completed_at ? quiz_result.completed_at|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_quiz_result_index') }}">back to list</a>

    <a href="{{ path('app_quiz_result_edit', {'id': quiz_result.id}) }}">edit</a>

    {{ include('quiz_result/_delete_form.html.twig') }}
{% endblock %}