{% extends 'base.html.twig' %}

{% block title %}Modifier – {{ project.name }}{% endblock %}

{% block content %}

    <div class="integra-header">
        <div>
            <h1>✏️ Modifier Projet</h1>
            <p>{{ project.name }}</p>
        </div>
        <a href="{{ path('app_project_index') }}" style="background:rgba(255,255,255,0.25); color:white; border-radius:30px; padding:10px 20px; text-decoration:none; font-weight:bold; border:1px solid rgba(255,255,255,0.4);">
            ← Retour
        </a>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="integra-card">
                <h3 style="color:#1e3a5f; font-weight:700; border-bottom:2px solid #b0c4de; padding-bottom:12px; margin-bottom:25px; font-size:18px;">
                    📋 Modifier les informations
                </h3>

                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

                <div style="margin-bottom:18px;">
                    <label class="integra-form-label">📛 Nom du projet <span style="color:#ef4444;">*</span></label>
                    {{ form_widget(form.name, {'attr': {'class': 'integra-form-control'}}) }}
                    {% if form_errors(form.name) is not empty %}
                        <div class="form-error"><i class="fas fa-exclamation-circle mr-1"></i>{{ form_errors(form.name) }}</div>
                    {% endif %}
                </div>

                <div style="margin-bottom:18px;">
                    <label class="integra-form-label">📝 Description</label>
                    {{ form_widget(form.description, {'attr': {'class': 'integra-form-control', 'rows': 3}}) }}
                </div>

                <div style="display:flex; gap:15px; margin-bottom:18px;">
                    <div style="flex:1;">
                        <label class="integra-form-label">📅 Date de début <span style="color:#ef4444;">*</span></label>
                        {{ form_widget(form.startDate, {'attr': {'class': 'integra-form-control'}}) }}
                        {% if form_errors(form.startDate) is not empty %}
                            <div class="form-error">{{ form_errors(form.startDate) }}</div>
                        {% endif %}
                    </div>
                    <div style="flex:1;">
                        <label class="integra-form-label">📆 Date de fin <span style="color:#ef4444;">*</span></label>
                        {{ form_widget(form.endDate, {'attr': {'class': 'integra-form-control'}}) }}
                        {% if form_errors(form.endDate) is not empty %}
                            <div class="form-error">{{ form_errors(form.endDate) }}</div>
                        {% endif %}
                    </div>
                </div>

                <div style="display:flex; gap:15px; margin-bottom:18px;">
                    <div style="flex:1;">
                        <label class="integra-form-label">⚙️ Statut <span style="color:#ef4444;">*</span></label>
                        {{ form_widget(form.status, {'attr': {'class': 'integra-form-control'}}) }}
                    </div>
                    <div style="flex:1;">
                        <label class="integra-form-label">💰 Budget (TND) <span style="color:#ef4444;">*</span></label>
                        {{ form_widget(form.budget, {'attr': {'class': 'integra-form-control'}}) }}
                        {% if form_errors(form.budget) is not empty %}
                            <div class="form-error">{{ form_errors(form.budget) }}</div>
                        {% endif %}
                    </div>
                </div>

                <div style="display:flex; justify-content:flex-end; gap:12px; margin-top:25px; padding-top:15px; border-top:1px solid #f1f5f9;">
                    <a href="{{ path('app_project_index') }}" style="background:#e2e8f0; color:#1e293b; border-radius:30px; padding:11px 25px; text-decoration:none; font-weight:bold; font-size:14px;">
                        Annuler
                    </a>
                    <button type="submit" style="background:#f59e0b; color:white; border-radius:30px; padding:11px 30px; border:none; font-weight:bold; font-size:14px; cursor:pointer;">
                        <i class="fas fa-save mr-1"></i> Mettre à jour
                    </button>
                </div>

                {{ form_end(form) }}

                {# Formulaire de suppression – paramètre corrigé #}
                <div style="margin-top:15px; padding-top:15px; border-top:1px solid #fee2e2;">
                    <p style="color:#94a3b8; font-size:12px; margin-bottom:8px;">Zone dangereuse</p>
                    <form method="post" action="{{ path('app_project_delete', {'projectId': project.projectId}) }}"
                          onsubmit="return confirm('Supprimer définitivement ce projet ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.projectId) }}">
                        <button type="submit" style="background:#ef4444; color:white; border-radius:30px; padding:9px 20px; border:none; font-weight:bold; font-size:13px; cursor:pointer;">
                            🗑️ Supprimer ce projet
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

{% endblock %}