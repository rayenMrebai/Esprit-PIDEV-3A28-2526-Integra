{% extends 'base.html.twig' %}
{% block title %}Projets RH{% endblock %}

{% block content %}

    {# FLASH MESSAGES #}
    {% for msg in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible" style="border-radius:15px; margin-bottom:15px;">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            ✅ {{ msg }}
        </div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible" style="border-radius:15px; margin-bottom:15px;">
            <button type="button" class="close" data-dismiss="alert">&times;</button>
            ❌ {{ msg }}
        </div>
    {% endfor %}

    {# HEADER #}
    <div class="integra-header">
        <div>
            <h1>INTEGRA – Manage HR Projects</h1>
            <p>Administrator / RH / Manager Module</p>
        </div>
        <a href="{{ path('app_project_new') }}" class="btn-add">
            <i class="fas fa-plus mr-1"></i> Add Project
        </a>
    </div>

    {# FILTRES PHP #}
    <div class="integra-card">
        <form method="get" action="{{ path('app_project_index') }}" id="filterForm" style="display:flex; align-items:center; gap:15px; flex-wrap:wrap;">
            <div style="flex:2; min-width:200px; position:relative;">
                <i class="fas fa-search" style="position:absolute; left:14px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:13px;"></i>
                <input type="text" name="search" value="{{ app.request.query.get('search') }}" id="searchInput"
                       placeholder="Recherche par nom ou ID..."
                       style="width:100%; border-radius:30px; border:1px solid #dbeafe; padding:10px 15px 10px 38px; font-size:14px; outline:none; background:white;">
            </div>
            <div style="min-width:160px;">
                <select name="status" id="statusSelect" style="width:100%; border-radius:30px; border:1px solid #dbeafe; padding:10px 15px; font-size:14px; background:white; cursor:pointer; outline:none;">
                    <option value="">Tous les statuts</option>
                    <option value="PLANNING" {% if app.request.query.get('status') == 'PLANNING' %}selected{% endif %}>PLANNING</option>
                    <option value="IN PROGRESS" {% if app.request.query.get('status') == 'IN PROGRESS' %}selected{% endif %}>IN PROGRESS</option>
                    <option value="ACTIVE" {% if app.request.query.get('status') == 'ACTIVE' %}selected{% endif %}>ACTIVE</option>
                    <option value="ON HOLD" {% if app.request.query.get('status') == 'ON HOLD' %}selected{% endif %}>ON HOLD</option>
                    <option value="COMPLETED" {% if app.request.query.get('status') == 'COMPLETED' %}selected{% endif %}>COMPLETED</option>
                </select>
            </div>
            <div>
                <input type="date" name="startFrom" value="{{ app.request.query.get('startFrom') }}" id="startFromInput"
                       style="border-radius:30px; border:1px solid #dbeafe; padding:9px 14px; font-size:14px; outline:none; background:white; cursor:pointer;">
            </div>
            <div>
                <input type="date" name="startTo" value="{{ app.request.query.get('startTo') }}" id="startToInput"
                       style="border-radius:30px; border:1px solid #dbeafe; padding:9px 14px; font-size:14px; outline:none; background:white; cursor:pointer;">
            </div>
            <button type="submit"
                    style="background:linear-gradient(135deg,#0B63CE,#0FA36B); color:white; border:none; border-radius:30px; padding:10px 22px; font-weight:bold; cursor:pointer; font-size:14px; white-space:nowrap;">
                <i class="fas fa-filter mr-1"></i> Filtrer
            </button>
            {% if app.request.query.all|length > 0 %}
                <a href="{{ path('app_project_index') }}"
                   style="background:#e2e8f0; color:#1e293b; border-radius:30px; padding:10px 18px; text-decoration:none; font-weight:bold; font-size:14px; white-space:nowrap;">
                    ↺ Reset
                </a>
            {% endif %}
        </form>
    </div>

    {# LISTE PROJETS #}
    <div class="integra-card">
        <h3 style="color:#1e3a5f; font-weight:700; margin-bottom:15px; font-size:17px;">
            📊 HR Projects
            <span style="background:#dbeafe; color:#0B63CE; border-radius:20px; padding:2px 12px; font-size:13px; margin-left:8px; font-weight:600;">
                {{ projects|length }}
            </span>
        </h3>

        <div style="display:flex; align-items:center; padding:8px 12px; border-bottom:2px solid #dbeafe; font-weight:700; color:#1e3a5f; font-size:13px; background:#f8fafc; border-radius:10px 10px 0 0;">
            <div style="width:70px;">ID</div>
            <div style="width:230px;">Nom du projet</div>
            <div style="width:110px;">Début</div>
            <div style="width:110px;">Fin</div>
            <div style="width:130px;">Statut</div>
            <div style="width:70px; text-align:center;">👥</div>
            <div style="flex:1; text-align:center;">Actions</div>
        </div>

        <div id="projectsList">
            {% for project in projects %}
                {% set nbEmployees = employeesCount[project.projectId]|default(0) %}
                <div class="project-row"
                     onclick="selectProject(this)"
                     data-id="{{ project.projectId }}"
                     data-name="{{ project.name|e('html_attr') }}"
                     data-desc="{{ project.description|default('')|e('html_attr') }}"
                     data-start="{{ project.startDate ? project.startDate|date('Y-m-d') : '' }}"
                     data-end="{{ project.endDate ? project.endDate|date('Y-m-d') : '' }}"
                     data-status="{{ project.status|e('html_attr') }}"
                     data-budget="{{ project.budget|default('') }}">

                    <div style="width:70px; font-weight:700; color:#0B63CE; font-size:15px;">{{ project.projectId }}</div>

                    <div style="width:230px;">
                        <span style="color:#0f172a; font-weight:500;">{{ project.name }}</span>
                        {% if project.isOverdue is defined and project.isOverdue %}
                            <span style="background:#fef2f2; color:#ef4444; border:1px solid #fecaca; padding:1px 7px; border-radius:20px; font-size:10px; font-weight:bold; margin-left:5px;">⚠️ RETARD</span>
                        {% endif %}
                    </div>

                    <div style="width:110px; color:#64748b; font-size:13px;">{{ project.startDate ? project.startDate|date('d/m/Y') : '—' }}</div>
                    <div style="width:110px; color:#64748b; font-size:13px;">{{ project.endDate ? project.endDate|date('d/m/Y') : '—' }}</div>

                    <div style="width:130px;">
                        {% if project.status == 'PLANNING' %}
                            <span class="status-badge status-planning">PLANNING</span>
                        {% elseif project.status == 'IN PROGRESS' %}
                            <span class="status-badge status-inprogress">IN PROGRESS</span>
                        {% elseif project.status == 'ACTIVE' %}
                            <span class="status-badge status-active">ACTIVE</span>
                        {% elseif project.status == 'ON HOLD' %}
                            <span class="status-badge status-onhold">ON HOLD</span>
                        {% elseif project.status == 'COMPLETED' %}
                            <span class="status-badge status-completed">COMPLETED</span>
                        {% else %}
                            <span class="status-badge" style="background:#94a3b8; color:white;">{{ project.status }}</span>
                        {% endif %}
                    </div>

                    <div style="width:70px; text-align:center; font-weight:600; color:#0B63CE;">{{ nbEmployees }}</div>

                    <div style="flex:1; display:flex; justify-content:center; gap:6px;">
                        <a href="{{ path('app_project_edit', {'projectId': project.projectId}) }}"
                           style="background:#f59e0b; color:white; border-radius:20px; padding:5px 12px; font-size:12px; font-weight:bold; text-decoration:none; border:none; cursor:pointer;"
                           onclick="event.stopPropagation()">
                            ✏️ Edit
                        </a>
                        <form method="post" action="{{ path('app_project_delete', {'projectId': project.projectId}) }}"
                              onsubmit="return confirm('Supprimer ce projet ?')"
                              onclick="event.stopPropagation()">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ project.projectId) }}">
                            <button type="submit"
                                    style="background:#ef4444; color:white; border-radius:20px; padding:5px 12px; font-size:12px; font-weight:bold; border:none; cursor:pointer;">
                                🗑️ Del
                            </button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div style="padding:40px; text-align:center; color:#94a3b8;">
                    <i class="fas fa-inbox fa-3x" style="display:block; margin-bottom:10px; color:#dbeafe;"></i>
                    Aucun projet trouvé.
                </div>
            {% endfor %}
        </div>
    </div>

    {# DÉTAILS + ACTIONS #}
    <div style="display:flex; gap:20px; margin-bottom:20px;">

        {# DÉTAILS #}
        <div class="details-card" style="flex:1;">
            <h3 style="font-size:18px; font-weight:bold; color:#1e3a5f; border-bottom:2px solid #b0c4de; padding-bottom:10px; margin-bottom:20px;">
                📋 Project Details
            </h3>
            <div class="detail-row"><div class="detail-label">🏷️ Project Name:</div><div class="detail-value" id="detailName">—</div></div>
            <div class="detail-row"><div class="detail-label">📝 Description:</div><div class="detail-value" id="detailDesc">—</div></div>
            <div class="detail-row"><div class="detail-label">📅 Start Date:</div><div class="detail-value" id="detailStart">—</div></div>
            <div class="detail-row"><div class="detail-label">📆 End Date:</div><div class="detail-value" id="detailEnd">—</div></div>
            <div class="detail-row"><div class="detail-label">⚙️ Status:</div><div class="detail-value" id="detailStatus">—</div></div>
            <div class="detail-row"><div class="detail-label">💰 Budget:</div><div class="detail-value" id="detailBudget">—</div></div>
        </div>

        {# ACTIONS #}
        <div class="details-card" style="width:250px; min-width:250px;">
            <h3 style="font-size:18px; font-weight:bold; color:#1e3a5f; border-bottom:1px solid #b0c4de; padding-bottom:10px; margin-bottom:15px;">
                ⚡ Quick Actions
            </h3>
            {# Boutons PDF #}
            <a id="exportAllPdfBtn" href="{{ path('app_project_export_all') }}" class="action-btn" style="background:#8b5cf6;">📄 Exporter tout en PDF</a>
            <a id="exportSinglePdfBtn" href="#" class="action-btn" style="background:#0B63CE;">📄 Exporter ce projet</a>
            {# Boutons Excel #}
            <a id="exportAllExcelBtn" href="{{ path('app_project_export_excel_all') }}" class="action-btn" style="background:#10b981;">📊 Exporter tout en Excel</a>
            <a id="exportSingleExcelBtn" href="#" class="action-btn" style="background:#059669;">📊 Exporter ce projet</a>
            {# Bouton IA #}
            <a id="aiRecommendBtn" href="#" class="action-btn" style="background:#0B63CE;">🤖 Recommandation IA</a>
        </div>
    </div>

    {# CSRF tokens cachés #}
    {% for project in projects %}
        <span id="csrf_{{ project.projectId }}" data-token="{{ csrf_token('delete' ~ project.projectId) }}" style="display:none;"></span>
    {% endfor %}

{% endblock %}

{% block javascripts %}
    <script>
        let selectedRow = null;

        function selectProject(row) {
            if (selectedRow) selectedRow.classList.remove('selected');
            selectedRow = row;
            row.classList.add('selected');

            document.getElementById('detailName').innerText   = row.dataset.name   || '—';
            document.getElementById('detailDesc').innerText   = row.dataset.desc   || '—';
            document.getElementById('detailStart').innerText  = row.dataset.start  || '—';
            document.getElementById('detailEnd').innerText    = row.dataset.end    || '—';
            document.getElementById('detailStatus').innerText = row.dataset.status || '—';
            document.getElementById('detailBudget').innerText = row.dataset.budget ? row.dataset.budget + ' TND' : '—';

            const id = row.dataset.id;
            document.getElementById('exportSinglePdfBtn').href = `/project/${id}/export`;
            document.getElementById('exportSingleExcelBtn').href = `/project/${id}/export/excel`;
            document.getElementById('aiRecommendBtn').href = `/ai/recommend/${id}`;
        }

        // Vérifications pour les exports et l'IA
        document.getElementById('exportSinglePdfBtn').addEventListener('click', e => { if (!selectedRow) { e.preventDefault(); alert('Veuillez sélectionner un projet.'); }});
        document.getElementById('exportSingleExcelBtn').addEventListener('click', e => { if (!selectedRow) { e.preventDefault(); alert('Veuillez sélectionner un projet.'); }});
        document.getElementById('aiRecommendBtn').addEventListener('click', e => { if (!selectedRow) { e.preventDefault(); alert('Veuillez sélectionner un projet.'); }});

        // Soumission automatique des filtres
        const filterForm = document.getElementById('filterForm');
        const searchInput = document.getElementById('searchInput');
        const statusSelect = document.getElementById('statusSelect');
        const startFromInput = document.getElementById('startFromInput');
        const startToInput = document.getElementById('startToInput');

        let debounceTimer;
        function submitForm() {
            clearTimeout(debounceTimer);
            debounceTimer = setTimeout(() => filterForm.submit(), 500);
        }
        searchInput.addEventListener('input', submitForm);
        statusSelect.addEventListener('change', submitForm);
        startFromInput.addEventListener('change', submitForm);
        startToInput.addEventListener('change', submitForm);
    </script>
{% endblock %}