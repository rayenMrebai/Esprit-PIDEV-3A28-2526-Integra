{% extends 'base.html.twig' %}

{% block title %}UserAccount index{% endblock %}

{% block body %}
    <h1>UserAccount index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>UserId</th>
                <th>Username</th>
                <th>Email</th>
                <th>Password</th>
                <th>Role</th>
                <th>CreatedAt</th>
                <th>UpdatedAt</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user_account in user_accounts %}
            <tr>
                <td>{{ user_account.userId }}</td>
                <td>{{ user_account.username }}</td>
                <td>{{ user_account.email }}</td>
                <td>{{ user_account.password }}</td>
                <td>{{ user_account.role }}</td>
                <td>{{ user_account.createdAt ? user_account.createdAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>{{ user_account.updatedAt ? user_account.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
                <td>
                    <a href="{{ path('app_user_account_show', {'userId': user_account.userId}) }}">show</a>
                    <a href="{{ path('app_user_account_edit', {'userId': user_account.userId}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_user_account_new') }}">Create new</a>
{% endblock %}
