{% extends 'base.html.twig' %}

{% block title %}UserAccount{% endblock %}

{% block body %}
    <h1>UserAccount</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>UserId</th>
                <td>{{ user_account.userId }}</td>
            </tr>
            <tr>
                <th>Username</th>
                <td>{{ user_account.username }}</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>{{ user_account.email }}</td>
            </tr>
            <tr>
                <th>Password</th>
                <td>{{ user_account.password }}</td>
            </tr>
            <tr>
                <th>Role</th>
                <td>{{ user_account.role }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ user_account.createdAt ? user_account.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ user_account.updatedAt ? user_account.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_user_account_index') }}">back to list</a>

    <a href="{{ path('app_user_account_edit', {'userId': user_account.userId}) }}">edit</a>

    {{ include('user_account/_delete_form.html.twig') }}
{% endblock %}
