<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>User List</title>
    <style>
        body { font-family: Arial, sans-serif; }
        h1 { color: #1e3a5f; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
        th { background-color: #f2f2f2; }
        .footer { margin-top: 30px; font-size: 12px; text-align: center; }
    </style>
</head>
<body>
<h1>User List</h1>
<p>Generated on: {{ generatedAt|date('Y-m-d H:i:s') }}</p>
<table>
    <thead>
    <tr><th>ID</th><th>Username</th><th>Email</th><th>Role</th><th>Active</th><th>Created</th></tr>
    </thead>
    <tbody>
    {% for user in users %}
        <tr>
            <td>{{ user.userId }}</td>
            <td>{{ user.username }}</td>
            <td>{{ user.email }}</td>
            <td>{{ user.role }}</td>
            <td>{{ user.isActive ? 'Yes' : 'No' }}</td>
            <td>{{ user.accountCreatedDate|date('Y-m-d') }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
<div class="footer">INTEGRA RH - User Management</div>
</body>
</html>