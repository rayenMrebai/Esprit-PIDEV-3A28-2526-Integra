{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}Edit User{% endblock %}
{% block breadcrumb %}Edit User{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Edit {{ user.email }}</h3>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
            {{ form_row(form.email) }}
            {{ form_row(form.username) }}
            <button type="submit" class="btn btn-primary">Save</button>
            <a href="{{ path('admin_user_list') }}" class="btn btn-secondary">Cancel</a>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}