{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}User Management{% endblock %}
{% block breadcrumb %}Users{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">List of Users</h3>
            <div class="card-tools">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('admin_add_user') }}" class="btn btn-primary btn-sm">
                        <i class="fas fa-user-plus"></i> Add User
                    </a>
                    <a href="{{ path('admin_export_pdf', {search: search, role: selectedRole}) }}" class="btn btn-danger btn-sm">
                        <i class="fas fa-file-pdf"></i> Export PDF
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="mb-3">
                <div class="row">
                    <div class="col-md-4">
                        <input type="text" name="search" class="form-control" placeholder="Search by email or username" value="{{ search }}">
                    </div>
                    <div class="col-md-3">
                        <select name="role" class="form-control">
                            <option value="">All Roles</option>
                            <option value="EMPLOYE" {% if selectedRole == 'EMPLOYE' %}selected{% endif %}>Employee</option>
                            <option value="MANAGER" {% if selectedRole == 'MANAGER' %}selected{% endif %}>Manager</option>
                            <option value="ADMINISTRATEUR" {% if selectedRole == 'ADMINISTRATEUR' %}selected{% endif %}>Administrator</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary" type="submit">Filter</button>
                        {% if search or selectedRole %}
                            <a href="{{ path('admin_user_list') }}" class="btn btn-secondary">Clear</a>
                        {% endif %}
                    </div>
                </div>
            </form>

            <table class="table table-bordered table-striped">
                <thead>
                <tr>
                    <th>ID</th><th>Email</th><th>Username</th><th>Active</th><th>Role</th><th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.userId }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.username }}</td>
                        <td>{{ user.isActive ? '<span class="badge badge-success">Yes</span>'|raw : '<span class="badge badge-danger">No</span>'|raw }}</td>
                        <td>{{ user.role }}</td>
                        <td>
                            <a href="{{ path('admin_user_show', {id: user.userId}) }}" class="btn btn-sm btn-info">View</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('admin_user_edit', {id: user.userId}) }}" class="btn btn-sm btn-warning">Edit</a>
                            {% endif %}
                            <a href="{{ path('admin_user_toggle', {id: user.userId}) }}" class="btn btn-sm btn-secondary">Toggle Active</a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <form action="{{ path('admin_user_delete', {id: user.userId}) }}" method="post" style="display:inline-block" onsubmit="return confirm('Delete this user permanently?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.userId) }}">
                                    <button class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center">No users found.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}