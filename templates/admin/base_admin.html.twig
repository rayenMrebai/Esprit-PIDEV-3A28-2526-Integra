<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}INTEGRA RH Admin{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}sidebar-mini layout-fixed{% endblock %}">
<div class="wrapper">
    <!-- Navbar -->
    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
            </li>
        </ul>
        <ul class="navbar-nav ml-auto">
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_logout') }}">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </li>
        </ul>
    </nav>

    <!-- Sidebar -->
    {% include 'admin/partials/sidebar.html.twig' %}

    <!-- Content Wrapper -->
    <div class="content-wrapper" style="background-color: #f8fafc;">
        <div class="content-header">
            <div class="container-fluid">
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <h1 class="m-0" style="color:#1e3a5f; font-weight:700;">{% block page_title %}{% endblock %}</h1>
                    </div>
                    <div class="col-sm-6">
                        <ol class="breadcrumb float-sm-right">
                            <li class="breadcrumb-item"><a href="{{ path('app_dashboard') }}" style="color:#0B63CE;"><i class="fas fa-home"></i> Accueil</a></li>
                            <li class="breadcrumb-item active">{% block breadcrumb %}{% endblock %}</li>
                        </ol>
                    </div>
                </div>
            </div>
        </div>
        <section class="content">
            <div class="container-fluid">
                {% block admin_content %}{% endblock %}
            </div>
        </section>
    </div>

    <footer class="main-footer" style="background: linear-gradient(to right, #e2eaf8, #d4e0f0); border:none;">
        <span style="color:#1e3a5f; font-size:13px; font-weight:500;">🔌 Connecté – INTEGRA RH Management</span>
    </footer>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
