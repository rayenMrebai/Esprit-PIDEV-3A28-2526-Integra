{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}📊 Dashboard{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .stat-card {
            border-radius: 20px !important;
            border: none !important;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08) !important;
            overflow: hidden;
        }
        .stat-card .inner { padding: 18px 20px 8px; }
        .stat-card h3 { font-size: 36px; font-weight: 800; margin: 0; color: white; }
        .stat-card p  { font-size: 14px; color: rgba(255,255,255,0.85); margin: 4px 0 0; }
        .stat-card .icon { font-size: 48px; color: rgba(255,255,255,0.25); }
        .stat-card .small-box-footer {
            background: rgba(0,0,0,0.15); color: white;
            padding: 6px 20px; font-size: 12px;
        }
        .risk-bar-wrap { background: #e2e8f0; border-radius: 30px; height: 10px; overflow: hidden; }
        .risk-bar { height: 10px; border-radius: 30px; transition: width 0.6s; }
        .trend-icon { font-size: 16px; }
        .breakdown-pill {
            background: #f1f5f9; border-radius: 20px;
            padding: 2px 10px; font-size: 11px; color: #475569;
            display: inline-block; margin: 1px;
        }
        .btn-recrutement {
            background: linear-gradient(135deg, #0B63CE, #0FA36B);
            border: none;
            border-radius: 30px;
            padding: 8px 20px;
            font-weight: 700;
            color: white;
            transition: 0.2s ease;
            box-shadow: 0 4px 12px rgba(11,99,206,0.3);
        }
        .btn-recrutement:hover {
            transform: translateY(-2px);
            background: linear-gradient(135deg, #0a55b5, #0d8a5a);
            color: white;
        }
        /* Styles salaires (from su branch) */
        .stat-kpi {
            border-radius: 14px;
            padding: 20px 22px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
            border: 1px solid #e5e7eb;
            background: white;
            transition: transform .2s;
        }
        .stat-kpi:hover { transform: translateY(-2px); }
        .stat-kpi .kpi-value {
            font-size: 28px;
            font-weight: 800;
            line-height: 1.1;
        }
        .stat-kpi .kpi-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .05em;
            color: #64748b;
        }
        .stat-kpi .kpi-sub {
            font-size: 11px;
            color: #94a3b8;
            margin-top: 4px;
        }
        .section-title {
            font-size: 15px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .chart-card {
            background: white;
            border-radius: 14px;
            border: 1px solid #e5e7eb;
            box-shadow: 0 2px 12px rgba(0,0,0,0.04);
            padding: 20px;
        }
        .prediction-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 14px;
            padding: 20px;
            color: white;
        }
        .pred-month-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 8px 12px;
            background: rgba(255,255,255,0.15);
            border-radius: 8px;
            margin-bottom: 6px;
            font-size: 13px;
        }
        .r2-bar-wrap {
            background: rgba(255,255,255,0.2);
            border-radius: 20px;
            height: 8px;
            margin-top: 6px;
            overflow: hidden;
        }
        .r2-bar-fill {
            height: 100%;
            border-radius: 20px;
            background: #86efac;
            transition: width .8s ease;
        }
        .top-emp-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 6px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 12px;
        }
        .top-emp-row:last-child { border-bottom: none; }
    </style>
{% endblock %}

{% block admin_content %}

    <!-- ── STAT CARDS USERS ─────────────────────────────────────────── -->
    <div class="row mb-4">
        <div class="col-lg-3 col-6">
            <div class="small-box stat-card" style="background: linear-gradient(135deg,#0B63CE,#3b82f6);">
                <div class="inner">
                    <h3>{{ totalUsers }}</h3>
                    <p>Total utilisateurs</p>
                </div>
                <div class="icon"><i class="fas fa-users"></i></div>
                <a href="{{ path('admin_user_list') }}" class="small-box-footer">
                    Voir la liste <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
        <div class="col-lg-3 col-6">
            <div class="small-box stat-card" style="background: linear-gradient(135deg,#0FA36B,#34d399);">
                <div class="inner">
                    <h3>{{ activeUsers }}</h3>
                    <p>Utilisateurs actifs</p>
                </div>
                <div class="icon"><i class="fas fa-user-check"></i></div>
                <a href="{{ path('admin_user_list') }}" class="small-box-footer">
                    Voir la liste <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
        <div class="col-lg-3 col-6">
            <div class="small-box stat-card" style="background: linear-gradient(135deg,#ef4444,#f87171);">
                <div class="inner">
                    <h3>{{ stats.inactive }}</h3>
                    <p>Utilisateurs inactifs</p>
                </div>
                <div class="icon"><i class="fas fa-user-times"></i></div>
                <a href="{{ path('admin_user_list') }}" class="small-box-footer">
                    Voir la liste <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
        <div class="col-lg-3 col-6">
            {% set criticalCount = riskUsers|filter(r => r.riskLevel == 'Critical')|length %}
            <div class="small-box stat-card" style="background: linear-gradient(135deg,#f59e0b,#fbbf24);">
                <div class="inner">
                    <h3>{{ criticalCount }}</h3>
                    <p>Risques critiques</p>
                </div>
                <div class="icon"><i class="fas fa-exclamation-triangle"></i></div>
                <a href="#riskTable" class="small-box-footer">
                    Voir l'analyse <i class="fas fa-arrow-circle-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- ── SECTION SALAIRES (KPI) ─────────────────────────────────────── -->
    <div class="section-title mt-2">
        <i class="bi bi-cash-stack text-success"></i> Statistiques Salaires
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div class="kpi-value" style="color:#667eea;">{{ salStats.totalCount }}</div>
                <div class="kpi-label">Total salaires</div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div class="kpi-value" style="color:#0369a1;">
                    {{ salStats.averageSalary|number_format(0, ',', ' ') }}
                    <span style="font-size:13px;font-weight:600;">DT</span>
                </div>
                <div class="kpi-label">Salaire moyen</div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div class="kpi-value" style="color:#166534;">
                    {{ salStats.totalAmount|number_format(0, ',', ' ') }}
                    <span style="font-size:13px;font-weight:600;">DT</span>
                </div>
                <div class="kpi-label">Total versé</div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div class="kpi-value" style="color:#854d0e;">
                    {{ salStats.totalBonus|number_format(0, ',', ' ') }}
                    <span style="font-size:13px;font-weight:600;">DT</span>
                </div>
                <div class="kpi-label">Total bonus</div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div class="kpi-value" style="color:#28a745;">{{ salStats.paidCount }}</div>
                <div class="kpi-label">Salaires payés</div>
                <div class="kpi-sub">{{ salStats.paidPercentage|number_format(1) }}% du total</div>
            </div>
        </div>
        <div class="col-lg-2 col-md-4 col-6">
            <div class="stat-kpi">
                <div style="display:flex;gap:8px;align-items:flex-end;">
                    <div>
                        <div class="kpi-value" style="color:#dc3545;font-size:20px;">{{ salStats.maxSalary|number_format(0) }}</div>
                        <div class="kpi-label">Max DT</div>
                    </div>
                    <div style="width:1px;height:30px;background:#e2e8f0;"></div>
                    <div>
                        <div class="kpi-value" style="color:#6366f1;font-size:20px;">{{ salStats.minSalary|number_format(0) }}</div>
                        <div class="kpi-label">Min DT</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ── BADGES STATUTS SALAIRES ── -->
    <div class="row g-3 mb-4">
        <div class="col-12">
            <div class="chart-card d-flex gap-4 align-items-center flex-wrap" style="padding:14px 20px;">
                <span style="font-size:12px;font-weight:700;color:#64748b;text-transform:uppercase;">
                    Répartition par statut :
                </span>
                <span style="background:rgba(22,163,74,0.1);color:#166534;padding:6px 16px;border-radius:20px;font-weight:700;font-size:13px;">
                    ✅ PAYÉ : {{ salStats.paidCount }}
                </span>
                <span style="background:rgba(3,105,161,0.1);color:#0369a1;padding:6px 16px;border-radius:20px;font-weight:700;font-size:13px;">
                    🔄 EN COURS : {{ salStats.enCoursCount }}
                </span>
                <span style="background:rgba(133,77,14,0.1);color:#854d0e;padding:6px 16px;border-radius:20px;font-weight:700;font-size:13px;">
                    📝 CRÉÉ : {{ salStats.creeCount }}
                </span>
                <a href="{{ path('app_backoffice_salaires_index') }}"
                   class="btn btn-sm btn-outline-primary ms-auto" style="border-radius:8px;font-size:12px;">
                    <i class="bi bi-arrow-right me-1"></i> Voir tous les salaires
                </a>
            </div>
        </div>
    </div>

    <!-- ── CHARTS + MÉTÉO + TOP EMPLOYÉS ─────────────────────────────── -->
    <div class="row g-4 mb-4">
        <!-- Graphique utilisateurs actifs/inactifs -->
        <div class="col-md-4">
            <div class="chart-card h-100">
                <div class="section-title" style="font-size:13px;">
                    <i class="bi bi-pie-chart-fill text-primary"></i> Utilisateurs Actifs vs Inactifs
                </div>
                <canvas id="userChart" style="max-height:240px;"></canvas>
            </div>
        </div>

        <!-- Graphique répartition salaires par statut -->
        <div class="col-md-4">
            <div class="chart-card h-100">
                <div class="section-title" style="font-size:13px;">
                    <i class="bi bi-pie-chart-fill text-success"></i> Répartition Statuts Salaires
                </div>
                <canvas id="statusChart" style="max-height:240px;"></canvas>
            </div>
        </div>

        <!-- Météo (de recrutement_user) -->
        <div class="col-md-4">
            <div class="chart-card h-100">
                <div class="card-header" style="border-radius:20px 20px 0 0; border-bottom:2px solid #dbeafe; background:white; padding:15px 20px;">
                    <h3 class="card-title" style="color:#1e3a5f; font-weight:700;">🌤️ Météo du jour – Tunis</h3>
                </div>
                <div class="card-body text-center" style="padding:30px;">
                    {% if weather is not null %}
                        <img src="https://openweathermap.org/img/wn/{{ weather.weather[0].icon }}@2x.png"
                             alt="météo" style="width:80px;">
                        <h2 style="font-size:48px; font-weight:800; color:#1e3a5f; margin:8px 0;">
                            {{ weather.main.temp }}°C
                        </h2>
                        <p style="color:#0B63CE; font-weight:600; font-size:16px;">
                            {{ weather.weather[0].description|capitalize }}
                        </p>
                        <div class="d-flex justify-content-center" style="gap:24px; color:#64748b; font-size:13px;">
                            <span><i class="fas fa-tint mr-1" style="color:#0B63CE;"></i>{{ weather.main.humidity }}%</span>
                            <span><i class="fas fa-wind mr-1" style="color:#0FA36B;"></i>{{ weather.wind.speed }} m/s</span>
                            <span><i class="fas fa-thermometer-half mr-1" style="color:#f59e0b;"></i>Ressenti {{ weather.main.feels_like }}°C</span>
                        </div>
                    {% else %}
                        <div style="color:#94a3b8; padding:40px 0;">
                            <i class="fas fa-cloud fa-3x mb-3 d-block"></i>
                            Données météo non disponibles.
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <!-- ── TOP 5 EMPLOYÉS + ÉVOLUTION MENSUELLE + PRÉDICTION ────────── -->
    <div class="row g-4 mb-4">
        <!-- Top 5 employés (salaire moyen) -->
        <div class="col-md-4">
            <div class="chart-card h-100">
                <div class="section-title" style="font-size:13px;">
                    <i class="bi bi-trophy-fill text-warning"></i> Top 5 Employés (salaire moyen)
                </div>
                {% if salStats.topEmployees|length > 0 %}
                    {% for name, avg in salStats.topEmployees %}
                        <div class="top-emp-row">
                            <div style="display:flex;align-items:center;gap:8px;">
                                <span style="background:#667eea;color:white;border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;">
                                    {{ loop.index }}
                                </span>
                                <span style="font-weight:600;color:#1e293b;">{{ name }}</span>
                            </div>
                            <span style="font-weight:700;color:#166534;">
                                {{ avg|number_format(0, ',', ' ') }} DT
                            </span>
                        </div>
                    {% endfor %}
                {% else %}
                    <div class="text-center text-muted py-4" style="font-size:12px;">
                        <i class="bi bi-inbox d-block mb-2" style="font-size:24px;opacity:.4;"></i>
                        Aucune donnée disponible
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Graphique évolution mensuelle des salaires -->
        <div class="col-md-4">
            <div class="chart-card h-100">
                <div class="section-title" style="font-size:13px;">
                    <i class="bi bi-graph-up text-primary"></i>
                    Évolution mensuelle des salaires moyens
                    <span style="font-size:10px;color:#94a3b8;font-weight:400;margin-left:4px;">
                        (historique + prédiction IA)
                    </span>
                </div>
                {% if salStats.monthlyData.labels|length > 0 %}
                    <canvas id="monthlyChart" style="max-height:280px;"></canvas>
                {% else %}
                    <div class="text-center text-muted py-5" style="font-size:12px;">
                        <i class="bi bi-bar-chart d-block mb-2" style="font-size:32px;opacity:.3;"></i>
                        Aucune donnée de salaire disponible
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Bloc prédiction IA -->
        <div class="col-md-4">
            <div class="prediction-card h-100">
                <div style="font-size:15px;font-weight:700;margin-bottom:16px;display:flex;align-items:center;gap:8px;">
                    🤖 Prédiction IA
                    <span style="font-size:10px;opacity:.8;font-weight:400;">Régression linéaire</span>
                </div>

                {% if salStats.prediction.predictions|length > 0 %}
                    {% for pred in salStats.prediction.predictions %}
                        <div class="pred-month-row">
                            <span>📅 {{ pred.month }}</span>
                            <span style="font-weight:700;">~{{ pred.value|number_format(0, ',', ' ') }} DT</span>
                        </div>
                    {% endfor %}

                    <div style="margin-top:16px;">
                        <div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;">
                            <span>Fiabilité R²</span>
                            <span style="font-weight:700;">
                                {% if salStats.prediction.r2 >= 70 %}
                                    <span style="color:#86efac;">{{ salStats.prediction.r2 }}% ✅</span>
                                {% elseif salStats.prediction.r2 >= 50 %}
                                    <span style="color:#fde68a;">{{ salStats.prediction.r2 }}% ⚠️</span>
                                {% else %}
                                    <span style="color:#fca5a5;">{{ salStats.prediction.r2 }}% ❌</span>
                                {% endif %}
                            </span>
                        </div>
                        {% set r2Width = salStats.prediction.r2 > 100 ? 100 : salStats.prediction.r2 %}
                        <div class="r2-bar-wrap">
                            <div class="r2-bar-fill"
                                style="width:{{ r2Width }}%;
                                        background:{% if salStats.prediction.r2 >= 70 %}#86efac{% elseif salStats.prediction.r2 >= 50 %}#fde68a{% else %}#fca5a5{% endif %};">
                            </div>
                        </div>
                        <div style="font-size:10px;margin-top:8px;opacity:.8;line-height:1.6;">
                            ≥ 70% Excellente &nbsp;|&nbsp; 50–70% Modérée &nbsp;|&nbsp; &lt; 50% Insuffisante
                        </div>
                    </div>
                {% else %}
                    <div style="text-align:center;opacity:.7;font-size:13px;padding:20px 0;">
                        <i class="bi bi-info-circle d-block mb-2" style="font-size:28px;"></i>
                        {{ salStats.prediction.message|default('Minimum 3 mois de données requis') }}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- ── RISK ANALYSIS TABLE (de recrutement_user) ─────────────────── -->
    <div class="card" id="riskTable"
         style="border-radius:20px; border:none; box-shadow:0 4px 20px rgba(0,0,0,0.08);">
        <div class="card-header" style="border-radius:20px 20px 0 0; background:white; border-bottom:2px solid #dbeafe;">
            <h3 class="card-title" style="color:#1e3a5f; font-weight:700;">
                🤖 Analyse IA — Prédiction d'inactivité
            </h3>
            <div class="card-tools">
                <small style="color:#64748b;">
                    Score basé sur : fréquence de connexion · ancienneté du compte · rôle · tendance
                </small>
            </div>
        </div>
        <div class="card-body p-0">
            {% if riskUsers|length > 0 %}
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead style="background:#f8fafc;">
                        <tr>
                            <th style="padding:14px 20px; color:#1e3a5f; font-weight:700;">Utilisateur</th>
                            <th style="color:#1e3a5f; font-weight:700;">Dernière connexion</th>
                            <th style="color:#1e3a5f; font-weight:700; min-width:200px;">Score de risque</th>
                            <th style="color:#1e3a5f; font-weight:700;">Niveau</th>
                            <th style="color:#1e3a5f; font-weight:700;">Tendance</th>
                            <th style="color:#1e3a5f; font-weight:700;">Détail score</th>
                        </tr>
                        </thead>
                        <tbody>
                        {% for item in riskUsers %}
                            {% set barColor = {
                                'Critical': '#ef4444',
                                'High':     '#f59e0b',
                                'Medium':   '#3b82f6',
                                'Low':      '#94a3b8',
                                'Active':   '#0FA36B'
                            }[item.riskLevel] ?? '#94a3b8' %}

                            <tr style="border-bottom:1px solid #f1f5f9;">
                                <td style="padding:14px 20px;">
                                    <div style="font-weight:600; color:#0f172a;">{{ item.user.username }}</div>
                                    <div style="font-size:11px; color:#94a3b8;">{{ item.user.email }}</div>
                                </td>
                                <td style="color:#374151;">
                                    {% if item.user.lastLogin %}
                                        {{ item.user.lastLogin|date('d/m/Y H:i') }}
                                        <div style="font-size:11px; color:#94a3b8;">
                                            il y a {{ item.daysSinceLastLogin }} jour(s)
                                        </div>
                                    {% else %}
                                        <span style="color:#ef4444; font-weight:600;">Jamais connecté</span>
                                    {% endif %}
                                </td>
                                <td style="padding-right:24px;">
                                    <div class="d-flex align-items-center" style="gap:10px;">
                                        <div class="risk-bar-wrap flex-grow-1">
                                            <div class="risk-bar"
                                                 style="width:{{ item.riskScore }}%; background:{{ barColor }};"></div>
                                        </div>
                                        <span style="font-weight:700; color:{{ barColor }}; min-width:38px; text-align:right;">
                                            {{ item.riskScore }}%
                                        </span>
                                    </div>
                                </td>
                                <td>
                                    {% set badgeBg = {
                                        'Critical': '#fef2f2',
                                        'High':     '#fffbeb',
                                        'Medium':   '#eff6ff',
                                        'Low':      '#f8fafc',
                                        'Active':   '#f0fdf4'
                                    }[item.riskLevel] ?? '#f8fafc' %}
                                    <span style="background:{{ badgeBg }}; color:{{ barColor }};
                                            padding:4px 14px; border-radius:20px;
                                            font-weight:700; font-size:12px;">
                                        {% if item.riskLevel == 'Critical' %}🔴 Critique
                                        {% elseif item.riskLevel == 'High' %}🟠 Élevé
                                        {% elseif item.riskLevel == 'Medium' %}🔵 Moyen
                                        {% elseif item.riskLevel == 'Low' %}⚪ Faible
                                        {% else %}🟢 Actif{% endif %}
                                    </span>
                                </td>
                                <td>
                                    {% if item.trend == 'never' %}
                                        <span class="trend-icon" title="Jamais connecté">⛔</span>
                                    {% elseif item.trend == 'declining' %}
                                        <span class="trend-icon" title="En déclin">📉</span>
                                    {% elseif item.trend == 'at_risk' %}
                                        <span class="trend-icon" title="À surveiller">⚠️</span>
                                    {% else %}
                                        <span class="trend-icon" title="Sain">✅</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <span class="breakdown-pill" title="Connexion">🔑 {{ item.breakdown.login }}</span>
                                    <span class="breakdown-pill" title="Ancienneté">📅 {{ item.breakdown.age }}</span>
                                    <span class="breakdown-pill" title="Rôle">👤 {{ item.breakdown.role }}</span>
                                    <span class="breakdown-pill" title="Tendance">📊 {{ item.breakdown.trend }}</span>
                                </td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
                <div style="padding:12px 20px; background:#f8fafc; border-radius:0 0 20px 20px;
                    font-size:12px; color:#64748b; border-top:1px solid #e2e8f0;">
                    💡 Les utilisateurs inactifs depuis plus de 3 jours sont automatiquement désactivés.
                    Score = connexion(50) + ancienneté(20) + rôle(20) + tendance(10).
                </div>
            {% else %}
                <div class="text-center" style="padding:40px; color:#94a3b8;">
                    <i class="fas fa-users fa-2x mb-2 d-block"></i>
                    Aucun utilisateur trouvé.
                </div>
            {% endif %}
        </div>
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // ── 1. Graphique Utilisateurs Actifs/Inactifs ──
        new Chart(document.getElementById('userChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['Actifs', 'Inactifs'],
                datasets: [{
                    data: [{{ stats.active }}, {{ stats.inactive }}],
                    backgroundColor: ['#0FA36B', '#ef4444'],
                    borderWidth: 0,
                    hoverOffset: 8
                }]
            },
            options: {
                responsive: true,
                cutout: '65%',
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 13 } } }
                }
            }
        });

        // ── 2. Graphique Statuts Salaires ──
        new Chart(document.getElementById('statusChart').getContext('2d'), {
            type: 'doughnut',
            data: {
                labels: ['PAYÉ', 'EN COURS', 'CRÉÉ'],
                datasets: [{
                    data: [
                        {{ salStats.paidCount }},
                        {{ salStats.enCoursCount }},
                        {{ salStats.creeCount }}
                    ],
                    backgroundColor: ['#166534', '#0369a1', '#854d0e'],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                plugins: {
                    legend: { position: 'bottom', labels: { font: { size: 11 } } }
                },
                cutout: '60%'
            }
        });

        // ── 3. Graphique Évolution Mensuelle + Prédiction ──
        {% if salStats.monthlyData.labels|length > 0 %}

        const historicalLabels = {{ salStats.monthlyData.labels | json_encode | raw }};
        const historicalData   = {{ salStats.monthlyData.data   | json_encode | raw }};

        {% set predLabels = [] %}
        {% set predData   = [] %}
        {% for pred in salStats.prediction.predictions %}
            {% set predLabels = predLabels|merge([pred.month]) %}
            {% set predData   = predData|merge([pred.value]) %}
        {% endfor %}

        const predLabels = {{ predLabels | json_encode | raw }};
        const predValues = {{ predData   | json_encode | raw }};

        // Fusion des labels
        const allLabels = [...historicalLabels, ...predLabels];

        // Données historiques (avec null pour les mois de prédiction)
        const histFull = [
            ...historicalData,
            ...Array(predLabels.length).fill(null)
        ];

        // Données prédiction (null pour l'historique + dernier point historique pour continuité)
        const predFull = [
            ...Array(historicalData.length - 1).fill(null),
            historicalData[historicalData.length - 1],
            ...predValues
        ];

        new Chart(document.getElementById('monthlyChart').getContext('2d'), {
            type: 'line',
            data: {
                labels: allLabels,
                datasets: [
                    {
                        label: 'Historique',
                        data: histFull,
                        borderColor: '#667eea',
                        backgroundColor: 'rgba(102,126,234,0.08)',
                        borderWidth: 3,
                        pointRadius: 5,
                        pointBackgroundColor: '#667eea',
                        tension: 0.3,
                        fill: true,
                        spanGaps: false
                    },
                    {
                        label: 'Prédiction IA',
                        data: predFull,
                        borderColor: '#ef4444',
                        backgroundColor: 'rgba(239,68,68,0.06)',
                        borderWidth: 3,
                        borderDash: [8, 4],
                        pointRadius: 5,
                        pointStyle: 'triangle',
                        pointBackgroundColor: '#ef4444',
                        tension: 0.3,
                        fill: false,
                        spanGaps: false
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: true,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: { position: 'top', labels: { font: { size: 11 } } },
                    tooltip: {
                        callbacks: {
                            label: ctx => ctx.parsed.y !== null
                                ? `${ctx.dataset.label} : ${ctx.parsed.y.toLocaleString('fr-TN')} DT`
                                : null
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: false,
                        ticks: {
                            callback: val => val.toLocaleString('fr-TN') + ' DT',
                            font: { size: 10 }
                        },
                        grid: { color: '#f1f5f9' }
                    },
                    x: {
                        ticks: { font: { size: 10 } },
                        grid: { display: false }
                    }
                }
            }
        });
        {% endif %}
    </script>
{% endblock %}