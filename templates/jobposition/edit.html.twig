{% extends 'base.html.twig' %}

{% block title %}Modifier une offre{% endblock %}

{% block body %}
    <div class="dashboard-container">
        <!-- HEADER identique au dashboard -->
        <div class="main-header">
            <div class="logo-area">
                <div class="logo-icon">IN</div>
                <div class="logo-text">
                    <h1>INTEGRA RECRUITMENT</h1>
                    <p>Gestion des recrutements</p>
                </div>
            </div>
            <div>
                <div class="user-info">
                    <strong>Admin User</strong><br>
                    <span>Administrateur</span>
                </div>
            </div>
        </div>

        <!-- Carte d'édition -->
        <div class="card-modern" style="max-width: 800px; margin: 30px auto;">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-edit"></i> Modifier l'offre
                </div>
                <a href="{{ path('app_recruitment_dashboard') }}" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Retour au tableau
                </a>
            </div>

            <!-- Formulaire d'édition -->
            {{ form_start(form, {'attr': {'class': 'form-grid'}}) }}
            <div class="form-group">{{ form_row(form.title, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.departement, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.employeeType, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.status, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group full">{{ form_row(form.description, {'attr': {'class': 'form-control', 'rows': 4}}) }}</div>
            <div class="form-group">{{ form_row(form.postedAt, {'attr': {'class': 'form-control'}}) }}</div>

            <div class="modal-footer" style="grid-column: span 2; padding: 0; margin-top: 20px; display: flex; justify-content: space-between;">
                <a href="{{ path('app_recruitment_dashboard') }}" class="btn btn-outline">Annuler</a>
                <button type="submit" class="btn btn-success">Mettre à jour</button>
            </div>
            {{ form_end(form) }}

            <!-- Formulaire de suppression -->
            <hr style="margin: 30px 0 20px; border-color: var(--gray-200);">
            <div style="text-align: center;">
                <form method="post" action="{{ path('app_jobposition_delete', {'idJob': jobposition.idJob}) }}" onsubmit="return confirm('Supprimer définitivement cette offre ?');" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ jobposition.idJob) }}">
                    <button class="btn btn-danger">🗑 Supprimer l'offre</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}