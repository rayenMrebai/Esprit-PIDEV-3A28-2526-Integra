{% extends 'base.html.twig' %}

{% block title %}Affectation #{{ assignment.idAssignment }}{% endblock %}

{% block content %}

    <div class="integra-header">
        <div>
            <h1>📋 Détail de l'affectation</h1>
            <p>Affectation #{{ assignment.idAssignment }}</p>
        </div>
        <a href="{{ path('app_projectassignment_index') }}" style="background:rgba(255,255,255,0.25); color:white; border-radius:30px; padding:10px 20px; text-decoration:none; font-weight:bold; border:1px solid rgba(255,255,255,0.4);">
            ← Retour
        </a>
    </div>

    <div class="details-card" style="max-width:800px; margin:0 auto;">
        <h3 style="font-size:18px; font-weight:bold; color:#1e3a5f; border-bottom:2px solid #b0c4de; padding-bottom:10px; margin-bottom:20px;">
            📋 Informations
        </h3>
        <div class="detail-row"><div class="detail-label">ID :</div><div class="detail-value">{{ assignment.idAssignment }}</div></div>
        <div class="detail-row"><div class="detail-label">Projet :</div><div class="detail-value">{{ assignment.project ? assignment.project.name : '—' }}</div></div>
        <div class="detail-row"><div class="detail-label">Employé :</div><div class="detail-value">{{ assignment.userAccount ? assignment.userAccount.username : '—' }}</div></div>
        <div class="detail-row"><div class="detail-label">Rôle :</div><div class="detail-value">{{ assignment.role }}</div></div>
        <div class="detail-row"><div class="detail-label">Allocation :</div><div class="detail-value">{{ assignment.allocationRate }}%</div></div>
        <div class="detail-row"><div class="detail-label">Date début :</div><div class="detail-value">{{ assignment.assignedFrom ? assignment.assignedFrom|date('Y-m-d') : '—' }}</div></div>
        <div class="detail-row"><div class="detail-label">Date fin :</div><div class="detail-value">{{ assignment.assignedTo ? assignment.assignedTo|date('Y-m-d') : '—' }}</div></div>
    </div>

{% endblock %}