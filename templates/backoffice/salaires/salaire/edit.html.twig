{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Modifier le Salaire{% endblock %}
{% block page_title %}Modifier le Salaire{% endblock %}
{% block breadcrumb %}Salaires / Modifier{% endblock %}

{% block admin_content %}

{# Messages flash #}
{% for msg in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show rounded-4 border-0 shadow-sm" role="alert">
    <i class="bi bi-check-circle-fill me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}
{% for msg in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show rounded-4 border-0 shadow-sm" role="alert">
    <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}

<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card border-0 rounded-4 shadow-lg overflow-hidden">
      <div class="card-header bg-gradient-primary text-white py-3" style="background: linear-gradient(135deg, #0d6efd, #0b5ed7);">
        <h5 class="mb-0 text-center fw-semibold"><i class="bi bi-pencil-square me-2"></i>Modifier le Salaire</h5>
      </div>
      <div class="card-body p-4 p-lg-5">
        
        {# ═══════════════════════════════════════════════════════════
           SECTION INFORMATIONS NON MODIFIABLES (comme votre interface Java)
        ═══════════════════════════════════════════════════════════ #}
        <div class="alert alert-light border-start border-4 border-primary rounded-3 shadow-sm mb-4 p-3">
          <h6 class="fw-bold text-dark mb-3 pb-2 border-bottom border-2 border-primary d-inline-block"><i class="bi bi-info-circle-fill me-1 text-primary"></i> Informations du Salaire (non modifiables)</h6>
          
          <table class="table table-sm table-borderless mb-0">
            <tbody>
              <tr>
                <td style="width: 35%;" class="fw-semibold text-secondary">👤 Nom d'utilisateur:</td>
                <td style="width: 65%;" class="text-dark fw-medium">{{ salaire.user.username }}</td>
              </tr>
              <tr>
                <td class="fw-semibold text-secondary">💰 Salaire de Base:</td>
                <td class="text-primary fw-bold">{{ salaire.baseAmount|number_format(2, ',', ' ') }} DT</td>
              </tr>
              <tr>
                <td class="fw-semibold text-secondary">🎁 Bonus:</td>
                <td class="text-success fw-bold">{{ salaire.bonusAmount|number_format(2, ',', ' ') }} DT</td>
              </tr>
              <tr class="border-top pt-2">
                <td class="fw-semibold text-secondary">📊 Total:</td>
                <td class="fw-bold text-danger" style="font-size: 1.2em;">
                  {{ salaire.totalAmount|number_format(2, ',', ' ') }} DT
                </td>
              </tr>
            </tbody>
          </table>
        </div>
        
        <hr class="my-4 border-2 border-dashed">
        
        {# ═══════════════════════════════════════════════════════════
           SECTION CHAMPS MODIFIABLES
        ═══════════════════════════════════════════════════════════ #}
        <h6 class="fw-bold text-center mb-4 text-dark"><i class="bi bi-pencil-fill me-2 text-warning"></i>Champs Modifiables</h6>
        
        {# Formulaire avec validation côté serveur uniquement #}
        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'needs-validation'}}) }}
        
        <div class="mb-4">
          <div class="row align-items-center g-3">
            <div class="col-md-4 text-md-end">
              {{ form_label(form.status, "Statut", {'label_attr': {'class': 'form-label fw-semibold mb-0'}}) }}
              <span class="text-danger">*</span>
            </div>
            <div class="col-md-5">
              {{ form_widget(form.status, {'attr': {'class': 'form-select rounded-3 border-2'}}) }}
            </div>
            <div class="col-md-3">
              {{ form_errors(form.status, {'attr': {'class': 'text-danger small fw-semibold d-block'}}) }}
            </div>
          </div>
        </div>
        
        <div class="mb-4">
          <div class="row align-items-center g-3">
            <div class="col-md-4 text-md-end">
              {{ form_label(form.datePaiement, "Date de Paiement", {'label_attr': {'class': 'form-label fw-semibold mb-0'}}) }}
              <span class="text-danger">*</span>
            </div>
            <div class="col-md-5">
              {{ form_widget(form.datePaiement, {'attr': {'class': 'form-control rounded-3 border-2'}}) }}
            </div>
            <div class="col-md-3">
              {{ form_errors(form.datePaiement, {'attr': {'class': 'text-danger small fw-semibold d-block'}}) }}
            </div>
          </div>
        </div>
        
        {# Messages d'aide spécifiques #}
        <div class="alert alert-warning bg-warning bg-opacity-10 border border-warning rounded-3 small py-2 px-3 mb-4">
          <i class="bi bi-lightbulb-fill me-1 text-warning"></i>
          <strong class="text-dark">Note:</strong> <span class="text-muted">Si le statut est "PAYÉ", la date de paiement doit être aujourd'hui.</span>
        </div>
        
        {# Boutons d'action #}
        <div class="d-flex justify-content-center gap-3 mt-5">
          {{ form_widget(form.save, {'attr': {'class': 'btn btn-primary px-5 py-2 rounded-pill shadow-sm fw-semibold'}}) }}
          <a href="{{ path('app_backoffice_salaires_index') }}" class="btn btn-outline-secondary px-4 py-2 rounded-pill fw-semibold">
            <i class="bi bi-arrow-left me-1"></i> Annuler
          </a>
        </div>

        {# Rendu des champs cachés #}
        {{ form_rest(form) }}
        
        {{ form_end(form) }}
        
      </div>
    </div>
  </div>
</div>

{% endblock %}