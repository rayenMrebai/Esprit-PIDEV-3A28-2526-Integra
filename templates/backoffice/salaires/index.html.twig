{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Gestion des Salaires{% endblock %}
{% block page_title %}Gestion des Salaires{% endblock %}
{% block breadcrumb %}Salaires{% endblock %}

{% block admin_content %}

{# Messages flash #}
{% for msg in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}
{% for msg in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-circle me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}

<div class="row g-3">

  {# ══════════════════════════════════════════
     COLONNE GAUCHE — Liste des salaires
  ══════════════════════════════════════════ #}
  <div class="col-lg-5" id="leftPanel">
    <div class="card h-100">
      <div class="card-body">

        <h4 class="fw-bold text-dark mb-1">Employee Salaries</h4>
        <p class="text-muted small mb-3">Manage employee compensation</p>

        {# Barre d'outils #}
        <div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
          <input type="text" id="searchInput" class="form-control"
                 placeholder="Search employee" style="max-width:240px;">
          <a href="{{ path('salaire_new') }}" class="btn btn-success">
            <i class="bi bi-plus-lg me-1"></i> Add Salary
          </a>
        </div>

        <hr>

        {# En-têtes #}
        <div class="row px-2 mb-2">
          <div class="col-1  text-muted fw-bold" style="font-size:11px;">ID</div>
          <div class="col-3  text-muted fw-bold" style="font-size:11px;">Employee</div>
          <div class="col-2  text-muted fw-bold" style="font-size:11px;">Base</div>
          <div class="col-2  text-muted fw-bold" style="font-size:11px;">Bonus</div>
          <div class="col-2  text-muted fw-bold" style="font-size:11px;">Total</div>
          <div class="col-2  text-muted fw-bold" style="font-size:11px;">Status</div>
        </div>

        {# Lignes #}
        <div id="salaryRows">
          {% if salaires|length > 0 %}
            {% for salaire in salaires %}

              {# Badge statut #}
              {% if salaire.status == 'EN_COURS' %}
                {% set badgeClass = 'text-bg-info' %}
              {% elseif salaire.status == 'PAYÉ' %}
                {% set badgeClass = 'text-bg-success' %}
              {% else %}
                {% set badgeClass = 'text-bg-warning text-dark' %}
              {% endif %}

              <div class="salary-row row align-items-center px-2 py-3 rounded mb-1"
                   style="cursor:pointer; transition:background .15s;"
                   onmouseover="if(!this.classList.contains('active-row')) this.style.background='#f7fafc'"
                   onmouseout="if(!this.classList.contains('active-row')) this.style.background=''"
                   onclick="showDetails(this,
                     {{ salaire.id }},
                     '{{ salaire.user.username | e('js') }}',
                     {{ salaire.baseAmount }},
                     {{ salaire.bonusAmount }},
                     {{ salaire.totalAmount }},
                     '{{ salaire.datePaiement | date('Y-m-d') }}',
                     '{{ salaire.status }}'
                   )"
                   data-id="{{ salaire.id }}">

                <div class="col-1 fw-bold text-secondary" style="font-size:13px;">
                  {{ salaire.user.userId }}
                </div>
                <div class="col-3" style="font-size:13px; color:#2d3748;">
                  {{ salaire.user.username }}
                </div>
                <div class="col-2" style="font-size:13px; color:#2b6cb0;">
                  {{ salaire.baseAmount | number_format(2, ',', ' ') }} DT
                </div>
                <div class="col-2 fw-semibold" style="font-size:13px; color:#38a169;">
                  {{ salaire.bonusAmount | number_format(2, ',', ' ') }} DT
                </div>
                <div class="col-2 fw-bold" style="font-size:14px; color:#5a67d8;">
                  {{ salaire.totalAmount | number_format(2, ',', ' ') }} DT
                </div>
                <div class="col-2">
                  <span class="badge rounded-pill {{ badgeClass }}" style="font-size:11px;">
                    {{ salaire.status }}
                  </span>
                </div>

              </div>
            {% endfor %}
          {% else %}
            <div class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-2 d-block mb-2"></i>
              Aucun salaire enregistré.
            </div>
          {% endif %}
        </div>

      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════
     COLONNE DROITE — Détails + Bonus Rules
  ══════════════════════════════════════════ #}
  <div class="col-lg-7" id="rightPanel" style="display:none;">
    <div class="card h-100">
      <div class="card-body">

        {# Header #}
        <div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
          <div>
            <h4 class="fw-bold text-dark mb-0">Salary Details</h4>
            <p class="text-muted small mb-0">Complete salary breakdown</p>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            {# Générer PDF — lien dynamique mis à jour par JS #}
            <a id="btnPdf" href="#" class="btn btn-sm text-white" style="background:#9f7aea;">
              <i class="bi bi-file-earmark-pdf me-1"></i> Générer PDF
            </a>
            {# Update — lien dynamique mis à jour par JS #}
            <a id="btnEdit" href="#" class="btn btn-sm btn-primary">Update</a>
            {# Delete — form POST #}
            <form id="deleteForm" method="POST" action="#"
                  onsubmit="return confirm('Supprimer ce salaire ?')">
              <input type="hidden" name="_token" id="deleteToken" value="">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </div>

        {# Carte résumé #}
        <div class="rounded-3 p-4 mb-3" style="background:#e0e7ff;">
          <h3 class="fw-bold mb-3" id="detailName">—</h3>
          <div class="d-flex gap-5 mb-3">
            <div>
              <div class="text-muted small fw-bold mb-1">Base Salary</div>
              <div class="fw-bold fs-5" id="detailBase" style="color:#2d3748;">—</div>
            </div>
            <div>
              <div class="text-muted small fw-bold mb-1">Bonus Applied</div>
              <div class="fw-bold fs-5 text-success" id="detailBonus">—</div>
            </div>
          </div>
          <hr class="border-secondary opacity-25">
          <div class="d-flex align-items-center gap-3">
            <span class="text-muted fw-bold">Total Salary</span>
            <span class="fw-bold" style="font-size:28px; color:#667eea;" id="detailTotal">—</span>
          </div>
        </div>

        {# Grille infos #}
        <div class="rounded-3 p-3 mb-3" style="background:#f7fafc;">
          <div class="row mb-2 align-items-center">
            <div class="col-5 text-muted fw-bold" style="font-size:13px;">Payment Date</div>
            <div class="col-7" style="font-size:14px;" id="detailDate">—</div>
          </div>
          <div class="row align-items-center">
            <div class="col-5 text-muted fw-bold" style="font-size:13px;">Salary Status</div>
            <div class="col-7">
              <span class="badge rounded-pill" id="detailStatus">—</span>
            </div>
          </div>
        </div>

        <hr>

        {# Bonus Rules #}
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
          <div>
            <h5 class="fw-bold mb-0">Bonus Rules</h5>
            <p class="text-muted small mb-0">Manage bonus calculation rules</p>
          </div>
          <a id="btnAddRule" href="{{ path('bonus_rule_new') }}"
             class="btn btn-sm text-white" style="background:#9f7aea;">
            <i class="bi bi-plus-lg me-1"></i> Add Bonus Rule
          </a>
        </div>

        {# En-têtes bonus rules #}
        <div class="row px-2 mb-1">
          <div class="col-1  text-muted fw-bold" style="font-size:11px;">ID</div>
          <div class="col-3  text-muted fw-bold" style="font-size:11px;">Rule Name</div>
          <div class="col-2  text-muted fw-bold" style="font-size:11px;">Percentage</div>
          <div class="col-3  text-muted fw-bold" style="font-size:11px;">Conditions</div>
          <div class="col-3  text-muted fw-bold" style="font-size:11px;">Actions</div>
        </div>

        <div id="bonusRulesList">
          <div class="text-center text-muted py-3 small">
            Cliquez sur un salaire pour voir ses règles.
          </div>
        </div>

      </div>
    </div>
  </div>

</div>

{# ── Données JSON pour le JS ── #}
{# bonusRulesMap : { salaireId: [ {id, nomRegle, percentage, conditionText, status, editUrl, deleteUrl, deleteToken} ] } #}
<script>
const bonusRulesMap = {{ bonusRulesMap | json_encode | raw }};
const salaireUrls   = {{ salaireUrls   | json_encode | raw }};

let activeRow = null;

function showDetails(row, id, name, base, bonus, total, date, status) {

  // Surbrillance
  if (activeRow) {
    activeRow.style.background = '';
    activeRow.classList.remove('active-row');
  }
  row.style.background = '#ebf4ff';
  row.classList.add('active-row');
  activeRow = row;

  document.getElementById('rightPanel').style.display = '';

  // Détails
  document.getElementById('detailName').textContent  = name;
  document.getElementById('detailBase').textContent  = formatDT(base);
  document.getElementById('detailBonus').textContent = formatDT(bonus);
  document.getElementById('detailTotal').textContent = formatDT(total);
  document.getElementById('detailDate').textContent  = date;

  const badge = document.getElementById('detailStatus');
  badge.textContent = status;
  badge.className   = 'badge rounded-pill ' + getStatusClass(status);

  // Boutons dynamiques via salaireUrls
  const urls = salaireUrls[id] || {};
  document.getElementById('btnEdit').href         = urls.edit  || '#';
  document.getElementById('btnPdf').href          = urls.show  || '#';
  document.getElementById('deleteForm').action    = urls.delete || '#';
  document.getElementById('deleteToken').value    = urls.deleteToken || '';

  // Désactiver Delete si PAYÉ
  document.querySelector('#deleteForm button').disabled = (status === 'PAYÉ');

  // Bonus rules
  loadBonusRules(id, status);
}

function loadBonusRules(salaireId, salaireStatus) {
  const container = document.getElementById('bonusRulesList');
  const rules     = bonusRulesMap[salaireId] || [];

  if (rules.length === 0) {
    container.innerHTML = '<div class="text-center text-muted py-3 small">Aucune règle de bonus pour ce salaire.</div>';
    return;
  }

  container.innerHTML = rules.map(rule => {
    const isLocked = rule.status === 'ACTIVE' || salaireStatus === 'PAYÉ';

    const editBtn = isLocked
      ? `<button class="btn btn-sm btn-secondary" style="opacity:.5;font-size:11px;" disabled>Edit</button>`
      : `<a href="${rule.editUrl}" class="btn btn-sm btn-primary" style="font-size:11px;">Edit</a>`;

    const delBtn = isLocked
      ? `<button class="btn btn-sm btn-secondary" style="opacity:.5;font-size:11px;" disabled>Delete</button>`
      : `<form method="POST" action="${rule.deleteUrl}" style="display:inline"
              onsubmit="return confirm('Supprimer cette règle ?')">
           <input type="hidden" name="_token" value="${rule.deleteToken}">
           <button type="submit" class="btn btn-sm btn-danger" style="font-size:11px;">Delete</button>
         </form>`;

    return `
      <div class="row align-items-center px-2 py-2 mb-1 rounded border"
           style="background:white; font-size:13px;">
        <div class="col-1 fw-bold text-muted">${rule.id}</div>
        <div class="col-3">${rule.nomRegle}</div>
        <div class="col-2 fw-semibold text-success">${rule.percentage}%</div>
        <div class="col-3 text-muted small">${rule.conditionText ?? ''}</div>
        <div class="col-3 d-flex gap-1 align-items-center">${editBtn}${delBtn}</div>
      </div>`;
  }).join('');
}

function formatDT(amount) {
  return parseFloat(amount).toLocaleString('fr-TN', {
    minimumFractionDigits: 2, maximumFractionDigits: 2
  }) + ' DT';
}

function getStatusClass(status) {
  if (status === 'EN_COURS') return 'text-bg-info';
  if (status === 'PAYÉ')     return 'text-bg-success';
  return 'text-bg-warning text-dark';
}

// Recherche live
document.getElementById('searchInput').addEventListener('keyup', function () {
  const filter = this.value.toLowerCase();
  document.querySelectorAll('.salary-row').forEach(row => {
    row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
  });
});
</script>

{% endblock %}
