{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Gestion des Salaires{% endblock %}
{% block page_title %}Gestion des Salaires{% endblock %}
{% block breadcrumb %}Salaires{% endblock %}

{% block admin_content %}

{# Messages flash #}
{% for msg in app.flashes('success') %}
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}
{% for msg in app.flashes('error') %}
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-circle me-2"></i>{{ msg }}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
{% endfor %}

<div class="row g-3">

  {# ══════════════════════════════════════════
     COLONNE GAUCHE — Liste des salaires
  ══════════════════════════════════════════ #}
  <div class="col-lg-6" id="leftPanel">
    <div class="card h-100">
      <div class="card-body d-flex flex-column" style="gap:0;">

        {# ── Header + barre d'outils inline ── #}
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
          <div>
            <h5 class="fw-bold text-dark mb-0" style="font-size:15px;">Employee Salaries</h5>
            <span class="text-muted" style="font-size:11px;">Manage employee compensation</span>
          </div>
          <a href="{{ path('salaire_new') }}" class="btn btn-success btn-sm">
            <i class="bi bi-plus-lg me-1"></i> Ajouter
          </a>
        </div>

        {# ── Recherche + filtre sur une seule ligne ── #}
        <div class="d-flex gap-2 mb-2 align-items-center flex-wrap" style="background:#f8fafc; border-radius:8px; padding:8px 10px; border:0.5px solid #e2e8f0;">

          {# Recherche #}
          <form method="get" action="{{ path('app_backoffice_salaires_index') }}" class="d-flex gap-1 align-items-center flex-grow-1" style="min-width:160px;">
            <div class="input-group input-group-sm" style="max-width:220px;">
              <span class="input-group-text bg-white px-2"><i class="bi bi-search" style="font-size:11px;"></i></span>
              <input type="text" name="search" class="form-control form-control-sm" placeholder="Rechercher..." value="{{ search|default('') }}" style="font-size:12px;">
              {% if hasSearch|default(false) %}
                <a href="{{ path('app_backoffice_salaires_index') }}" class="btn btn-outline-danger btn-sm px-2" title="Effacer"><i class="bi bi-x" style="font-size:12px;"></i></a>
              {% endif %}
              <button type="submit" class="btn btn-primary btn-sm px-2" style="font-size:11px;">OK</button>
            </div>
          </form>

          {# Séparateur #}
          <div style="width:1px; height:24px; background:#e2e8f0;"></div>

          {# Filtre statut #}
          <form method="get" action="{{ path('app_backoffice_salaires_index') }}" class="d-flex gap-1 align-items-center">
            {% if hasSearch|default(false) %}
              <input type="hidden" name="search" value="{{ search }}">
            {% endif %}
            <select name="filter_status" class="form-select form-select-sm" style="font-size:11px; width:auto; min-width:120px;">
              <option value="">Tous les statuts</option>
              <option value="CREÉ" {% if filterStatus|default('') == 'CREÉ' %}selected{% endif %}>CRÉÉ</option>
              <option value="EN_COURS" {% if filterStatus|default('') == 'EN_COURS' %}selected{% endif %}>EN COURS</option>
              <option value="PAYÉ" {% if filterStatus|default('') == 'PAYÉ' %}selected{% endif %}>PAYÉ</option>
            </select>
            <button type="submit" class="btn btn-outline-primary btn-sm px-2" style="font-size:11px;"><i class="bi bi-funnel-fill"></i></button>
            {% if hasFilter|default(false) %}
              <a href="{{ path('app_backoffice_salaires_index', {'search': search}) }}" class="btn btn-outline-danger btn-sm px-2" title="Effacer filtre"><i class="bi bi-x" style="font-size:12px;"></i></a>
            {% endif %}
          </form>
        </div>

        {# Badges actifs #}
        {% if hasSearch|default(false) or hasFilter|default(false) %}
          <div class="d-flex gap-2 mb-2 flex-wrap" style="font-size:11px;">
            {% if hasSearch|default(false) %}
              <span class="badge bg-secondary fw-normal"><i class="bi bi-search me-1"></i>{{ search }}</span>
            {% endif %}
            {% if hasFilter|default(false) %}
              <span class="badge bg-info text-dark fw-normal"><i class="bi bi-funnel me-1"></i>{{ filterStatus }}</span>
            {% endif %}
          </div>
        {% endif %}

        <hr class="my-2">

        {# En-têtes #}
        <div class="row px-2 mb-1" style="font-size:10px; text-transform:uppercase; letter-spacing:.04em; color:#94a3b8; font-weight:700;">
          <div class="col-1">ID</div>
          <div class="col-3">Employé</div>
          <div class="col-2">Base</div>
          <div class="col-2">Bonus</div>
          <div class="col-2">Total</div>
          <div class="col-2">Statut</div>
        </div>

        {# Lignes — scrollable si nécessaire #}
        <div id="salaryRows" style="overflow-y:auto; flex:1;">
          {% if salaires|length > 0 %}
            {% for salaire in salaires %}
              {% if salaire.status == 'EN_COURS' %}
                {% set badgeClass = 'text-bg-info' %}
              {% elseif salaire.status == 'PAYÉ' %}
                {% set badgeClass = 'text-bg-success' %}
              {% else %}
                {% set badgeClass = 'text-bg-warning text-dark' %}
              {% endif %}

              <div class="salary-row row align-items-center px-2 py-2 rounded mb-1"
                   style="cursor:pointer; transition:background .15s; font-size:12px;"
                   onmouseover="if(!this.classList.contains('active-row')) this.style.background='#f7fafc'"
                   onmouseout="if(!this.classList.contains('active-row')) this.style.background=''"
                   onclick="showDetails(this, {{ salaire.id }}, '{{ salaire.user.username | e('js') }}', {{ salaire.baseAmount }}, {{ salaire.bonusAmount }}, {{ salaire.totalAmount }}, '{{ salaire.datePaiement | date('Y-m-d') }}', '{{ salaire.status }}')"
                   data-id="{{ salaire.id }}">

                <div class="col-1 fw-bold text-secondary" style="font-size:11px;">{{ salaire.user.userId }}</div>
                <div class="col-3" style="color:#2d3748; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ salaire.user.username }}</div>
                <div class="col-2" style="color:#2b6cb0;">{{ salaire.baseAmount | number_format(2, ',', ' ') }} DT</div>
                <div class="col-2 fw-semibold" style="color:#38a169;">{{ salaire.bonusAmount | number_format(2, ',', ' ') }} DT</div>
                <div class="col-2 fw-bold" style="color:#5a67d8;">{{ salaire.totalAmount | number_format(2, ',', ' ') }} DT</div>
                <div class="col-2">
                  <span class="badge rounded-pill {{ badgeClass }}" style="font-size:10px;">{{ salaire.status }}</span>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <div class="text-center text-muted py-5">
              <i class="bi bi-inbox fs-2 d-block mb-2"></i>
              {% if hasSearch|default(false) or hasFilter|default(false) %}
                Aucun résultat ne correspond aux critères.
              {% else %}
                Aucun salaire enregistré.
              {% endif %}
            </div>
          {% endif %}
        </div>

      </div>
    </div>
  </div>

  {# ══════════════════════════════════════════
     COLONNE DROITE — Détails + Bonus Rules
  ══════════════════════════════════════════ #}
  <div class="col-lg-6" id="rightPanel" style="display:none;">
    <div class="card h-100">
      <div class="card-body">
        <div class="d-flex align-items-start justify-content-between mb-3 flex-wrap gap-2">
          <div>
            <h4 class="fw-bold text-dark mb-0">Salary Details</h4>
            <p class="text-muted small mb-0">Complete salary breakdown</p>
          </div>
          <div class="d-flex gap-2 flex-wrap">
            <a id="btnPdf" href="#" class="btn btn-sm text-white" style="background:#9f7aea;">
              <i class="bi bi-file-earmark-pdf me-1"></i> Générer PDF
            </a>
            <a id="btnEdit" href="#" class="btn btn-sm btn-primary">Update</a>
            <form id="deleteForm" method="POST" action="#" onsubmit="return confirm('Supprimer ce salaire ?')">
              <input type="hidden" name="_token" id="deleteToken" value="">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </div>

        <div class="rounded-3 p-4 mb-3" style="background:#e0e7ff;">
          <h3 class="fw-bold mb-3" id="detailName">—</h3>
          <div class="d-flex gap-5 mb-3">
            <div>
              <div class="text-muted small fw-bold mb-1">Base Salary</div>
              <div class="fw-bold fs-5" id="detailBase" style="color:#2d3748;">—</div>
            </div>
            <div>
              <div class="text-muted small fw-bold mb-1">Bonus Applied</div>
              <div class="fw-bold fs-5 text-success" id="detailBonus">—</div>
            </div>
          </div>
          <hr class="border-secondary opacity-25">
          <div class="d-flex align-items-center gap-3">
            <span class="text-muted fw-bold">Total Salary</span>
            <span class="fw-bold" style="font-size:28px; color:#667eea;" id="detailTotal">—</span>
          </div>
        </div>

        <div class="rounded-3 p-3 mb-3" style="background:#f7fafc;">
          <div class="row mb-2 align-items-center">
            <div class="col-5 text-muted fw-bold" style="font-size:13px;">Payment Date</div>
            <div class="col-7" style="font-size:14px;" id="detailDate">—</div>
          </div>
          <div class="row align-items-center">
            <div class="col-5 text-muted fw-bold" style="font-size:13px;">Salary Status</div>
            <div class="col-7">
              <span class="badge rounded-pill" id="detailStatus">—</span>
            </div>
          </div>
        </div>

        <hr>

        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
          <div>
            <h5 class="fw-bold mb-0">Bonus Rules</h5>
            <p class="text-muted small mb-0">Manage bonus calculation rules</p>
          </div>
          <a id="btnAddRule"
            href="#"
            onclick="goToAddRule()"
            class="btn btn-sm text-white"
            style="background:#9f7aea;">
            <i class="bi bi-plus-lg me-1"></i> Add Bonus Rule
          </a>
        </div>

        <div class="row px-2 mb-1">
          <div class="col-1 text-muted fw-bold" style="font-size:11px;">ID</div>
          <div class="col-3 text-muted fw-bold" style="font-size:11px;">Rule Name</div>
          <div class="col-2 text-muted fw-bold" style="font-size:11px;">Percentage</div>
          <div class="col-3 text-muted fw-bold" style="font-size:11px;">Conditions</div>
          <div class="col-3 text-muted fw-bold" style="font-size:11px;">Actions</div>
        </div>

        <div id="bonusRulesList">
          <div class="text-center text-muted py-3 small">
            Cliquez sur un salaire pour voir ses règles.
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{# ── Données JSON pour le JS ── #}
<script>
const bonusRulesMap = {{ bonusRulesMap | json_encode(constant('JSON_THROW_ON_ERROR')) | raw }};
const salaireUrls   = {{ salaireUrls   | json_encode(constant('JSON_THROW_ON_ERROR')) | raw }};

let activeRow = null;

function showDetails(row, id, name, base, bonus, total, date, status) {
  // 🔹 gérer sélection ligne
  if (activeRow) {
    activeRow.style.background = '';
    activeRow.classList.remove('active-row');
  }

  row.style.background = '#ebf4ff';
  row.classList.add('active-row');
  activeRow = row;

  // 🔹 afficher panel
  document.getElementById('rightPanel').style.display = '';

  // 🔹 afficher données
  document.getElementById('detailName').textContent  = name;
  document.getElementById('detailBase').textContent  = formatDT(base);
  document.getElementById('detailBonus').textContent = formatDT(bonus);
  document.getElementById('detailTotal').textContent = formatDT(total);
  document.getElementById('detailDate').textContent  = date;

  // 🔹 statut badge
  const badge = document.getElementById('detailStatus');
  badge.textContent = status;
  badge.className   = 'badge rounded-pill ' + getStatusClass(status);

  // 🔹 urls
  const urls = salaireUrls[id] || {};
  const isPaid = (status === 'PAYÉ');

  // ========================
  // 🔹 bouton EDIT
  // ========================
  const btnEdit = document.getElementById('btnEdit');
  btnEdit.href = urls.edit || '#';

  if (isPaid) {
    btnEdit.classList.add('disabled', 'btn-secondary');
    btnEdit.classList.remove('btn-primary');
    btnEdit.style.pointerEvents = 'none';
    btnEdit.style.opacity = '0.5';
  } else {
    btnEdit.classList.remove('disabled', 'btn-secondary');
    btnEdit.classList.add('btn-primary');
    btnEdit.style.pointerEvents = '';
    btnEdit.style.opacity = '';
  }

  // ========================
  // 🔹 bouton PDF
  // ========================
  document.getElementById('btnPdf').href = urls.show || '#';

  // ========================
  // 🔹 bouton DELETE
  // ========================
  const deleteForm = document.getElementById('deleteForm');
  const deleteBtn = deleteForm.querySelector('button');

  deleteForm.action = urls.delete || '#';
  document.getElementById('deleteToken').value = urls.deleteToken || '';

  deleteBtn.disabled = isPaid;

  if (isPaid) {
    deleteBtn.classList.add('btn-secondary');
    deleteBtn.classList.remove('btn-danger');
  } else {
    deleteBtn.classList.remove('btn-secondary');
    deleteBtn.classList.add('btn-danger');
  }

  // ========================
  // 🔥 bouton ADD BONUS RULE (corrigé)
  // ========================
  const btnAddRule = document.getElementById('btnAddRule');

  // 👉 lien dynamique avec salaireId
  btnAddRule.href = `/bonus-rule/new?salaireId=${id}`;

  // 👉 désactivation si payé
  if (isPaid) {
    btnAddRule.classList.add('disabled');
    btnAddRule.style.pointerEvents = 'none';
    btnAddRule.style.opacity = '0.5';
    btnAddRule.title = "Impossible d'ajouter (salaire payé)";
  } else {
    btnAddRule.classList.remove('disabled');
    btnAddRule.style.pointerEvents = '';
    btnAddRule.style.opacity = '';
    btnAddRule.title = "Ajouter une règle";
  }

  // ========================
  // 🔹 charger bonus rules
  // ========================
  loadBonusRules(id, status);
}

function loadBonusRules(salaireId, salaireStatus) {
  const container = document.getElementById('bonusRulesList');
  const rules = bonusRulesMap[salaireId] || [];

  if (rules.length === 0) {
    container.innerHTML = '<div class="text-center text-muted py-3 small">Aucune règle de bonus pour ce salaire.</div>';
    return;
  }

  container.innerHTML = rules.map(rule => {
    const isLocked = rule.status === 'ACTIVE' || salaireStatus === 'PAYÉ';

    const editBtn = isLocked
      ? `<button class="btn btn-sm btn-secondary" style="opacity:.5;font-size:11px;" disabled>Edit</button>`
      : `<a href="${rule.editUrl}" class="btn btn-sm btn-primary" style="font-size:11px;">Edit</a>`;

    const delBtn = isLocked
      ? `<button class="btn btn-sm btn-secondary" style="opacity:.5;font-size:11px;" disabled>Delete</button>`
      : `<form method="POST" action="${rule.deleteUrl}" style="display:inline" onsubmit="return confirm('Supprimer cette règle ?')">
           <input type="hidden" name="_token" value="${rule.deleteToken}">
           <button type="submit" class="btn btn-sm btn-danger" style="font-size:11px;">Delete</button>
         </form>`;

    return `
      <div class="row align-items-center px-2 py-2 mb-1 rounded border" style="background:white; font-size:13px;">
        <div class="col-1 fw-bold text-muted">${rule.id}</div>
        <div class="col-3">${rule.nomRegle}</div>
        <div class="col-2 fw-semibold text-success">${rule.percentage}%</div>
        <div class="col-3 text-muted small">${rule.conditionText ?? ''}</div>
        <div class="col-3 d-flex gap-1 align-items-center">${editBtn}${delBtn}</div>
      </div>`;
  }).join('');
}

function formatDT(amount) {
  return parseFloat(amount).toLocaleString('fr-TN', {
    minimumFractionDigits: 2, maximumFractionDigits: 2
  }) + ' DT';
}

function getStatusClass(status) {
  if (status === 'EN_COURS') return 'text-bg-info';
  if (status === 'PAYÉ') return 'text-bg-success';
  return 'text-bg-warning text-dark';
}

function goToAddRule() {
  if (!activeRow) {
    alert("Veuillez sélectionner un salaire");
    return;
  }

  const salaireId = activeRow.dataset.id;
  window.location.href = `/bonus-rule/new?salaireId=${salaireId}`;
}
</script>

{% endblock %}
