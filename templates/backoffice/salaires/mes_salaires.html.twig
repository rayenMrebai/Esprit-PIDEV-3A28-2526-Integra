{% extends 'admin/base_admin.html.twig' %}

{% block title %}Mes Salaires{% endblock %}
{% block page_title %}Mes Bulletins de Paie{% endblock %}
{% block breadcrumb %}Mes Salaires{% endblock %}

{% block admin_content %}

<style>
  .stat-card { background: white; border-radius: 12px; padding: 1.5rem; box-shadow: 0 2px 8px rgba(0,0,0,0.04); border-left: 4px solid var(--accent); }
  .salary-card { background: white; border-radius: 12px; border: 1px solid #e2e8f0; margin-bottom: 1rem; overflow: hidden; }
  .salary-header { background: #f8fafc; padding: 1rem 1.25rem; border-bottom: 1px solid #e2e8f0; display: flex; justify-content: space-between; align-items: center; }
  .status-badge { padding: 0.35rem 0.85rem; border-radius: 20px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
  .status-paye { background: rgba(40,167,69,0.1); color: #28a745; }
  .status-encours { background: rgba(23,162,184,0.1); color: #17a2b8; }
  .status-cree { background: rgba(255,193,7,0.1); color: #856404; }
</style>

<div class="row mb-4">
  <div class="col-md-3 mb-3">
    <div class="stat-card" style="--accent: #667eea;">
      <div class="text-muted text-uppercase small fw-bold mb-1">Total perçu</div>
      <div class="h4 mb-0 fw-bold">{{ totalPercu|number_format(0, ',', ' ') }} DT</div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="stat-card" style="--accent: #28a745;">
      <div class="text-muted text-uppercase small fw-bold mb-1">Total bonus</div>
      <div class="h4 mb-0 fw-bold">{{ totalBonus|number_format(0, ',', ' ') }} DT</div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="stat-card" style="--accent: #17a2b8;">
      <div class="text-muted text-uppercase small fw-bold mb-1">Salaire moyen</div>
      <div class="h4 mb-0 fw-bold">{{ moyenne|number_format(0, ',', ' ') }} DT</div>
    </div>
  </div>
  <div class="col-md-3 mb-3">
    <div class="stat-card" style="--accent: #ffc107;">
      <div class="text-muted text-uppercase small fw-bold mb-1">Bulletins payés</div>
      <div class="h4 mb-0 fw-bold">{{ nbPayes }}/{{ nbTotal }}</div>
    </div>
  </div>
</div>

{% for salaire in salaires %}
  {% set statusClass = salaire.status == 'PAYÉ' ? 'status-paye' : (salaire.status == 'EN_COURS' ? 'status-encours' : 'status-cree') %}
  
  <div class="salary-card">
    <div class="salary-header">
      <div class="d-flex align-items-center gap-2">
        <i class="far fa-calendar-alt text-primary"></i>
        <strong>
          {% if salaire.datePaiement %}
            {{ salaire.datePaiement|date('F Y') }}
          {% else %}
            Date non définie
          {% endif %}
        </strong>
      </div>
      <span class="status-badge {{ statusClass }}">{{ salaire.status }}</span>
    </div>
    
    <div class="p-4">
      <div class="row">
        <div class="col-md-4 mb-3">
          <div class="text-muted small mb-1">Salaire de base</div>
          <div class="fw-bold fs-5">{{ salaire.baseAmount|number_format(2, ',', ' ') }} DT</div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="text-muted small mb-1">Bonus</div>
          <div class="fw-bold fs-5 text-success">
            {% if salaire.bonusAmount > 0 %}+{% endif %}{{ salaire.bonusAmount|number_format(2, ',', ' ') }} DT
          </div>
        </div>
        <div class="col-md-4 mb-3">
          <div class="text-muted small mb-1">Total net</div>
          <div class="fw-bold fs-4 text-primary">{{ salaire.totalAmount|number_format(2, ',', ' ') }} DT</div>
        </div>
      </div>
      
      {% if bonusRulesMap[salaire.id] is defined and bonusRulesMap[salaire.id]|length > 0 %}
        <hr class="my-3">
        <div class="small text-muted mb-2">Règles de bonus appliquées :</div>
        <div class="d-flex gap-2 flex-wrap">
          {% for rule in bonusRulesMap[salaire.id] %}
            <span class="badge bg-light text-primary border">
              {{ rule.nomRegle }} ({{ rule.percentage }}%)
            </span>
          {% endfor %}
        </div>
      {% endif %}
      
      <div class="mt-3 text-end">
          <a href="{{ salaireUrls[salaire.id].pdf }}" 
            class="btn btn-outline-primary btn-sm"
            target="_blank">
              <i class="bi bi-file-earmark-pdf me-1"></i> Télécharger ma fiche PDF
          </a>
      </div>
    </div>
  </div>
{% else %}
  <div class="text-center text-muted py-5 bg-white rounded shadow-sm">
    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-25"></i>
    <p>Aucun bulletin de salaire disponible.</p>
  </div>
{% endfor %}

{% endblock %}