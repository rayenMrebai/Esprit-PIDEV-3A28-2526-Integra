{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block admin_content %}

  <div class="row mb-4">
    <div class="col-12">
      <div class="card">
        <div class="card-body d-flex align-items-center">
          <div class="me-4">
            <span class="fa-stack fa-2x text-white bg-primary rounded-circle p-3">
              <i class="fas fa-circle fa-stack-2x"></i>
              <i class="fas fa-user fa-stack-1x fa-inverse"></i>
            </span>
          </div>
          <div>
            <h4 class="mb-1">Admin</h4>
            <p class="mb-0">Profil administrateur par défaut</p>
            <p class="text-muted mb-0">Email: admin@example.com</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-4 col-6">
      <div class="small-box text-bg-primary">
        <div class="inner"><h3>0</h3><p>Compétences</p></div>
        <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/></svg>
        <a href="{{ path('app_skill_index') }}" class="small-box-footer link-light link-underline-opacity-0 link-underline-opacity-50-hover">
          Voir <i class="bi bi-arrow-right-circle"></i>
        </a>
      </div>
    </div>
    <div class="col-lg-4 col-6">
      <div class="small-box text-bg-success">
        <div class="inner"><h3>0</h3><p>Programmes de formation</p></div>
        <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/></svg>
        <a href="{{ path('app_training_program_index') }}" class="small-box-footer link-light link-underline-opacity-0 link-underline-opacity-50-hover">
          Voir <i class="bi bi-arrow-right-circle"></i>
        </a>
      </div>
    </div>
    <div class="col-lg-4 col-6">
      <div class="small-box text-bg-info">
        <div class="inner"><h3>0</h3><p>Quiz</p></div>
        <svg class="small-box-icon" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15h-2v-2h2v2zm0-4h-2V7h2v6zm6 4h-2v-4h2v4zm0-6h-2V7h2v4z"/></svg>
        <a href="{{ path('app_quiz_result_index') }}" class="small-box-footer link-light link-underline-opacity-0 link-underline-opacity-50-hover">
          Voir <i class="bi bi-arrow-right-circle"></i>
        </a>
      </div>
    </div>
  </div>

{% endblock %}
