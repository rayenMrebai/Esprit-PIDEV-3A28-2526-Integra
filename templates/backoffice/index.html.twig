{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}
{% block breadcrumb %}Dashboard{% endblock %}

{% block admin_content %}
<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Utilisateurs</h5>
                <p class="card-text display-6">{{ total_users|default(0) }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-success mb-3">
            <div class="card-body">
                <h5 class="card-title">Formations</h5>
                <p class="card-text display-6">{{ total_formations|default(0) }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Compétences</h5>
                <p class="card-text display-6">{{ total_competences|default(0) }}</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Quiz</h5>
                <p class="card-text display-6">{{ total_quiz|default(0) }}</p>
            </div>
        </div>
    </div>
</div>

<div class="row mt-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5>Derniers utilisateurs</h5></div>
            <div class="card-body">
                <table class="table table-sm">
                    <thead><tr><th>Nom</th><th>Email</th><th>Rôle</th></tr></thead>
                    <tbody>
                        {% for user in recent_users|default([]) %}
                            <tr>
                                <td>{{ user.username }}</td>
                                <td>{{ user.email }}</td>
                                <td>{{ user.role }}</td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3" class="text-center">Aucun utilisateur</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><h5>Actions rapides</h5></div>
            <div class="card-body d-grid gap-2">
                <a href="{{ path('app_backoffice_users') }}" class="btn btn-primary">Gérer les utilisateurs</a>
                <a href="{{ path('app_backoffice_formations') }}" class="btn btn-success">Gérer les formations</a>
                <a href="{{ path('app_backoffice_competences') }}" class="btn btn-info">Gérer les compétences</a>
                <a href="{{ path('app_backoffice_quiz') }}" class="btn btn-warning">Gérer les quiz</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}