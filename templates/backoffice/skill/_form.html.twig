{{ form_start(form, {'attr': {'class': 'form', 'novalidate': 'novalidate'}}) }}

    {# Erreurs globales du formulaire #}
    {% if form_errors(form) %}
        <div class="alert alert-danger">
            {{ form_errors(form) }}
        </div>
    {% endif %}

    <div class="mb-3">
        {{ form_label(form.nom, 'Nom de la compétence *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.nom, {'attr': {
            'class': form.nom.vars.errors|length > 0 ? 'form-control is-invalid' : 'form-control'
        }}) }}
        {% if form.nom.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {% for error in form.nom.vars.errors %}
                    <span>{{ error.message }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="mb-3">
        {{ form_label(form.description, 'Description *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.description, {'attr': {
            'class': form.description.vars.errors|length > 0 ? 'form-control is-invalid' : 'form-control',
            'rows': 4
        }}) }}
        {% if form.description.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {% for error in form.description.vars.errors %}
                    <span>{{ error.message }}</span>
                {% endfor %}
            </div>
        {% endif %}
        <small class="text-muted">Maximum 500 caractères.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.level_required, 'Niveau requis (1 à 5) *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.level_required, {'attr': {
            'class': form.level_required.vars.errors|length > 0 ? 'form-control is-invalid' : 'form-control'
        }}) }}
        {% if form.level_required.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {% for error in form.level_required.vars.errors %}
                    <span>{{ error.message }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="mb-3">
        {{ form_label(form.categorie, 'Catégorie *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.categorie, {'attr': {
            'class': form.categorie.vars.errors|length > 0 ? 'form-select is-invalid' : 'form-select'
        }}) }}
        {% if form.categorie.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {% for error in form.categorie.vars.errors %}
                    <span>{{ error.message }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <div class="mb-3">
        {{ form_label(form.trainingProgram, 'Programme de formation *', {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.trainingProgram, {'attr': {
            'class': form.trainingProgram.vars.errors|length > 0 ? 'form-select is-invalid' : 'form-select'
        }}) }}
        {% if form.trainingProgram.vars.errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {% for error in form.trainingProgram.vars.errors %}
                    <span>{{ error.message }}</span>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    {{ form_rest(form) }}

    <div class="mt-3">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg"></i> Enregistrer
        </button>
        <a href="{{ path('app_backoffice_competences') }}" class="btn btn-secondary">
            <i class="bi bi-x-lg"></i> Annuler
        </a>
    </div>

{{ form_end(form) }}