{% extends 'backoffice/base_backoffice.html.twig' %}

{% block page_title %}Modifier mon profil{% endblock %}
{% block breadcrumb %}Mon Profil / Modifier{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header">
        <h3>Modifier mon profil</h3>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
        {{ form_row(form.email) }}
        {{ form_row(form.username) }}
        <button type="submit" class="btn btn-primary">Enregistrer</button>
        <a href="{{ path('app_backoffice_profile') }}" class="btn btn-secondary">Annuler</a>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}