{# templates/backoffice/partials/_navbar.html.twig #}

{# ── Lecture des données utilisateur depuis la session fake ── #}
{% set fake_name  = app.session.get('fake_user_name')  ?? 'Administrateur' %}
{% set fake_email = app.session.get('fake_user_email') ?? '' %}
{% set fake_role  = app.session.get('fake_user_role')  ?? '' %}

<nav class="app-header navbar navbar-expand bg-body">
  <div class="container-fluid">

    {# Bouton toggle sidebar #}
    <ul class="navbar-nav">
      <li class="nav-item">
        <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
          <i class="bi bi-list"></i>
        </a>
      </li>
    </ul>

    {# Droite : nom + rôle + logout #}
    <ul class="navbar-nav ms-auto align-items-center">

      {# Nom + rôle #}
      <li class="nav-item d-flex align-items-center me-3">
        <i class="bi bi-person-circle me-2 fs-5 text-secondary"></i>
        <div class="lh-1">
          <div class="fw-semibold" style="font-size: 0.88rem;">{{ fake_name }}</div>
          <div class="text-muted" style="font-size: 0.72rem;">
            {% if fake_role == 'ADMINISTRATEUR' %}Administrateur
            {% elseif fake_role == 'MANAGER' %}Manager
            {% elseif fake_role == 'EMPLOYE' %}Employé
            {% else %}Utilisateur{% endif %}
          </div>
        </div>
      </li>

      {# Séparateur #}
      <li class="nav-item me-2">
        <div style="width:1px; height:28px; background:rgba(0,0,0,0.12);"></div>
      </li>

      {# Bouton Déconnexion #}
      <li class="nav-item">
        <a href="{{ path('fake_logout') }}" class="nav-link text-danger d-flex align-items-center gap-1">
          <i class="bi bi-box-arrow-right fs-5"></i>
          <span class="d-none d-md-inline" style="font-size: 0.85rem;">Déconnexion</span>
        </a>
      </li>

    </ul>
  </div>
</nav>
