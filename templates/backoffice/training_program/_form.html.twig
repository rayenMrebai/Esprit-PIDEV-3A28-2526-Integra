{{ form_start(form, {'attr': {'id': 'training-form', 'class': 'ajax-form'}})}}

    {{ form_errors(form) }}

    <div class="mb-3">
        {{ form_label(form.title, 'Titre', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.title, {'attr': {'class': 'form-control'}})}}
        {{ form_errors(form.title) }}
        <small class="text-muted">Minimum 3 caractères, maximum 150.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4}})}}
        {{ form_errors(form.description) }}
        <small class="text-muted">Maximum 1000 caractères.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.duration, 'Durée (heures)', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.duration, {'attr': {'class': 'form-control'}})}}
        {{ form_errors(form.duration) }}
        <small class="text-muted">Doit être un nombre positif.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.type, 'Type', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.type, {'attr': {'class': 'form-select'}})}}
        {{ form_errors(form.type) }}
        <small class="text-muted">Sélectionnez le type de formation.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.startDate, 'Date de début', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.startDate, {'attr': {'class': 'form-control'}})}}
        {{ form_errors(form.startDate) }}
        <small class="text-muted">Doit être antérieure à la date de fin.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.endDate, 'Date de fin', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.endDate, {'attr': {'class': 'form-control'}})}}
        {{ form_errors(form.endDate) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.status, 'Statut', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.status, {'attr': {'class': 'form-select'}})}}
        {{ form_errors(form.status) }}
        <small class="text-muted">Sélectionnez le statut du programme.</small>
    </div>

    <div class="mb-3">
        {{ form_label(form.skills, 'Compétences associées', {'label_attr': {'class': 'form-label'}})}}
        {{ form_widget(form.skills, {'attr': {'class': 'form-select'}})}}
        {{ form_errors(form.skills) }}
        <small class="text-muted">Sélectionnez au moins une compétence (Ctrl+clic pour plusieurs).</small>
    </div>

    {{ form_rest(form) }}
{{ form_end(form) }}