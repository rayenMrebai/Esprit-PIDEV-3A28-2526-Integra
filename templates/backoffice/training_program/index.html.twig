{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Programmes de formation{% endblock %}
{% block page_title %}Programmes de formation{% endblock %}
{% block breadcrumb %}Dashboard / Programmes{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header">
        <div class="d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Liste des programmes</h4>
            <a href="{{ path('app_training_program_new') }}" class="btn btn-success">Ajouter un programme</a>
        </div>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-bordered">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Durée</th>
                        <th>Type</th>
                        <th>Date début</th>
                        <th>Date fin</th>
                        <th>Statut</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for training_program in training_programs %}
                    <tr>
                        <td>{{ training_program.id }}</td>
                        <td>{{ training_program.title }}</td>
                        <td>{{ training_program.description|length > 100 ? training_program.description|slice(0, 100) ~ '...' : training_program.description }}</td>
                        <td>{{ training_program.duration }}</td>
                        <td>{{ training_program.type }}</td>
                        <td>{{ training_program.startDate ? training_program.startDate|date('Y-m-d') : '' }}</td>
                        <td>{{ training_program.endDate ? training_program.endDate|date('Y-m-d') : '' }}</td>
                        <td>{{ training_program.status }}</td>
                        <td>
                            <a href="{{ path('app_training_program_show', {'id': training_program.id}) }}" class="btn btn-info btn-sm">Voir</a>
                            <a href="{{ path('app_training_program_edit', {'id': training_program.id}) }}" class="btn btn-warning btn-sm">Éditer</a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="9" class="text-center">Aucun programme trouvé.</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}