{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Modifier Programme de Formation{% endblock %}
{% block page_title %}Modifier le Programme de Formation{% endblock %}
{% block breadcrumb %}Dashboard / Formations / Modifier{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Modifier {{ training_program.title }}</h3>
        </div>
        <div class="card-body">
            {{ include('training_program/_form.html.twig') }}
        </div>
        <div class="card-footer">
            <a href="{{ path('app_training_program_index') }}" class="btn btn-secondary">Retour à la liste</a>
            {{ include('training_program/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}