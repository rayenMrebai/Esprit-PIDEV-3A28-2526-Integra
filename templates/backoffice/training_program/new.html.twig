{% extends 'backoffice/base_backoffice.html.twig' %}

{% block page_title %}Ajouter une formation{% endblock %}
{% block breadcrumb %}Formations / Ajouter{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Nouveau programme de formation</h3>
    </div>
    <div class="card-body">
        {{ include('backoffice/training_program/_form.html.twig', {'form': form}) }}
    </div>
    <div class="card-footer">
        <a href="{{ path('app_backoffice_formations') }}" class="btn btn-secondary">Retour à la liste</a>
    </div>
</div>
{% endblock %}