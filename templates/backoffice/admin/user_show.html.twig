{% extends 'admin/base_admin.html.twig' %}

{% block page_title %}User Details{% endblock %}
{% block breadcrumb %}View User{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ user.email }}</h3>
            <div class="card-tools">
                <a href="{{ path('admin_user_list') }}" class="btn btn-secondary btn-sm">Back to list</a>
            </div>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tr><th>ID</th><td>{{ user.userId }}</td></tr>
                <tr><th>Email</th><td>{{ user.email }}</td></tr>
                <tr><th>Username</th><td>{{ user.username }}</td></tr>
                <tr><th>Active</th><td>{{ user.isActive ? 'Yes' : 'No' }}</td></tr>
                <tr><th>Role</th><td>{{ user.role }}</td></tr>
                <tr><th>Account Created</th><td>{{ user.accountCreatedDate|date('Y-m-d H:i') }}</td></tr>
                <tr><th>Status</th><td>{{ user.accountStatus }}</td></tr>
                {% if user.faceImagePath %}
                    <tr><th>Photo</th><td><img src="{{ asset(user.faceImagePath) }}" width="100"></td></tr>
                {% endif %}
            </table>
        </div>
    </div>
{% endblock %}