{% extends 'backoffice/base_backoffice.html.twig' %}

{% block page_title %}Modifier l'utilisateur{% endblock %}
{% block breadcrumb %}Utilisateurs / Modifier{% endblock %}

{% block admin_content %}
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Modifier l'utilisateur #{{ user.userId }}</h3>
    </div>
    <div class="card-body">
        {{ form_start(form) }}
        
        <div class="row">
            <div class="col-md-6">
                {{ form_row(form.email) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.username) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.role) }}
            </div>
            <div class="col-md-6">
                {{ form_row(form.isActive) }}
            </div>
            <div class="col-md-12">
                {{ form_row(form.skills) }}
            </div>
        </div>
        
        <button type="submit" class="btn btn-success">Enregistrer</button>
        <a href="{{ path('app_backoffice_users') }}" class="btn btn-secondary">Annuler</a>
        
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<script>
    $(document).ready(function() {
        $('.select2-multi').select2({
            theme: 'bootstrap-5',
            placeholder: 'Sélectionnez les compétences...',
            allowClear: true
        });
    });
</script>
{% endblock %}