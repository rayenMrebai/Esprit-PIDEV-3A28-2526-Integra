{% extends 'backoffice/base_backoffice.html.twig' %}

{% block page_title %}Gestion des utilisateurs{% endblock %}
{% block breadcrumb %}Utilisateurs{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Liste des utilisateurs</h3>
            <div class="card-tools">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('app_backoffice_users_new') }}" class="btn btn-primary btn-sm">
                        <i class="fas fa-user-plus"></i> Ajouter un utilisateur
                    </a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <form method="get" class="mb-3">
                <div class="row">
                    <div class="col-md-4">
                        <input type="text" name="search" class="form-control" placeholder="Rechercher par email ou nom" value="{{ search }}">
                    </div>
                    <div class="col-md-3">
                        <select name="role" class="form-control">
                            <option value="">Tous les rôles</option>
                            <option value="EMPLOYE" {% if selectedRole == 'EMPLOYE' %}selected{% endif %}>Employé</option>
                            <option value="MANAGER" {% if selectedRole == 'MANAGER' %}selected{% endif %}>Manager</option>
                            <option value="ADMINISTRATEUR" {% if selectedRole == 'ADMINISTRATEUR' %}selected{% endif %}>Administrateur</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button class="btn btn-primary" type="submit">Filtrer</button>
                        {% if search or selectedRole %}
                            <a href="{{ path('app_backoffice_users') }}" class="btn btn-secondary">Effacer</a>
                        {% endif %}
                    </div>
                </div>
            </form>

            <table class="table table-bordered table-striped">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Email</th>
                    <th>Nom d'utilisateur</th>
                    <th>Actif</th>
                    <th>Rôle</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.userId }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.username }}</td>
                        <td>{{ user.isActive ? '<span class="badge bg-success">Oui</span>'|raw : '<span class="badge bg-danger">Non</span>'|raw }}</td>
                        <td>{{ user.role }}</td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('app_backoffice_users_show', {id: user.userId}) }}" class="btn btn-sm btn-info">Voir</a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <a href="{{ path('app_backoffice_users_edit', {id: user.userId}) }}" class="btn btn-sm btn-warning">Modifier</a>
                                {% endif %}
                                <a href="{{ path('app_backoffice_users_toggle', {id: user.userId}) }}" class="btn btn-sm btn-secondary">Activer/Désactiver</a>
                                {% if is_granted('ROLE_ADMIN') %}
                                    <form action="{{ path('app_backoffice_users_delete', {id: user.userId}) }}" method="post" style="display:inline-block" onsubmit="return confirm('Supprimer cet utilisateur ?')">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.userId) }}">
                                        <button class="btn btn-sm btn-danger">Supprimer</button>
                                    </form>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center">Aucun utilisateur trouvé.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}