<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>INTEGRA RH – {% block title %}Accueil{% endblock %}</title>

    <!-- Bootstrap core CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom fonts -->
    <link href="https://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300italic,400italic,600italic,700italic,800italic,400,300,600,700,800" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Custom styles -->
    <link href="{{ asset('front/css/styles.css') }}" rel="stylesheet">

    <style>
        .btn-admin {
            border-radius: 40px;
            padding: 6px 16px;
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            background: rgba(11, 99, 206, 0.7);
            backdrop-filter: blur(5px);
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .btn-admin:hover {
            background: rgba(11, 99, 206, 0.9);
            border-color: white;
            color: white;
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNav">
    <div class="container">
        {# LOGO : accueil public si non connecté, dashboard employé si connecté #}
        {% if app.user %}
            <a class="navbar-brand" href="{{ path('front_home') }}">INTEGRA RH</a>
        {% else %}
            <a class="navbar-brand" href="{{ path('front_acceuil') }}">INTEGRA RH</a>
        {% endif %}

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive">
            Menu <i class="fas fa-bars"></i>
        </button>

        <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ms-auto">

                {# ACCUEIL : public si non connecté, dashboard si connecté #}
                <li class="nav-item">
                    {% if app.user %}
                        <a class="nav-link" href="{{ path('front_home') }}">Accueil</a>
                    {% else %}
                        <a class="nav-link" href="{{ path('front_acceuil') }}">Accueil</a>
                    {% endif %}
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('front_home') }}#offres">Offres</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="#">Contact</a>
                </li>

                {# BOUTON LOGIN (visible si NON connecté) #}
                {% if not app.user %}
                    <li class="nav-item ms-2">
                        <a href="{{ path('app_login') }}" class="btn btn-admin">
                            <i class="fas fa-sign-in-alt me-1"></i> Login
                        </a>
                    </li>
                {% endif %}

                {# BOUTON LOGOUT (visible si CONNECTÉ) #}
                {% if app.user %}
                    <li class="nav-item ms-2">
                        <a href="{{ path('app_logout') }}" class="btn btn-danger rounded-pill"
                           onclick="return confirm('Voulez-vous vous déconnecter ?');">
                            <i class="fas fa-sign-out-alt me-1"></i> Logout
                        </a>
                    </li>
                {% endif %}

            </ul>
        </div>
    </div>
</nav>

<!-- HEADER -->
<header class="masthead" style="background-image: url('{{ asset('front/img/integralogo.jpg') }}')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
                <div class="site-heading">
                    <h1>{% block header_title %}INTEGRA RH{% endblock %}</h1>
                    <span class="subheading">
                        {% block header_subtitle %}Gestion des ressources humaines{% endblock %}
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- CONTENT -->
<main class="container px-4 px-lg-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-7">
            {% block content %}{% endblock %}
        </div>
    </div>
</main>

<!-- FOOTER -->
<footer class="border-top">
    <div class="container px-4 px-lg-5 text-center">
        <ul class="list-inline">
            <li class="list-inline-item">
                <a href="#"><i class="fab fa-twitter fa-lg"></i></a>
            </li>
            <li class="list-inline-item">
                <a href="#"><i class="fab fa-facebook fa-lg"></i></a>
            </li>
            <li class="list-inline-item">
                <a href="#"><i class="fab fa-github fa-lg"></i></a>
            </li>
        </ul>
        <p class="small text-muted">© INTEGRA RH 2025</p>
    </div>
</footer>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('front/js/scripts.js') }}"></script>

{% block javascripts %}{% endblock %}

</body>
</html>