<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>INTEGRA RH – {% block title %}Accueil{% endblock %}</title>

    <!-- Bootstrap core CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom fonts -->
    <link href="https://fonts.googleapis.com/css?family=Lora:400,700,400italic,700italic" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300italic,400italic,600italic,700italic,800italic,400,300,600,700,800" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

    <!-- Custom styles -->
    <link href="{{ asset('front/css/styles.css') }}" rel="stylesheet">

    <style>
        .btn-admin {
            border-radius: 40px;
            padding: 6px 16px;
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            background: rgba(11, 99, 206, 0.7);
            backdrop-filter: blur(5px);
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .btn-admin:hover {
            background: rgba(11, 99, 206, 0.9);
            border-color: white;
            color: white;
        }
        .btn-admin i {
            transition: transform 0.2s ease;
        }
        .btn-admin:hover i.fa-arrow-right {
            transform: translateX(3px);
        }
        .btn-admin:hover i.fa-lock {
            transform: scale(1.1);
        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>
<body>

<!-- Navigation -->
<nav class="navbar navbar-expand-lg navbar-light fixed-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand" href="{{ path('front_home') }}">INTEGRA RH</a>
        <button class="navbar-toggler navbar-toggler-right" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive" aria-controls="navbarResponsive" aria-expanded="false" aria-label="Toggle navigation">
            Menu
            <i class="fas fa-bars"></i>
        </button>
        <div class="collapse navbar-collapse" id="navbarResponsive">
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('front_home') }}">Accueil</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('front_home') }}#offres">Offres</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#">Contact</a>
                </li>

                {% if not app.user %}
                    <li class="nav-item ms-2">
                        <a href="{{ path('app_login') }}" class="btn-admin d-flex align-items-center gap-2 text-decoration-none">
                            <i class="fas fa-sign-in-alt"></i>
                            <span>Login</span>
                        </a>
                    </li>
                {% endif %}

                {% if app.user %}
                    <li class="nav-item ms-2">
                        <a href="{{ path('app_logout') }}" class="btn-admin d-flex align-items-center gap-2 text-decoration-none"
                           onclick="return confirm('Voulez-vous vous déconnecter ?');">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Logout</span>
                        </a>
                    </li>
                {% endif %}

                <!-- ========== BOUTON ESPACE ADMIN (corrigé) ========== -->
                <li class="nav-item ms-3 d-flex align-items-center">
                    <a href="{{ path('app_backoffice_dashboard') }}" class="btn-admin d-flex align-items-center gap-2 text-decoration-none">
                        <i class="fas fa-lock" style="font-size: 12px;"></i>
                        <span>Espace Admin</span>
                        <i class="fas fa-arrow-right" style="font-size: 12px;"></i>
                    </a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<!-- Page Header -->
<header class="masthead" style="background-image: url('{{ asset('front/img/integralogo.jpg') }}')">
    <div class="container position-relative px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
                <div class="site-heading">
                    <h1>{% block header_title %}INTEGRA RH{% endblock %}</h1>
                    <span class="subheading">
                        {% block header_subtitle %}Gestion des ressources humaines{% endblock %}
                    </span>
                </div>
            </div>
        </div>
    </div>
</header>

<!-- Main Content -->
<div class="container px-4 px-lg-5">
    <div class="row gx-4 gx-lg-5 justify-content-center">
        <div class="col-md-10 col-lg-8 col-xl-7">
            {% block content %}{% endblock %}
        </div>
    </div>
</div>

<!-- Footer -->
<footer class="border-top">
    <div class="container px-4 px-lg-5">
        <div class="row gx-4 gx-lg-5 justify-content-center">
            <div class="col-md-10 col-lg-8 col-xl-7">
                <ul class="list-inline text-center">
                    <li class="list-inline-item">
                        <a href="#">
                            <span class="fa-stack fa-lg">
                                <i class="fas fa-circle fa-stack-2x"></i>
                                <i class="fab fa-twitter fa-stack-1x fa-inverse"></i>
                            </span>
                        </a>
                    </li>
                    <li class="list-inline-item">
                        <a href="#">
                            <span class="fa-stack fa-lg">
                                <i class="fas fa-circle fa-stack-2x"></i>
                                <i class="fab fa-facebook-f fa-stack-1x fa-inverse"></i>
                            </span>
                        </a>
                    </li>
                    <li class="list-inline-item">
                        <a href="#">
                            <span class="fa-stack fa-lg">
                                <i class="fas fa-circle fa-stack-2x"></i>
                                <i class="fab fa-github fa-stack-1x fa-inverse"></i>
                            </span>
                        </a>
                    </li>
                </ul>
                <div class="small text-center text-muted fst-italic">Copyright &copy; INTEGRA RH 2026</div>
            </div>
        </div>
    </div>
</footer>

<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ asset('front/js/scripts.js') }}"></script>
{% block javascripts %}{% endblock %}
</body>
</html>