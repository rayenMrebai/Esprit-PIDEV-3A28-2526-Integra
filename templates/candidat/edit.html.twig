{% extends 'base.html.twig' %}

{% block title %}Modifier un candidat{% endblock %}

{% block body %}
    <div class="dashboard-container">
        <!-- HEADER identique -->
        <div class="main-header">
            <div class="logo-area">
                <div class="logo-icon">IN</div>
                <div class="logo-text">
                    <h1>INTEGRA RECRUITMENT</h1>
                    <p>Gestion des recrutements</p>
                </div>
            </div>
            <div>
                <div class="user-info">
                    <strong>Admin User</strong><br>
                    <span>Administrateur</span>
                </div>
            </div>
        </div>

        <!-- Carte d'édition -->
        <div class="card-modern" style="max-width: 800px; margin: 30px auto;">
            <div class="section-header">
                <div class="section-title">
                    <i class="fas fa-edit"></i> Modifier le candidat
                </div>
                <a href="{{ path('app_recruitment_dashboard') }}" class="btn btn-outline">
                    <i class="fas fa-arrow-left"></i> Retour au tableau
                </a>
            </div>

            {{ form_start(form, {'attr': {'class': 'form-grid'}}) }}
            <div class="form-group">{{ form_row(form.firstName, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.lastName, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.email, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.phone, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.educationLevel, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group">{{ form_row(form.status, {'attr': {'class': 'form-control'}}) }}</div>
            <div class="form-group full">{{ form_row(form.skills, {'attr': {'class': 'form-control', 'rows': 3}}) }}</div>
            <div class="form-group full">{{ form_row(form.jobposition, {'attr': {'class': 'form-control'}}) }}</div>

            <div class="modal-footer" style="grid-column: span 2; padding: 0; margin-top: 20px; display: flex; justify-content: space-between;">
                <a href="{{ path('app_recruitment_dashboard') }}" class="btn btn-outline">Annuler</a>
                <button type="submit" class="btn btn-success">Mettre à jour</button>
            </div>
            {{ form_end(form) }}

            <!-- Suppression -->
            <hr style="margin: 30px 0 20px; border-color: var(--gray-200);">
            <div style="text-align: center;">
                <form method="post" action="{{ path('app_candidat_delete', {'id': candidat.id}) }}" onsubmit="return confirm('Supprimer définitivement ce candidat ?');" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidat.id) }}">
                    <button class="btn btn-danger">🗑 Supprimer le candidat</button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}