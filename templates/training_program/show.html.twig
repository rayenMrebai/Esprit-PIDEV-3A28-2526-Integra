{% extends 'backoffice/base_backoffice.html.twig' %}

{% block title %}Programme de Formation{% endblock %}
{% block page_title %}Détails du Programme de Formation{% endblock %}
{% block breadcrumb %}Dashboard / Formations / Détails{% endblock %}

{% block admin_content %}
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">{{ training_program.title }}</h3>
            <div class="card-tools">
                <a href="{{ path('app_training_program_edit', {'id': training_program.id}) }}" class="btn btn-warning btn-sm">
                    <i class="fas fa-edit"></i> Modifier
                </a>
                {{ include('training_program/_delete_form.html.twig') }}
            </div>
        </div>
        <div class="card-body">
            <table class="table table-bordered">
                <tbody>
                    <tr>
                        <th>Id</th>
                        <td>{{ training_program.id }}</td>
                    </tr>
                    <tr>
                        <th>Title</th>
                        <td>{{ training_program.title }}</td>
                    </tr>
                    <tr>
                        <th>Description</th>
                        <td>{{ training_program.description }}</td>
                    </tr>
                    <tr>
                        <th>Duration</th>
                        <td>{{ training_program.duration }}</td>
                    </tr>
                    <tr>
                        <th>Type</th>
                        <td>{{ training_program.type }}</td>
                    </tr>
                    <tr>
                        <th>Start_date</th>
                        <td>{{ training_program.start_date ? training_program.start_date|date('Y-m-d') : '' }}</td>
                    </tr>
                    <tr>
                        <th>End_date</th>
                        <td>{{ training_program.end_date ? training_program.end_date|date('Y-m-d') : '' }}</td>
                    </tr>
                    <tr>
                        <th>Status</th>
                        <td>{{ training_program.status }}</td>
                    </tr>
                </tbody>
            </table>
        </div>
        <div class="card-footer">
            <a href="{{ path('app_training_program_index') }}" class="btn btn-secondary">Retour à la liste</a>
        </div>
    </div>
{% endblock %}