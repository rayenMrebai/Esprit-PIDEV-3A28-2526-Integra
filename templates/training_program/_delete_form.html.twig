<form method="post" action="{{ path('app_training_program_delete', {'id': training_program.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet élément ?');" style="display: inline;">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ training_program.id) }}">
    <button class="btn btn-danger btn-sm">
        <i class="fas fa-trash"></i> Supprimer
    </button>
</form>