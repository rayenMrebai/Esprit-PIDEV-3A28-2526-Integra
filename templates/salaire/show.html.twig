{% extends 'base.html.twig' %}

{% block title %}Salaire{% endblock %}

{% block body %}
    <h1>Salaire</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ salaire.id }}</td>
            </tr>
            <tr>
                <th>BaseAmount</th>
                <td>{{ salaire.baseAmount }}</td>
            </tr>
            <tr>
                <th>BonusAmount</th>
                <td>{{ salaire.bonusAmount }}</td>
            </tr>
            <tr>
                <th>TotalAmount</th>
                <td>{{ salaire.totalAmount }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ salaire.status }}</td>
            </tr>
            <tr>
                <th>DatePaiement</th>
                <td>{{ salaire.datePaiement ? salaire.datePaiement|date('Y-m-d') : '' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ salaire.createdAt ? salaire.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>UpdatedAt</th>
                <td>{{ salaire.updatedAt ? salaire.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_salaire_index') }}">back to list</a>

    <a href="{{ path('app_salaire_edit', {'id': salaire.id}) }}">edit</a>

    {{ include('salaire/_delete_form.html.twig') }}
{% endblock %}
