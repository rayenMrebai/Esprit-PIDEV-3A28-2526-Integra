<!DOCTYPE html>
<html>
<head>
    <title>Détail Salaire</title>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        table { border-collapse: collapse; width: 500px; }
        th, td { border: 1px solid #ddd; padding: 10px; text-align: left; }
        th { background-color: #4CAF50; color: white; width: 200px; }
        .btn { padding: 6px 12px; text-decoration: none; border-radius: 4px; color: white; }
        .btn-grey { background-color: #6c757d; }
    </style>
</head>
<body>
    <h1>👁 Détail du Salaire #{{ salaire.id }}</h1>

    <table>
        <tr><th>Employé</th><td>{{ salaire.user.username }}</td></tr>
        <tr><th>Email</th><td>{{ salaire.user.email }}</td></tr>
        <tr><th>Salaire de base</th><td>{{ salaire.baseAmount }} DT</td></tr>
        <tr><th>Bonus</th><td>{{ salaire.bonusAmount ?? 0 }} DT</td></tr>
        <tr><th>Total</th><td>{{ salaire.totalAmount }} DT</td></tr>
        <tr><th>Statut</th><td>{{ salaire.status }}</td></tr>
        <tr><th>Date Paiement</th><td>{{ salaire.datePaiement ? salaire.datePaiement|date('d/m/Y') : '-' }}</td></tr>
        <tr><th>Créé le</th><td>{{ salaire.createdAt|date('d/m/Y H:i') }}</td></tr>
    </table>

    <br>
    <a href="{{ path('salaire_index') }}" class="btn btn-grey">⬅ Retour</a>
</body>
</html>