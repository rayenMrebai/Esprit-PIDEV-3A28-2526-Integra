{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dashboard Recrutement{% endblock %}
{% block page_title %}Recrutement{% endblock %}
{% block breadcrumb %}Recrutement{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/integra.css') }}">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
{% endblock %}

{% block admin_content %}
    {# Flashes #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success">{{ message }}</div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    {# SECTION OFFRES #}
    <div class="card-modern">
        <div class="section-header">
            <div class="section-title"><i class="fas fa-briefcase"></i> OFFRES D'EMPLOI</div>
            <div class="actions-bar">
                <form method="get" action="{{ path('app_recruitment_dashboard') }}" style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                    <input type="text" name="search_job" value="{{ searchJob|default('') }}" placeholder="🔍 Rechercher par titre..." class="form-control" style="width: 200px;">
                    <button type="submit" class="btn btn-primary">Rechercher</button>
                    <div class="btn-group" style="display: flex; gap: 5px;">
                        {% set currentParams = app.request.query.all %}
                        <a href="{{ path('app_recruitment_dashboard', currentParams|merge({'sort_jobs': 'date_desc'})) }}" class="btn {{ sortJobs|default('date_desc') == 'date_desc' ? 'btn-primary' : 'btn-outline' }}" style="font-size: 12px;"><i class="fas fa-calendar-alt"></i> Récent</a>
                        <a href="{{ path('app_recruitment_dashboard', currentParams|merge({'sort_jobs': 'date_asc'})) }}" class="btn {{ sortJobs|default('date_desc') == 'date_asc' ? 'btn-primary' : 'btn-outline' }}" style="font-size: 12px;"><i class="fas fa-calendar-alt"></i> Ancien</a>
                    </div>
                    {% if searchJob %}
                        <a href="{{ path('app_recruitment_dashboard', {'sort_jobs': sortJobs|default('date_desc')}) }}" class="btn btn-outline">Réinitialiser</a>
                    {% endif %}
                </form>
                <button class="btn btn-primary" id="openJobModalBtn"><i class="fas fa-plus"></i> Nouvelle offre</button>
            </div>
        </div>
        <div id="jobsList">
            {% if jobs is empty %}
                <p>Aucune offre trouvée pour "{{ searchJob }}"</p>
            {% else %}
                {% for job in jobs %}
                    <div class="job-card {{ job.status|lower == 'closed' ? 'closed' : '' }} {% if selectedJob is defined and selectedJob and selectedJob.idJob == job.idJob %}selected-job{% endif %}" data-job-id="{{ job.idJob }}" style="cursor: pointer; transition: all 0.2s;">
                        <div class="job-accent"></div>
                        <div class="job-card-content">
                            <div class="job-icon-id"><span>💼</span><br><span class="job-id">#{{ job.idJob }}</span></div>
                            <div class="job-title">{{ job.title }}</div>
                            <div class="job-department"><label>DÉPARTEMENT</label><div>{{ job.departement }}</div></div>
                            <div class="job-type"><label>TYPE</label><div>{{ job.employeeType }}</div></div>
                            <div class="job-date"><label>PUBLIÉ LE</label><div>{{ job.postedAt ? job.postedAt|date('Y-m-d') : '' }}</div></div>
                            <div class="job-stats">
                                <span class="candidate-badge"><i class="fas fa-users"></i> {{ job.candidats|length }} candidat(s)</span>
                                <span class="status-badge {{ job.status|lower == 'open' ? 'open' : 'closed' }}">{{ job.status }}</span>
                            </div>
                        </div>
                        <div style="display: flex; gap: 5px; margin-right: 16px;">
                            <a href="{{ path('app_jobposition_edit', {'idJob': job.idJob}) }}" class="btn btn-warning btn-sm" onclick="event.stopPropagation();"><i class="fas fa-edit"></i></a>
                            <form method="post" action="{{ path('app_jobposition_delete', {'idJob': job.idJob}) }}" onsubmit="return confirm('Supprimer cette offre ?');" style="display: inline;" onclick="event.stopPropagation();">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ job.idJob) }}">
                                <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>

    {# SECTION CANDIDATS #}
    <div class="card-modern">
        <div class="section-header">
            <div class="section-title">
                <i class="fas fa-users"></i> CANDIDATS
                {% if selectedJob is defined and selectedJob %}
                    <span style="font-size: 14px; background: var(--primary); color: white; padding: 2px 10px; border-radius: 20px; margin-left: 12px;">{{ selectedJob.title }}</span>
                {% endif %}
            </div>
            <div class="actions-bar">
                <form method="get" action="{{ path('app_recruitment_dashboard') }}" style="display: flex; gap: 8px; align-items: center; flex-wrap: wrap;">
                    {% if selectedJob is defined and selectedJob %}<input type="hidden" name="job" value="{{ selectedJob.idJob }}">{% endif %}
                    <input type="text" name="search_candidat" value="{{ searchCandidat|default('') }}" placeholder="🔍 Nom, prénom ou email..." class="form-control" style="width: 220px;">
                    <button type="submit" class="btn btn-primary">Rechercher</button>
                    <div class="btn-group" style="display: flex; gap: 5px;">
                        {% set currentParams = app.request.query.all %}
                        <a href="{{ path('app_recruitment_dashboard', currentParams|merge({'sort_candidats': 'name_asc'})) }}" class="btn {{ sortCandidats|default('name_asc') == 'name_asc' ? 'btn-primary' : 'btn-outline' }}" style="font-size: 12px;"><i class="fas fa-sort-alpha-down"></i> A→Z</a>
                        <a href="{{ path('app_recruitment_dashboard', currentParams|merge({'sort_candidats': 'name_desc'})) }}" class="btn {{ sortCandidats|default('name_asc') == 'name_desc' ? 'btn-primary' : 'btn-outline' }}" style="font-size: 12px;"><i class="fas fa-sort-alpha-up"></i> Z→A</a>
                    </div>
                    {% if searchCandidat %}
                        <a href="{{ path('app_recruitment_dashboard', (selectedJob is defined and selectedJob) ? {'job': selectedJob.idJob, 'sort_candidats': sortCandidats|default('name_asc')} : {'sort_candidats': sortCandidats|default('name_asc')}) }}" class="btn btn-outline">Réinitialiser</a>
                    {% endif %}
                </form>
                <button class="btn btn-success" id="openCandidatModalBtn"><i class="fas fa-plus"></i> Ajouter</button>
                <a href="{{ path('app_cv_analyze') }}" class="btn btn-purple"><i class="fas fa-brain"></i> Upload CV</a>
            </div>
        </div>

        {% if selectedJob is defined and selectedJob %}
            <p style="margin-bottom: 12px; color: var(--gray-600);">
                <i class="fas fa-info-circle"></i> Affichage des candidats pour <strong>{{ selectedJob.title }}</strong>
                ({{ candidats|length }} résultat{{ candidats|length > 1 ? 's' : '' }})
            </p>
        {% endif %}

        <div style="overflow-x: auto;">
            <table class="data-table">
                <thead>
                <tr><th>ID</th><th>Nom complet</th><th>Email</th><th>Niveau</th><th>Statut</th><th>Actions</th></tr>
                </thead>
                <tbody>
                {% for candidat in candidats %}
                    <tr>
                        <td>{{ candidat.id }}</td>
                        <td>{{ candidat.firstName }} {{ candidat.lastName }}</td>
                        <td>{{ candidat.email }}</td>
                        <td>{{ candidat.educationLevel }}</td>
                        <td>
                            {% if candidat.status == 'Rejeté' %}
                                <span class="status-badge" style="background: #ef4444; color: white;">{{ candidat.status }}</span>
                            {% elseif candidat.status == 'Accepté' %}
                                <span class="status-badge" style="background: #0FA36B; color: white;">{{ candidat.status }}</span>
                            {% elseif candidat.status == 'En revue' %}
                                <span class="status-badge" style="background: #f59e0b; color: white;">{{ candidat.status }}</span>
                            {% else %}
                                <span class="status-badge" style="background: var(--primary); color: white;">{{ candidat.status }}</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="action-buttons" style="display: flex; gap: 6px; flex-wrap: wrap;">
                                <button class="btn btn-info btn-sm view-candidat" data-id="{{ candidat.id }}"><i class="fas fa-eye"></i></button>
                                <a href="{{ path('app_candidat_edit', {'id': candidat.id}) }}" class="btn btn-warning btn-sm"><i class="fas fa-edit"></i></a>
                                <form method="post" action="{{ path('app_candidat_delete', {'id': candidat.id}) }}" onsubmit="return confirm('Supprimer ce candidat ?');" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ candidat.id) }}">
                                    <button class="btn btn-danger btn-sm"><i class="fas fa-trash"></i></button>
                                </form>
                                <form method="post" action="{{ path('app_candidat_reject', {'id': candidat.id}) }}" onsubmit="return confirm('Confirmer le rejet de ce candidat ?');" style="display: inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ candidat.id) }}">
                                    <button class="btn btn-sm" style="background: #ef4444; color: white; border: none; border-radius: 8px; padding: 4px 10px;"><i class="fas fa-times-circle"></i> Rejeter</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6">Aucun candidat trouvé. <button class="btn btn-success btn-sm" id="openCandidatModalBtn2" style="margin-left: 10px;">+ Ajouter</button></td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# MODALES #}
    <div id="jobModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-briefcase"></i> Ajouter une offre</h3>
                <span class="close-btn" onclick="closeModal('jobModal')">&times;</span>
            </div>
            <div class="modal-body">
                {{ form_start(jobForm, {'action': path('app_recruitment_dashboard', {'modal': 'job_new'}), 'attr': {'class': 'form-grid', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">{{ form_row(jobForm.title, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(jobForm.departement, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(jobForm.employeeType, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(jobForm.status, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group full">{{ form_row(jobForm.description, {'attr': {'class': 'form-control', 'rows': 3}}) }}</div>
                <div class="form-group">{{ form_row(jobForm.postedAt, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" onclick="closeModal('jobModal')">Annuler</button>
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                </div>
                {{ form_end(jobForm) }}
            </div>
        </div>
    </div>

    <div id="candidatModal" class="modal" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3><i class="fas fa-user-plus"></i> Ajouter un candidat</h3>
                <span class="close-btn" onclick="closeModal('candidatModal')">&times;</span>
            </div>
            <div class="modal-body">
                {{ form_start(candidatForm, {'action': path('app_recruitment_dashboard', {'modal': 'candidat_new'}), 'attr': {'class': 'form-grid', 'novalidate': 'novalidate'}}) }}
                <div class="form-group">{{ form_row(candidatForm.firstName, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(candidatForm.lastName, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(candidatForm.email, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(candidatForm.phone, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(candidatForm.educationLevel, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group">{{ form_row(candidatForm.status, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="form-group full">{{ form_row(candidatForm.skills, {'attr': {'class': 'form-control', 'rows': 2}}) }}</div>
                <div class="form-group full">{{ form_row(candidatForm.jobposition, {'attr': {'class': 'form-control'}}) }}</div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" onclick="closeModal('candidatModal')">Annuler</button>
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                </div>
                {{ form_end(candidatForm) }}
            </div>
        </div>
    </div>

    <div id="candidatDetailModal" class="modal" style="display: none;">
        <div class="modal-content" style="max-width: 600px;">
            <div class="modal-header">
                <h3><i class="fas fa-id-card"></i> Détails du candidat</h3>
                <span class="close-btn" style="cursor: pointer; font-size: 28px;" onclick="document.getElementById('candidatDetailModal').style.display='none'">&times;</span>
            </div>
            <div class="modal-body">
                <div class="detail-row"><strong>Nom complet :</strong> <span id="detailFullName"></span></div>
                <div class="detail-row"><strong>Email :</strong> <span id="detailEmail"></span></div>
                <div class="detail-row"><strong>Téléphone :</strong> <span id="detailPhone"></span></div>
                <div class="detail-row"><strong>Niveau d'études :</strong> <span id="detailEducation"></span></div>
                <div class="detail-row"><strong>Compétences :</strong> <span id="detailSkills"></span></div>
                <div class="detail-row"><strong>Statut :</strong> <span id="detailStatus"></span></div>
                <div class="detail-row"><strong>Offre associée :</strong> <span id="detailJob"></span></div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" onclick="document.getElementById('candidatDetailModal').style.display='none'">Fermer</button>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.querySelectorAll('.job-card').forEach(card => {
            card.addEventListener('click', (e) => {
                if (e.target.closest('.btn-warning') || e.target.closest('.btn-danger')) return;
                const jobId = card.dataset.jobId;
                if (jobId) {
                    const url = new URL(window.location.href);
                    url.searchParams.set('job', jobId);
                    url.searchParams.delete('search_candidat');
                    window.location.href = url.toString();
                }
            });
        });

        window.onclick = function(event) {
            if (event.target.classList.contains('modal')) {
                event.target.style.display = 'none';
            }
        };

        document.querySelectorAll('.view-candidat').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                const candidatId = btn.dataset.id;
                try {
                    const response = await fetch(`/candidat/details/${candidatId}`);
                    const data = await response.json();
                    document.getElementById('detailFullName').innerText = `${data.firstName} ${data.lastName}`;
                    document.getElementById('detailEmail').innerText = data.email;
                    document.getElementById('detailPhone').innerText = data.phone;
                    document.getElementById('detailEducation').innerText = data.educationLevel;
                    document.getElementById('detailSkills').innerText = data.skills;
                    document.getElementById('detailStatus').innerText = data.status;
                    document.getElementById('detailJob').innerText = data.jobTitle;
                    document.getElementById('candidatDetailModal').style.display = 'flex';
                } catch (error) {
                    console.error('Erreur:', error);
                }
            });
        });

        function openModal(modalId) { document.getElementById(modalId).style.display = 'flex'; }
        function closeModal(modalId) { document.getElementById(modalId).style.display = 'none'; }

        const openJobModalBtn = document.getElementById('openJobModalBtn');
        if (openJobModalBtn) openJobModalBtn.addEventListener('click', () => openModal('jobModal'));

        const openCandidatModalBtn = document.getElementById('openCandidatModalBtn');
        const openCandidatModalBtn2 = document.getElementById('openCandidatModalBtn2');
        if (openCandidatModalBtn) openCandidatModalBtn.addEventListener('click', () => openModal('candidatModal'));
        if (openCandidatModalBtn2) openCandidatModalBtn2.addEventListener('click', () => openModal('candidatModal'));
    </script>
{% endblock %}