{% extends 'admin/base_admin.html.twig' %}

{% block title %}Analyse de CV par IA{% endblock %}
{% block page_title %}Analyse de CV{% endblock %}
{% block breadcrumb %}Recrutement / Analyse CV{% endblock %}

{% block admin_content %}
    <style>
        :root {
            --bg: #f6f8fc;
            --white: #ffffff;
            --primary: #6c63ff;
            --primary-light: #ecebff;
            --blue-soft: #eaf2ff;
            --green: #22c55e;
            --green-light: #eafbf1;
            --orange: #f59e0b;
            --orange-light: #fff6e5;
            --red: #ef4444;
            --red-light: #ffecec;
            --text: #243046;
            --muted: #7b8798;
            --border: #e7ebf3;
            --shadow: 0 10px 30px rgba(108, 99, 255, 0.08);
            --radius-xl: 28px;
            --radius-lg: 20px;
            --radius-md: 14px;
        }

        body {
            background: linear-gradient(180deg, #f8faff 0%, #f5f7fb 100%);
            color: var(--text);
        }

        .cv-wrapper {
            max-width: 1380px;
            margin: 30px auto;
            padding: 0 20px 40px;
        }

        .hero {
            background: linear-gradient(135deg, #f3f0ff 0%, #eef4ff 50%, #f9fbff 100%);
            border: 1px solid #ebeefe;
            border-radius: 32px;
            padding: 28px;
            box-shadow: var(--shadow);
            margin-bottom: 24px;
        }

        .hero-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .hero-left {
            display: flex;
            align-items: center;
            gap: 18px;
        }

        .hero-icon {
            width: 72px;
            height: 72px;
            border-radius: 24px;
            background: linear-gradient(135deg, #6c63ff, #8b7bff);
            color: white;
            font-size: 24px;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 12px 25px rgba(108, 99, 255, 0.22);
        }

        .hero h1 {
            margin: 0;
            font-size: 2rem;
            font-weight: 800;
            color: #2b3674;
        }

        .hero p {
            margin: 8px 0 0;
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.6;
            max-width: 780px;
        }

        .hero-tags {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 16px;
        }

        .hero-tag {
            background: white;
            border: 1px solid #e8eafb;
            color: #5c5f8f;
            padding: 9px 14px;
            border-radius: 999px;
            font-size: 0.9rem;
            font-weight: 600;
        }

        .back-btn {
            text-decoration: none;
            padding: 12px 18px;
            border-radius: 14px;
            background: white;
            border: 1px solid #e6e9f5;
            color: #4c57a6;
            font-weight: 700;
            transition: 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(108, 99, 255, 0.10);
            color: #4c57a6;
        }

        .grid-top {
            display: grid;
            grid-template-columns: 1.1fr 0.9fr;
            gap: 22px;
            margin-bottom: 22px;
        }

        .card-ui {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .step-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 20px;
        }

        .step-left {
            display: flex;
            align-items: center;
            gap: 14px;
        }

        .step-number {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            color: white;
            font-size: 1rem;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .s1 { background: linear-gradient(135deg, #6c63ff, #8d84ff); }
        .s2 { background: linear-gradient(135deg, #8b5cf6, #b084ff); }
        .s3 { background: linear-gradient(135deg, #f59e0b, #f8b84a); }

        .step-title {
            margin: 0;
            font-size: 1.15rem;
            font-weight: 800;
            color: #2a356d;
        }

        .step-subtitle {
            margin: 4px 0 0;
            color: var(--muted);
            font-size: 0.93rem;
        }

        .mini-label {
            padding: 8px 12px;
            border-radius: 999px;
            background: #f4f5ff;
            color: #665fd1;
            font-size: 0.85rem;
            font-weight: 700;
        }

        .upload-zone {
            display: grid;
            grid-template-columns: auto 1fr;
            gap: 14px;
            align-items: center;
            padding: 16px;
            background: #fafbff;
            border: 1px dashed #cfd5f7;
            border-radius: 18px;
            margin-bottom: 16px;
        }

        .file-btn {
            appearance: none;
            border: none;
            background: linear-gradient(135deg, #6c63ff, #8b7bff);
            color: white;
            font-weight: 700;
            padding: 13px 18px;
            border-radius: 14px;
            cursor: pointer;
            box-shadow: 0 10px 22px rgba(108, 99, 255, 0.20);
        }

        .file-display {
            min-height: 50px;
            display: flex;
            align-items: center;
            padding: 0 16px;
            background: white;
            border: 1px solid #e6eaf5;
            border-radius: 14px;
            color: #64748b;
            font-weight: 600;
        }

        .btn-row {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
            margin-bottom: 16px;
        }

        .btn-ui {
            border: none;
            border-radius: 14px;
            padding: 13px 18px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s ease;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-ui:hover {
            transform: translateY(-2px);
        }

        .btn-ui:disabled {
            opacity: 0.65;
            cursor: not-allowed;
            transform: none;
        }

        .btn-green {
            background: linear-gradient(135deg, #22c55e, #35d06f);
            color: white;
            box-shadow: 0 10px 22px rgba(34, 197, 94, 0.18);
        }

        .btn-purple {
            background: linear-gradient(135deg, #8b5cf6, #a77cff);
            color: white;
            box-shadow: 0 10px 22px rgba(139, 92, 246, 0.18);
            width: 100%;
        }

        .btn-add {
            background: linear-gradient(135deg, #22c55e, #3cd278);
            color: white;
        }

        .btn-reject {
            background: linear-gradient(135deg, #ef4444, #ff6a6a);
            color: white;
        }

        .btn-light {
            background: #f7f8fd;
            color: #586488;
            border: 1px solid #e5eaf5;
        }

        .input-ui,
        .select-ui,
        .textarea-ui {
            width: 100%;
            border: 1px solid #e5eaf5;
            background: #fcfdff;
            border-radius: 14px;
            padding: 13px 15px;
            color: var(--text);
            font-size: 0.95rem;
            outline: none;
            transition: 0.2s ease;
        }

        .input-ui:focus,
        .select-ui:focus,
        .textarea-ui:focus {
            border-color: #b8b7ff;
            box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.08);
            background: white;
        }

        .textarea-ui {
            resize: vertical;
            min-height: 140px;
        }

        .form-group-ui {
            margin-bottom: 16px;
        }

        .label-ui {
            display: block;
            margin-bottom: 8px;
            font-weight: 700;
            color: #3b4779;
            font-size: 0.93rem;
        }

        .helper {
            margin-top: 8px;
            font-size: 0.85rem;
            color: var(--muted);
        }

        .side-box {
            height: 100%;
            background: linear-gradient(180deg, #ffffff 0%, #f9faff 100%);
            border: 1px solid var(--border);
            border-radius: var(--radius-xl);
            padding: 24px;
            box-shadow: var(--shadow);
        }

        .side-box h3 {
            margin: 0 0 8px;
            color: #2b3674;
            font-size: 1.15rem;
            font-weight: 800;
        }

        .side-box p {
            margin: 0 0 18px;
            color: var(--muted);
            line-height: 1.7;
        }

        .info-card {
            display: flex;
            gap: 12px;
            align-items: flex-start;
            background: #fafbff;
            border: 1px solid #edf0f7;
            border-radius: 18px;
            padding: 14px;
            margin-bottom: 12px;
        }

        .info-icon {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            background: #f0edff;
            color: #6c63ff;
            font-weight: 800;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .info-card strong {
            display: block;
            margin-bottom: 4px;
            color: #33406f;
            font-size: 0.94rem;
        }

        .info-card span {
            color: #7b8798;
            font-size: 0.88rem;
            line-height: 1.5;
        }

        .result-card {
            display: none;
        }

        .result-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 16px;
            flex-wrap: wrap;
            margin-bottom: 18px;
        }

        .recommendation-badge {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 18px;
            border-radius: 999px;
            color: white;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .grid-form {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 18px;
        }

        .col-6 { grid-column: span 6; }
        .col-12 { grid-column: span 12; }

        .bottom-actions {
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            flex-wrap: wrap;
            margin-top: 20px;
            padding-top: 18px;
            border-top: 1px solid #edf0f7;
        }

        .modal {
            position: fixed;
            inset: 0;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(242, 245, 252, 0.75);
            backdrop-filter: blur(6px);
            z-index: 9999;
            padding: 24px;
        }

        .modal-content {
            width: 100%;
            max-width: 860px;
            background: white;
            border-radius: 28px;
            border: 1px solid #e9edf7;
            box-shadow: 0 20px 50px rgba(108, 99, 255, 0.12);
            overflow: hidden;
        }

        .modal-header {
            background: linear-gradient(135deg, #f2efff, #edf4ff);
            padding: 22px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            margin: 0;
            color: #37427d;
            font-weight: 800;
            font-size: 1.1rem;
        }

        .close-btn {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: white;
            border: 1px solid #e5eaf5;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 1.2rem;
            color: #64748b;
        }

        .modal-body {
            padding: 24px;
        }

        .modal-footer {
            padding: 0 24px 24px;
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            flex-wrap: wrap;
        }

        .letter-box {
            width: 100%;
            min-height: 320px;
            border: 1px solid #e5eaf5;
            border-radius: 18px;
            padding: 16px;
            background: #fcfdff;
            font-size: 0.95rem;
            line-height: 1.7;
            outline: none;
            resize: vertical;
            color: #243046;
        }

        .letter-box:focus {
            border-color: #b8b7ff;
            box-shadow: 0 0 0 4px rgba(108, 99, 255, 0.08);
            background: white;
        }

        .note {
            margin-top: 10px;
            color: var(--muted);
            font-size: 0.9rem;
        }

        @media (max-width: 1100px) {
            .grid-top {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .cv-wrapper {
                padding: 0 12px 28px;
                margin-top: 18px;
            }

            .hero {
                padding: 20px;
            }

            .hero h1 {
                font-size: 1.6rem;
            }

            .upload-zone {
                grid-template-columns: 1fr;
            }

            .col-6,
            .col-12 {
                grid-column: span 12;
            }

            .btn-row,
            .bottom-actions,
            .modal-footer {
                flex-direction: column;
            }

            .btn-ui {
                width: 100%;
            }
        }
    </style>

    <div class="cv-wrapper">
        <div class="hero">
            <div class="hero-top">
                <div class="hero-left">
                    <div class="hero-icon">IN</div>
                    <div>
                        <h1>Analyse de CV par IA</h1>
                        <p>
                            Importez un CV PDF, extrayez son contenu, analysez le profil avec l'IA
                            et prenez une décision dans une interface claire, moderne et professionnelle.
                        </p>
                        <div class="hero-tags">
                            <div class="hero-tag">PDF intelligent</div>
                            <div class="hero-tag">Analyse automatique</div>
                            <div class="hero-tag">Recrutement assisté</div>
                        </div>
                    </div>
                </div>

                <a href="{{ path('app_recruitment_dashboard') }}" class="back-btn">← Retour</a>
            </div>
        </div>

        <div class="grid-top">
            <div class="card-ui">
                <div class="step-head">
                    <div class="step-left">
                        <div class="step-number s1">1</div>
                        <div>
                            <h3 class="step-title">Sélectionner un CV</h3>
                            <p class="step-subtitle">Importez un fichier PDF depuis votre ordinateur.</p>
                        </div>
                    </div>
                    <div class="mini-label">Étape 1</div>
                </div>

                <div class="upload-zone">
                    <input type="file" id="cvFile" name="cv_file" accept=".pdf" class="file-btn">
                    <div class="file-display" id="fileNameDisplay">Aucun fichier sélectionné</div>
                </div>

                <div class="btn-row">
                    <button id="extractBtn" class="btn-ui btn-green" disabled>📄 Extraire le texte</button>
                </div>

                <div class="form-group-ui">
                    <label class="label-ui">Texte extrait</label>
                    <textarea id="cvText" rows="9" class="textarea-ui" placeholder="Le texte extrait apparaîtra ici..."></textarea>
                    <div class="helper">Le contenu extrait peut être relu avant l'analyse.</div>
                </div>
            </div>

            <div class="side-box">
                <h3>Flux de traitement</h3>
                <p>
                    Cette version mise sur un style plus lumineux, plus doux et plus propre,
                    tout en gardant une apparence sérieuse et professionnelle.
                </p>

                <div class="info-card">
                    <div class="info-icon">01</div>
                    <div>
                        <strong>Import simple</strong>
                        <span>Ajout rapide du CV avec affichage clair du fichier sélectionné.</span>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">02</div>
                    <div>
                        <strong>Extraction automatique</strong>
                        <span>Lecture du contenu du PDF pour préparer l'analyse du candidat.</span>
                    </div>
                </div>

                <div class="info-card">
                    <div class="info-icon">03</div>
                    <div>
                        <strong>Décision assistée</strong>
                        <span>Ajout du candidat ou préparation immédiate de la lettre de refus.</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-ui">
            <div class="step-head">
                <div class="step-left">
                    <div class="step-number s2">2</div>
                    <div>
                        <h3 class="step-title">Analyser avec l'IA</h3>
                        <p class="step-subtitle">Associez le CV à une offre puis lancez l'analyse.</p>
                    </div>
                </div>
                <div class="mini-label">Étape 2</div>
            </div>

            <div class="form-group-ui">
                <label class="label-ui">Offre associée</label>
                <select id="jobSelect" class="select-ui">
                    <option value="">-- Choisir une offre --</option>
                    {% for job in jobs %}
                        <option value="{{ job.idJob }}">{{ job.title }}</option>
                    {% endfor %}
                </select>
            </div>

            <button id="analyzeBtn" class="btn-ui btn-purple" disabled>🤖 Lancer l'analyse IA</button>
        </div>

        <div id="resultContainer" class="card-ui result-card" style="margin-top: 22px;">
            <div class="result-top">
                <div class="step-left">
                    <div class="step-number s3">3</div>
                    <div>
                        <h3 class="step-title">Résultat de l'analyse</h3>
                        <p class="step-subtitle">Vérifiez les données avant de confirmer votre décision.</p>
                    </div>
                </div>

                <div id="recommendationBadge" class="recommendation-badge"></div>
            </div>

            <div class="grid-form">
                <div class="col-6">
                    <div class="form-group-ui">
                        <label class="label-ui">Prénom</label>
                        <input type="text" id="editFirstName" class="input-ui">
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-group-ui">
                        <label class="label-ui">Nom</label>
                        <input type="text" id="editLastName" class="input-ui">
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-group-ui">
                        <label class="label-ui">Email <span style="color:#ef4444">*</span></label>
                        <input type="email" id="editEmail" class="input-ui" required>
                    </div>
                </div>

                <div class="col-6">
                    <div class="form-group-ui">
                        <label class="label-ui">Téléphone</label>
                        <input type="text" id="editPhone" class="input-ui">
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group-ui">
                        <label class="label-ui">Niveau d'études</label>
                        <input type="text" id="editEducation" class="input-ui">
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group-ui">
                        <label class="label-ui">Compétences</label>
                        <textarea id="editSkills" rows="4" class="textarea-ui"></textarea>
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group-ui">
                        <label class="label-ui">Poste visé</label>
                        <input type="text" id="editJobTitle" class="input-ui">
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group-ui">
                        <label class="label-ui">Justification IA</label>
                        <textarea id="editReason" rows="5" class="textarea-ui" readonly></textarea>
                    </div>
                </div>
            </div>

            <div class="bottom-actions">
                <button id="addCandidateBtn" class="btn-ui btn-add">✅ Ajouter le candidat</button>
                <button id="rejectBtn" class="btn-ui btn-reject">❌ Rejeter</button>
            </div>
        </div>
    </div>

    <div id="rejectionModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Lettre de refus générée par l'IA</h3>
                <span class="close-btn" onclick="closeRejectionModal()">&times;</span>
            </div>

            <div class="modal-body">
                <textarea id="rejectionLetterText" class="letter-box"></textarea>
                <p class="note">Vous pouvez modifier librement cette lettre avant l'envoi.</p>
            </div>

            <div class="modal-footer">
                <button class="btn-ui btn-light" onclick="closeRejectionModal()">Annuler</button>
                <button id="confirmSendRejectionBtn" class="btn-ui btn-reject">📧 Envoyer la lettre</button>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        let currentFilePath = null;
        let currentCvText = null;
        let currentJobId = null;
        let currentAnalysis = null;
        let currentCandidatId = null;

        $('#cvFile').on('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            if (file.name.split('.').pop().toLowerCase() !== 'pdf') {
                alert('Seuls les PDF sont acceptés.');
                $(this).val('');
                $('#fileNameDisplay').text('Aucun fichier sélectionné');
                return;
            }

            $('#fileNameDisplay').text(file.name);

            const formData = new FormData();
            formData.append('cv_file', file);

            $.ajax({
                url: '{{ path('app_cv_upload') }}',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                success: function(data) {
                    if (data.error) {
                        alert('Erreur : ' + data.error);
                        return;
                    }

                    currentFilePath = data.filePath;
                    $('#extractBtn').prop('disabled', false);
                },
                error: function(xhr) {
                    const msg = xhr.responseJSON ? xhr.responseJSON.error : 'Erreur upload';
                    alert(msg);
                }
            });
        });

        $('#extractBtn').on('click', function() {
            if (!currentFilePath) return;

            $.ajax({
                url: '{{ path('app_cv_extract') }}',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({ filePath: currentFilePath }),
                success: function(data) {
                    if (data.error) {
                        alert(data.error);
                        return;
                    }

                    currentCvText = data.text;
                    $('#cvText').val(currentCvText);
                    $('#analyzeBtn').prop('disabled', false);
                },
                error: function() {
                    alert('Erreur extraction');
                }
            });
        });

        $('#analyzeBtn').on('click', function() {
            const jobId = $('#jobSelect').val();

            if (!jobId) {
                alert('Choisissez une offre.');
                return;
            }

            if (!currentCvText) {
                alert('Extrayez d\'abord le texte.');
                return;
            }

            currentJobId = jobId;
            $('#analyzeBtn').prop('disabled', true).text('⏳ Analyse en cours...');

            $.ajax({
                url: '{{ path('app_cv_analyze_ai') }}',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    text: currentCvText,
                    jobId: jobId
                }),
                success: function(data) {
                    if (data.error) {
                        alert('Erreur analyse : ' + data.error);
                        $('#analyzeBtn').prop('disabled', false).text('🤖 Lancer l\'analyse IA');
                        return;
                    }

                    currentAnalysis = data;

                    const rec = data.recommendation;
                    const badge = $('#recommendationBadge');

                    badge.text(
                        rec === 'garder'
                            ? '✅ GARDER'
                            : (rec === 'rejeter' ? '❌ REJETER' : '❓ ' + rec)
                    );

                    badge.css(
                        'background',
                        rec === 'garder'
                            ? 'linear-gradient(135deg, #22c55e, #3cd278)'
                            : (rec === 'rejeter'
                                ? 'linear-gradient(135deg, #ef4444, #ff6a6a)'
                                : 'linear-gradient(135deg, #f59e0b, #f8b84a)')
                    );

                    $('#editFirstName').val(data.firstName || '');
                    $('#editLastName').val(data.lastName || '');
                    $('#editEmail').val(data.email || '');
                    $('#editPhone').val(data.phone || '');
                    $('#editEducation').val(data.educationLevel || '');
                    $('#editSkills').val(data.skills || '');
                    $('#editJobTitle').val(data.jobTitle || '');
                    $('#editReason').val(data.reason || '');

                    $('#resultContainer').fadeIn(250);
                    $('#analyzeBtn').prop('disabled', false).text('🤖 Lancer l\'analyse IA');
                },
                error: function(xhr) {
                    const msg = xhr.responseJSON ? xhr.responseJSON.error : 'Erreur analyse IA';
                    alert(msg);
                    $('#analyzeBtn').prop('disabled', false).text('🤖 Lancer l\'analyse IA');
                }
            });
        });

        $('#addCandidateBtn').on('click', function() {
            if (!currentAnalysis || !currentJobId) return;

            const firstName = $('#editFirstName').val();
            const lastName = $('#editLastName').val();
            const email = $('#editEmail').val();
            const phone = $('#editPhone').val();
            const education = $('#editEducation').val();
            const skills = $('#editSkills').val();

            if (!email) {
                alert("L'adresse email est obligatoire pour ajouter le candidat.");
                return;
            }

            const params = new URLSearchParams({
                modal: 'candidat_new',
                job: currentJobId,
                firstName: firstName,
                lastName: lastName,
                email: email,
                phone: phone,
                educationLevel: education,
                skills: skills,
                status: currentAnalysis.recommendation === 'garder' ? 'En revue' : 'Rejeté'
            });

            window.location.href = '{{ path('app_recruitment_dashboard') }}?' + params.toString();
        });

        $('#rejectBtn').on('click', function() {
            if (!currentAnalysis || !currentJobId) {
                alert('Veuillez d\'abord analyser un CV.');
                return;
            }

            const firstName = $('#editFirstName').val();
            const lastName = $('#editLastName').val();
            const email = $('#editEmail').val();
            const phone = $('#editPhone').val();
            const education = $('#editEducation').val();
            const skills = $('#editSkills').val();
            const jobTitle = $('#editJobTitle').val();
            const reason = $('#editReason').val();

            if (!email) {
                alert("L'adresse email est obligatoire pour envoyer la lettre de refus.");
                return;
            }

            $('#rejectBtn').prop('disabled', true).text('⏳ Préparation...');

            $.ajax({
                url: '{{ path('app_cv_add_rejected_candidate') }}',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    firstName: firstName,
                    lastName: lastName,
                    email: email,
                    phone: phone,
                    educationLevel: education,
                    skills: skills,
                    status: 'Rejeté',
                    jobId: currentJobId
                }),
                success: function(data) {
                    if (data.error) {
                        alert(data.error);
                        $('#rejectBtn').prop('disabled', false).text('❌ Rejeter');
                        return;
                    }

                    currentCandidatId = data.candidatId;

                    $.ajax({
                        url: '{{ path('app_generate_rejection_letter') }}',
                        type: 'POST',
                        contentType: 'application/json',
                        data: JSON.stringify({
                            firstName: firstName,
                            lastName: lastName,
                            jobTitle: jobTitle,
                            reason: reason
                        }),
                        success: function(letterData) {
                            if (letterData.error) {
                                alert(letterData.error);
                                $('#rejectBtn').prop('disabled', false).text('❌ Rejeter');
                                return;
                            }

                            $('#rejectionLetterText').val(letterData.letter);

                            $('#rejectionModal')
                                .data('candidatId', currentCandidatId)
                                .data('jobId', currentJobId)
                                .data('toEmail', email);

                            $('#rejectionModal').css('display', 'flex');
                            $('#rejectBtn').prop('disabled', false).text('❌ Rejeter');
                        },
                        error: function() {
                            alert('Erreur génération lettre');
                            $('#rejectBtn').prop('disabled', false).text('❌ Rejeter');
                        }
                    });
                },
                error: function(xhr) {
                    let msg = 'Erreur création candidat';
                    if (xhr.responseJSON && xhr.responseJSON.error) {
                        msg = xhr.responseJSON.error;
                    }
                    alert(msg);
                    $('#rejectBtn').prop('disabled', false).text('❌ Rejeter');
                }
            });
        });

        function closeRejectionModal() {
            $('#rejectionModal').css('display', 'none');
        }

        $('#confirmSendRejectionBtn').on('click', function() {
            const letter = $('#rejectionLetterText').val().trim();
            const toEmail = $('#editEmail').val().trim();
            const jobTitle = $('#editJobTitle').val().trim() || 'Poste';

            if (!toEmail) {
                alert("L'adresse email est obligatoire.");
                return;
            }

            if (!letter) {
                alert("La lettre est vide.");
                return;
            }

            const subject = `Suite à votre candidature - ${jobTitle}`;
            const body = letter;

            const mailtoLink =
                `mailto:${encodeURIComponent(toEmail)}` +
                `?subject=${encodeURIComponent(subject)}` +
                `&body=${encodeURIComponent(body)}`;

            window.location.href = mailtoLink;

            alert('Votre messagerie va s\'ouvrir avec la lettre déjà préparée.');
            closeRejectionModal();
        });
    </script>
{% endblock %}