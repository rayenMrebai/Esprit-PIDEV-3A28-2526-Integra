<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}INTEGRA Recruitment{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/integra.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="hold-transition sidebar-mini">
<div class="wrapper">
    <!-- Navbar (barre du haut avec le bouton menu) -->
    <nav class="main-header navbar navbar-expand navbar-white navbar-light">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
            </li>
        </ul>
        <ul class="navbar-nav ml-auto">
            <li class="nav-item">
                <a class="nav-link" href="{{ path('app_logout') }}">Déconnexion</a>
            </li>
        </ul>
    </nav>

    <!-- Sidebar (AdminLTE) -->
    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a href="{{ path('app_recruitment_dashboard') }}" class="brand-link">
            <span class="brand-text font-weight-light">INTEGRA RH</span>
        </a>
        <div class="sidebar">
            <nav class="mt-2">
                <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                    <li class="nav-item">
                        <a href="{{ path('app_recruitment_dashboard') }}" class="nav-link">
                            <i class="nav-icon fas fa-briefcase"></i>
                            <p>Recrutement</p>
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>

    <!-- Content Wrapper (contenu principal) -->
    <div class="content-wrapper" style="background: #f0f4f8;">
        <!-- Ta barre d'en-tête personnalisée (main-header) - étendue sur toute la largeur -->
        <div class="main-header" style="margin: 20px; border-radius: 20px;">
            <div class="logo-area">
                <div class="logo-icon">IN</div>
                <div class="logo-text">
                    <h1>INTEGRA RECRUITMENT</h1>
                    <p>Gestion des recrutements</p>
                </div>
            </div>
            <div>
                <div class="user-info">
                    <strong>{{ app.user.username|default('Admin User') }}</strong><br>
                    <span>{{ app.user.role|default('Administrateur') }}</span>
                </div>
                <a href="{{ path('app_recruitment_statistiques') }}" class="btn btn-outline-light" style="margin-left: 15px;">
                    <i class="fas fa-chart-line"></i> Statistiques
                </a>
            </div>
        </div>

        <!-- Conteneur pour le contenu des pages -->
        <div class="dashboard-container" style="padding: 0 20px 20px 20px;">
            {% block body %}{% endblock %}
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>