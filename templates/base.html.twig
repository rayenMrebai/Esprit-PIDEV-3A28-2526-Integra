<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}INTEGRA Recruitment{% endblock %}</title>
    <link rel="stylesheet" href="{{ asset('css/integra.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <!-- AdminLTE CSS pour la sidebar uniquement -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">
    {% block stylesheets %}{% endblock %}
</head>
<body class="hold-transition sidebar-mini">
<div class="wrapper">
    <!-- Sidebar (AdminLTE) -->
    <aside class="main-sidebar sidebar-dark-primary elevation-4">
        <a href="{{ path('app_recruitment_dashboard') }}" class="brand-link">
            <span class="brand-text font-weight-light">INTEGRA RH</span>
        </a>
        <div class="sidebar">
            <nav class="mt-2">
                <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                    <!-- Lien vers le dashboard recrutement -->
                    <li class="nav-item">
                        <a href="{{ path('app_recruitment_dashboard') }}" class="nav-link">
                            <i class="nav-icon fas fa-briefcase"></i>
                            <p>Recrutement</p>
                        </a>
                    </li>
                    <!-- Lien vers le profil utilisateur (retour à l'interface user) -->
                    <li class="nav-item">
                        <a href="{{ path('app_profile') }}" class="nav-link">
                            <i class="nav-icon fas fa-user"></i>
                            <p>Mon compte</p>
                        </a>
                    </li>
                    <!-- Tu peux ajouter d'autres liens ici (ex: Dashboard admin) -->
                </ul>
            </nav>
        </div>
    </aside>

    <!-- Content Wrapper (contenu principal) -->
    <div class="content-wrapper" style="background: #f0f4f8; min-height: 100vh;">
        <div style="padding: 20px;">
            {% block body %}{% endblock %}
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>