<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}INTEGRA RH{% endblock %}</title>
    
    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700,800" rel="stylesheet">

    <style>
        body {
            font-family: 'Open Sans', sans-serif;
            background-color: #f8fafc;
        }
        
        /* Bouton retour accueil flottant */
        .back-to-home {
            position: fixed;
            top: 20px;
            left: 20px;
            z-index: 1050;
        }
        .back-to-home a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            background: white;
            border-radius: 30px;
            color: #0B63CE;
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            transition: all 0.3s ease;
            border: 2px solid #e2e8f0;
        }
        .back-to-home a:hover {
            background: #0B63CE;
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(11,99,206,0.3);
        }
        
        /* Navbar améliorée */
        .navbar-dark.bg-dark {
            background: linear-gradient(to right, #1e293b, #0f172a) !important;
        }
        .navbar-brand {
            font-weight: 800;
            font-size: 1.3rem;
        }
        
        {% block stylesheets %}{% endblock %}
    </style>
</head>
<body>

    {# BOUTON RETOUR À L'ACCUEIL (visible sur toutes les pages) #}
    <div class="back-to-home">
        <a href="{{ path('front_acceuil') }}">
            <i class="fas fa-arrow-left"></i> Retour à l'accueil
        </a>
    </div>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            {# Logo redirige vers accueil si non connecté, profile si connecté #}
            {% if app.user %}
                <a class="navbar-brand" href="{{ path('app_profile') }}">
                    <i class="fas fa-shield-alt me-2"></i>INTEGRA RH
                </a>
            {% else %}
                <a class="navbar-brand" href="{{ path('front_acceuil') }}">
                    <i class="fas fa-shield-alt me-2"></i>INTEGRA RH
                </a>
            {% endif %}
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    {% if app.user %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_profile') }}">
                                <i class="fas fa-user-circle me-1"></i>Profile
                            </a>
                        </li>
                        
                        {% if is_granted('ROLE_MANAGER') %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_dashboard') }}">
                                    <i class="fas fa-chart-line me-1"></i>Dashboard
                                </a>
                            </li>
                        {% endif %}
                        
                        <li class="nav-item">
                            <a class="nav-link text-danger" href="{{ path('app_logout') }}"
                               onclick="return confirm('Voulez-vous vous déconnecter ?');">
                                <i class="fas fa-sign-out-alt me-1"></i>Logout
                            </a>
                        </li>
                        
                    {% else %}
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_login') }}">
                                <i class="fas fa-sign-in-alt me-1"></i>Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_register') }}">
                                <i class="fas fa-user-plus me-1"></i>Register
                            </a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <main class="container mt-4">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="fas fa-check-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="fas fa-exclamation-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        
        {% for message in app.flashes('info') %}
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="fas fa-info-circle me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        
        {% block body %}{% endblock %}
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% block javascripts %}{% endblock %}
</body>
</html>