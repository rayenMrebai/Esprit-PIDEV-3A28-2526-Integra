{% extends 'base.html.twig' %}

{% block title %}Skill index{% endblock %}

{% block body %}
    <h1>Skill index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Level_required</th>
                <th>Categorie</th>
                <th>Trainingprogram_id</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for skill in skills %}
            <tr>
                <td>{{ skill.id }}</td>
                <td>{{ skill.nom }}</td>
                <td>{{ skill.description }}</td>
                <td>{{ skill.level_required }}</td>
                <td>{{ skill.categorie }}</td>
                <td>{{ skill.trainingprogram_id.title }}</td>
                <td>
                    <a href="{{ path('app_skill_show', {'id': skill.id}) }}">show</a>
                    <a href="{{ path('app_skill_edit', {'id': skill.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_skill_new') }}">Create new</a>
{% endblock %}