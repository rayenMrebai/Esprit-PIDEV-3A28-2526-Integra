<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Arial, sans-serif; font-size: 11px; color: #333; padding: 30px; }

    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #667eea; padding-bottom: 15px; margin-bottom: 20px; }
    .company-name { font-size: 22px; font-weight: bold; color: #667eea; }
    .company-sub  { font-size: 11px; color: #888; }
    .logo         { max-height: 60px; }

    .doc-title { text-align: center; background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 12px; border-radius: 6px; font-size: 16px; font-weight: bold; margin-bottom: 20px; }

    .code-bar { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; padding: 8px 12px; display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 10px; color: #555; }
    .code-bar span { font-weight: bold; color: #333; }

    .section-title { background: #667eea; color: white; padding: 6px 12px; border-radius: 4px; font-size: 11px; font-weight: bold; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.5px; }

    .info-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .info-table td { padding: 7px 10px; border-bottom: 1px solid #f0f0f0; }
    .info-table td:first-child { font-weight: bold; color: #555; width: 35%; }
    .info-table td:last-child  { color: #222; }

    .salary-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
    .salary-table thead th { background: #f1f5f9; padding: 8px 10px; text-align: left; font-size: 10px; text-transform: uppercase; color: #64748b; border-bottom: 2px solid #e2e8f0; }
    .salary-table tbody td { padding: 8px 10px; border-bottom: 1px solid #f8fafc; }
    .salary-table tbody tr:hover td { background: #fafafa; }
    .amount-right { text-align: right; font-weight: 600; }

    .total-box { background: linear-gradient(135deg, #667eea, #764ba2); color: white; padding: 16px 20px; border-radius: 8px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .total-label { font-size: 14px; font-weight: bold; }
    .total-amount { font-size: 26px; font-weight: bold; }

    .payment-box { border: 1px solid #e2e8f0; border-radius: 6px; padding: 12px 16px; margin-bottom: 20px; }
    .payment-row { display: flex; justify-content: space-between; padding: 5px 0; border-bottom: 1px solid #f5f5f5; font-size: 11px; }
    .payment-row:last-child { border-bottom: none; }

    .status-badge { display: inline-block; padding: 3px 10px; border-radius: 12px; font-size: 10px; font-weight: bold; }
    .status-paye    { background: rgba(40,167,69,0.15);  color: #28a745; }
    .status-encours { background: rgba(23,162,184,0.15); color: #17a2b8; }
    .status-cree    { background: rgba(255,193,7,0.15);  color: #856404; }

    .bonus-tag { display: inline-block; background: rgba(102,126,234,0.1); color: #667eea; padding: 2px 8px; border-radius: 4px; font-size: 10px; margin: 2px; border: 1px solid rgba(102,126,234,0.2); }

    .footer { border-top: 2px solid #e2e8f0; padding-top: 12px; text-align: center; color: #888; font-size: 9px; margin-top: 20px; }
    .footer strong { color: #667eea; }
</style>
</head>
<body>

{# ── EN-TÊTE ── #}
<div class="header">
    <div>
        <div class="company-name">INTEGRA RH</div>
        <div class="company-sub">Système de Gestion des Ressources Humaines</div>
    </div>
    {% if logoBase64 %}
        <img src="{{ logoBase64 }}" alt="Logo INTEGRA" class="logo">
    {% endif %}
</div>

{# ── TITRE ── #}
<div class="doc-title">FICHE DE PAIE</div>

{# ── CODE UNIQUE ── #}
<div class="code-bar">
    <div>Code fiche : <span>{{ code }}</span></div>
    <div>Générée le : <span>{{ generatedAt|date('d/m/Y à H:i') }}</span></div>
</div>

{# ── INFORMATIONS EMPLOYÉ ── #}
<div class="section-title">Informations Employé</div>
<table class="info-table">
    <tr>
        <td>Nom d'utilisateur</td>
        <td>{{ salaire.user.username }}</td>
    </tr>
    <tr>
        <td>Email</td>
        <td>{{ salaire.user.email }}</td>
    </tr>
    <tr>
        <td>Période</td>
        <td>{{ salaire.datePaiement|date('F Y') }}</td>
    </tr>
    <tr>
        <td>Statut</td>
        <td>
            {% set sc = salaire.status == 'PAYÉ' ? 'status-paye' : (salaire.status == 'EN_COURS' ? 'status-encours' : 'status-cree') %}
            <span class="status-badge {{ sc }}">{{ salaire.status }}</span>
        </td>
    </tr>
</table>

{# ── DÉTAIL RÉMUNÉRATION ── #}
<div class="section-title">Détail de la Rémunération</div>
<table class="salary-table">
    <thead>
        <tr>
            <th>Élément</th>
            <th class="amount-right">Montant</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            <td>Salaire de base</td>
            <td class="amount-right">{{ salaire.baseAmount|number_format(2, ',', ' ') }} DT</td>
        </tr>

        {% if salaire.bonusRules|length > 0 %}
            {% for rule in salaire.bonusRules %}
                {% if rule.status == 'ACTIVE' %}
                <tr>
                    <td>
                        <span class="bonus-tag">{{ rule.nomRegle }} ({{ rule.percentage }}%)</span>
                        <br><small style="color:#888; font-size:9px;">{{ rule.conditionText|slice(0, 60) }}{% if rule.conditionText|length > 60 %}...{% endif %}</small>
                    </td>
                    <td class="amount-right" style="color:#28a745;">+ {{ rule.bonus|number_format(2, ',', ' ') }} DT</td>
                </tr>
                {% endif %}
            {% endfor %}
        {% endif %}

        {% if salaire.bonusAmount > 0 %}
        <tr style="background:#f8fff8;">
            <td style="color:#28a745; font-weight:bold;">Total des bonus</td>
            <td class="amount-right" style="color:#28a745; font-weight:bold;">+ {{ salaire.bonusAmount|number_format(2, ',', ' ') }} DT</td>
        </tr>
        {% endif %}
    </tbody>
</table>

{# ── TOTAL NET ── #}
<div class="total-box">
    <div class="total-label">TOTAL NET À PAYER</div>
    <div class="total-amount">{{ salaire.totalAmount|number_format(2, ',', ' ') }} DT</div>
</div>

{# ── INFOS PAIEMENT ── #}
<div class="section-title">Informations de Paiement</div>
<div class="payment-box">
    <div class="payment-row">
        <span>Date de paiement: </span>
        <strong> {{ salaire.datePaiement|date('d/m/Y') }}</strong>
    </div>
    <div class="payment-row">
        <span>Mode de paiement: </span>
        <strong> Virement bancaire</strong>
    </div>
    <div class="payment-row">
        <span>Statut: </span>
        <strong> {{ salaire.status }}</strong>
    </div>
</div>

{# ── PIED DE PAGE ── #}
<div class="footer">
    <strong>INTEGRA RH</strong> — Ce document est généré automatiquement par le système de gestion RH.<br>
    © {{ generatedAt|date('Y') }} INTEGRA — Tous droits réservés
</div>

</body>
</html>